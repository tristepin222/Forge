class LeftCounter {
    private variable value: i32

    function get(self) -> i32 => self.value
}

class RightCounter {
    private variable value: i32

    function get(self) -> i32 => self.value + 10
}

function main() {
    value left: LeftCounter = LeftCounter { value: 2 }
    value right: RightCounter = RightCounter { value: 5 }
    print(left.get())
    print(right.get())
}
