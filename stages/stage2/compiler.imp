# Lexer / parser state
VAR ch
VAR state
VAR need_read
VAR eof_flag
VAR emit_requested
VAR tok_type
VAR tok_len
VAR tok_ptr
VAR current_line
VAR token_line
VAR parser_state
VAR expr_line
VAR expr_pending_op
VAR expr_mul_pending
VAR expr_group_ptr
VAR expr_saved_op
VAR expr_target
VAR target_off
VAR next_var_offset
VAR next_label
VAR loop_start_label
VAR loop_end_label
VAR cond_op
VAR cond_rhs_kind
VAR cond_rhs_value
VAR lhs_kind
VAR lhs_value
VAR lookup_mode
VAR proc_hash
VAR proc_line
VAR arg_index
VAR call_mode
VAR in_proc
VAR proc_saved_sym_ptr
VAR proc_local_size
VAR post_store_state
VAR post_load_state
VAR post_lookup_state
VAR post_cond_state
VAR post_rhs_state
VAR post_expr_state

# Working variables
VAR temp
VAR temp2
VAR temp3
VAR temp4
VAR parse_ptr
VAR remaining
VAR result
VAR sign_flag
VAR token_char
VAR tok_hash
VAR emit_handled
VAR sym_ptr
VAR sym_scan
VAR found_off
VAR found_flag
VAR entry_char
VAR block_ptr

# Tables / arenas
VAR token_buf
VAR symbol_tbl
VAR block_tbl
VAR expr_group_tbl

# Bootstrap allocations
ALLOC token_buf 128
ALLOC symbol_tbl 512
ALLOC block_tbl 256
ALLOC expr_group_tbl 128

LET tok_ptr token_buf
LET tok_len 0
LET tok_type 0
LET state 0
LET need_read 1
LET eof_flag 0
LET emit_requested 0
LET tok_hash 0
LET current_line 1
LET token_line 1
LET parser_state 0
LET expr_line 0
LET expr_pending_op 0
LET expr_mul_pending 0
LET expr_group_ptr expr_group_tbl
LET expr_saved_op 0
LET expr_target 0
LET next_var_offset 0
LET next_label 0
LET lookup_mode 0
LET proc_hash 0
LET proc_line 0
LET arg_index 0
LET call_mode 0
LET in_proc 0
LET proc_saved_sym_ptr 0
LET proc_local_size 0
LET post_store_state 0
LET post_load_state 0
LET post_lookup_state 0
LET post_cond_state 0
LET post_rhs_state 0
LET post_expr_state 0
LET sym_ptr symbol_tbl
LET block_ptr block_tbl

# Emit a valid output program header.
WRITE_STR "BITS 64"
WRITE_CHAR 10
WRITE_STR "section .text"
WRITE_CHAR 10
WRITE_STR "global _start"
WRITE_CHAR 10
WRITE_CHAR 10
WRITE_STR "_start:"
WRITE_CHAR 10
WRITE_STR "    mov qword [alloc_ptr], heap"
WRITE_CHAR 10

WHILE 1 == 1
    LET emit_requested 0

    IF need_read == 1
        READ ch
        LET need_read 0
        IF ch == 10
            ADD current_line 1
        END
    END

    IF ch == 0
        LET eof_flag 1

        IF state == 1
            LET tok_type 1
            LET emit_requested 1
            LET state 0
        END

        IF state == 2
            LET tok_type 2
            LET emit_requested 1
            LET state 0
        END

        IF state == 3
            LET tok_type 3
            LET emit_requested 1
            LET state 0
        END

        IF state == 5
            LET tok_type 4
            LET emit_requested 1
            LET state 0
        END

        IF state == 6
            LET tok_type 4
            LET emit_requested 1
            LET state 0
        END
    END

    IF eof_flag == 0
        IF state == 4
            IF ch == 10
                LET state 0
            END
            LET need_read 1
        END

        IF state == 6
            IF ch == 61
                POKE tok_ptr ch
                ADD tok_ptr 8
                ADD tok_len 1
                LET tok_type 4
                LET emit_requested 1
                LET state 0
                LET need_read 1
            END

            IF state == 6
                LET tok_type 4
                LET emit_requested 1
                LET state 0
                LET need_read 0
            END
        END

        IF state == 5
            LET temp 0
            IF ch > 47
                IF ch < 58
                    LET temp 1
                END
            END

            IF temp == 1
                POKE tok_ptr ch
                ADD tok_ptr 8
                ADD tok_len 1
                LET state 2
                LET need_read 1
            END

            IF state == 5
                LET tok_type 4
                LET emit_requested 1
                LET state 0
                LET need_read 0
            END
        END

        IF state == 3
            IF ch == 34
                LET tok_type 3
                LET emit_requested 1
                LET state 0
                LET need_read 1
            END

            IF state == 3
                POKE tok_ptr ch
                ADD tok_ptr 8
                ADD tok_len 1
                LET need_read 1
            END
        END

        IF state == 2
            IF need_read == 0
                LET temp 0
                IF ch <= 32
                    LET temp 1
                END
                IF ch == 35
                    LET temp 1
                END
                IF ch == 34
                    LET temp 1
                END
                IF ch == 60
                    LET temp 1
                END
                IF ch == 62
                    LET temp 1
                END
                IF ch == 61
                    LET temp 1
                END
                IF ch == 33
                    LET temp 1
                END
                IF ch == 43
                    LET temp 1
                END
                IF ch == 42
                    LET temp 1
                END
                IF ch == 40
                    LET temp 1
                END
                IF ch == 41
                    LET temp 1
                END

                IF temp == 1
                    LET tok_type 2
                    LET emit_requested 1
                    LET state 0
                    LET need_read 0
                END

                IF state == 2
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET need_read 1
                END
            END
        END

        IF state == 1
            LET temp 0
            IF ch <= 32
                LET temp 1
            END
            IF ch == 35
                LET temp 1
            END
            IF ch == 34
                LET temp 1
            END
            IF ch == 60
                LET temp 1
            END
            IF ch == 62
                LET temp 1
            END
            IF ch == 61
                LET temp 1
            END
            IF ch == 33
                LET temp 1
            END
            IF ch == 43
                LET temp 1
            END
            IF ch == 42
                LET temp 1
            END
            IF ch == 40
                LET temp 1
            END
            IF ch == 41
                LET temp 1
            END

            IF temp == 1
                LET tok_type 1
                LET emit_requested 1
                LET state 0
                LET need_read 0
            END

            IF state == 1
                MUL tok_hash 131
                ADD tok_hash ch
                POKE tok_ptr ch
                ADD tok_ptr 8
                ADD tok_len 1
                LET need_read 1
            END
        END
        IF emit_requested == 0
        IF state == 0
            IF need_read == 0
                IF ch <= 32
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 35
                    LET state 4
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 34
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    LET state 3
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 60
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET state 6
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 62
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET state 6
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 61
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET state 6
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 33
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET state 6
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 40
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET tok_type 4
                    LET emit_requested 1
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 41
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET tok_type 4
                    LET emit_requested 1
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 43
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET tok_type 4
                    LET emit_requested 1
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 42
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET tok_type 4
                    LET emit_requested 1
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                IF ch == 45
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET state 5
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                LET temp 0
                IF ch > 47
                    IF ch < 58
                        LET temp 1
                    END
                END

                IF temp == 1
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET state 2
                    LET need_read 1
                END
            END
        END

        IF state == 0
            IF need_read == 0
                LET temp 0
                IF ch > 32
                    LET temp 1
                END
                IF ch == 35
                    LET temp 0
                END
                IF ch == 34
                    LET temp 0
                END
                IF ch == 60
                    LET temp 0
                END
                IF ch == 62
                    LET temp 0
                END
                IF ch == 61
                    LET temp 0
                END
                IF ch == 33
                    LET temp 0
                END
                IF ch == 45
                    LET temp 0
                END

                IF temp == 1
                    LET tok_ptr token_buf
                    LET tok_len 0
                    LET token_line current_line
                    LET tok_hash ch
                    POKE tok_ptr ch
                    ADD tok_ptr 8
                    ADD tok_len 1
                    LET state 1
                    LET need_read 1
                END
            END
        END
        END
    END

    IF emit_requested == 1
        LET emit_handled 0

        IF parser_state == 0
            IF tok_type == 1
                PEEK temp token_buf

                IF tok_len == 3
                    IF temp == 86
                        LET parser_state 1
                        LET emit_handled 1
                    END
                    IF temp == 76
                        LET parser_state 2
                        LET emit_handled 1
                    END
                    IF temp == 65
                        LET parser_state 8
                        LET emit_handled 1
                    END
                    IF temp == 83
                        LET parser_state 9
                        LET emit_handled 1
                    END
                    IF temp == 77
                        LET parser_state 10
                        LET emit_handled 1
                    END
                    IF temp == 82
                        WRITE_STR "    leave"
                        WRITE_CHAR 10
                        WRITE_STR "    ret"
                        WRITE_CHAR 10
                        LET emit_handled 1
                    END
                    IF temp == 69
                        LET parser_state 48
                        LET emit_handled 1
                    END
                END

                IF tok_len == 2
                    IF temp == 73
                        LET parser_state 14
                        LET emit_handled 1
                    END
                END

                IF tok_len == 5
                    IF temp == 80
                        LET parser_state 4
                        LET emit_handled 1
                    END
                    IF temp == 87
                        LET parser_state 17
                        LET emit_handled 1
                    END
                    IF temp == 65
                        LET parser_state 21
                        LET emit_handled 1
                    END
                END

                IF tok_len == 6
                    IF temp == 82
                        LET parser_state 35
                        LET emit_handled 1
                    END
                END

                IF tok_len == 9
                    IF temp == 87
                        PEEK temp2 token_buf
                        IF temp2 == 87
                            LET parse_ptr token_buf
                            ADD parse_ptr 48
                            PEEK temp3 parse_ptr
                            IF temp3 == 73
                                LET parser_state 5
                                LET emit_handled 1
                            END
                            IF temp3 == 83
                                LET parser_state 7
                                LET emit_handled 1
                            END
                        END
                    END
                END

                IF tok_len == 10
                    IF temp == 87
                        LET parser_state 6
                        LET emit_handled 1
                    END
                END

                IF tok_len == 4
                    IF temp == 69
                        LET parse_ptr token_buf
                        ADD parse_ptr 8
                        PEEK temp2 parse_ptr
                        IF temp2 == 88
                            WRITE_STR "    mov rax, 60"
                            WRITE_CHAR 10
                            WRITE_STR "    xor rdi, rdi"
                            WRITE_CHAR 10
                            WRITE_STR "    syscall"
                            WRITE_CHAR 10
                            LET emit_handled 1
                        END
                        IF temp2 == 76
                            IF block_ptr > block_tbl
                                SUB block_ptr 24
                                PEEK temp2 block_ptr
                                ADD block_ptr 8
                                PEEK temp3 block_ptr
                                ADD block_ptr 8
                                PEEK temp4 block_ptr

                                IF temp2 == 1
                                    IF temp4 == 0
                                        ADD next_label 1
                                        WRITE_STR "    jmp .IF_AFTER_"
                                        WRITE_INT next_label
                                        WRITE_CHAR 10
                                        WRITE_STR ".IF_END_"
                                        WRITE_INT temp3
                                        WRITE_STR ":"
                                        WRITE_CHAR 10
                                        POKE block_ptr next_label
                                        LET emit_handled 1
                                    END
                                END

                                ADD block_ptr 8
                            END
                        END
                    END
                    IF temp == 82
                        LET parser_state 20
                        LET emit_handled 1
                    END
                    IF temp == 67
                        LET parser_state 31
                        LET emit_handled 1
                    END
                    IF temp == 80
                        LET parse_ptr token_buf
                        ADD parse_ptr 8
                        PEEK temp2 parse_ptr
                        IF temp2 == 82
                            LET parser_state 32
                            LET emit_handled 1
                        END
                    END
                    IF temp == 80
                        LET parse_ptr token_buf
                        ADD parse_ptr 8
                        PEEK temp2 parse_ptr
                        IF temp2 == 79
                            LET parser_state 23
                        END
                        IF temp2 == 69
                            LET parser_state 22
                        END
                        LET emit_handled 1
                    END
                END
            END
        END

        IF emit_handled == 0
            IF parser_state == 31
                IF tok_type == 1
                    IF tok_len > 0
                        LET proc_hash tok_hash
                        LET proc_line token_line
                        LET arg_index 0
                        LET call_mode 0
                        LET parser_state 33
                    END
                END
                LET emit_handled 1
            END
        END

        IF emit_handled == 0
            IF parser_state == 32
                IF tok_type == 1
                    IF tok_len > 0
                        LET proc_hash tok_hash
                        LET proc_line token_line
                        LET arg_index 0
                        LET in_proc 1
                        LET proc_saved_sym_ptr sym_ptr
                        LET proc_local_size 0
                        ADD next_label 1
                        WRITE_STR "    jmp .PROC_END_"
                        WRITE_INT next_label
                        WRITE_CHAR 10
                        WRITE_STR ".PROC_"
                        WRITE_INT tok_hash
                        WRITE_STR ":"
                        WRITE_CHAR 10
                        WRITE_STR "    push rbp"
                        WRITE_CHAR 10
                        WRITE_STR "    mov rbp, rsp"
                        WRITE_CHAR 10
                        POKE block_ptr 3
                        ADD block_ptr 8
                        POKE block_ptr next_label
                        ADD block_ptr 8
                        POKE block_ptr tok_hash
                        ADD block_ptr 8
                        LET parser_state 34
                    END
                END
                LET emit_handled 1
            END
        END

        IF emit_handled == 0
            IF parser_state == 33
                IF token_line == proc_line
                    IF tok_type == 2
                        LET parse_ptr token_buf
                        LET remaining tok_len
                        LET result 0
                        LET sign_flag 0

                        IF remaining > 0
                            PEEK temp parse_ptr
                            IF temp == 45
                                LET sign_flag 1
                                ADD parse_ptr 8
                                SUB remaining 1
                            END
                        END

                        WHILE remaining > 0
                            PEEK temp parse_ptr
                            MUL result 10
                            SUB temp 48
                            ADD result temp
                            ADD parse_ptr 8
                            SUB remaining 1
                        END

                        IF sign_flag == 1
                            MUL result -1
                        END

                        LET temp2 arg_index
                        MUL temp2 8
                        ADD temp2 1024
                        WRITE_STR "    mov rax, "
                        WRITE_INT result
                        WRITE_CHAR 10
                        WRITE_STR "    mov [vars + "
                        WRITE_INT temp2
                        WRITE_STR "], rax"
                        WRITE_CHAR 10
                        ADD arg_index 1
                        LET emit_handled 1
                    END

                    IF emit_handled == 0
                        IF tok_type == 1
                            LET lookup_mode 4
                            LET parser_state 30
                        END
                    END
                END

                IF emit_handled == 0
                    IF token_line > proc_line
                        WRITE_STR "    call .PROC_"
                        WRITE_INT proc_hash
                        WRITE_CHAR 10
                        LET parser_state 0
                        IF call_mode == 1
                            LET post_store_state 0
                            LET parser_state 37
                        END
                        IF call_mode == 2
                            WRITE_STR "    call print_rax"
                            WRITE_CHAR 10
                            LET parser_state 0
                        END
                        IF call_mode == 3
                            WRITE_STR "    call print_int_raw"
                            WRITE_CHAR 10
                            LET parser_state 0
                        END
                        LET call_mode 0
                    END
                END
            END
        END

        IF emit_handled == 0
            IF parser_state == 36
                IF tok_type == 1
                    IF tok_len == 4
                        PEEK temp token_buf
                        IF temp == 67
                            LET parse_ptr token_buf
                            ADD parse_ptr 8
                            PEEK temp2 parse_ptr
                            IF temp2 == 65
                                LET emit_handled 1
                            END
                        END
                    END
                END

                IF emit_handled == 0
                    IF tok_type == 1
                        IF tok_len > 0
                            LET proc_hash tok_hash
                            LET proc_line token_line
                            LET arg_index 0
                            IF call_mode == 0
                                LET call_mode 1
                            END
                            LET parser_state 33
                            LET emit_handled 1
                        END
                    END
                END
            END
        END

        IF emit_handled == 0
            IF parser_state == 34
                IF token_line == proc_line
                    IF tok_type == 1
                        IF tok_len > 0
                            LET temp2 arg_index
                            MUL temp2 8
                            ADD temp2 1024
                            POKE sym_ptr tok_hash
                            ADD sym_ptr 8
                            POKE sym_ptr temp2
                            ADD sym_ptr 8
                            ADD arg_index 1
                            LET emit_handled 1
                        END
                    END
                END

                IF emit_handled == 0
                    IF token_line > proc_line
                        LET parser_state 0
                    END
                END
            END
        END

        IF emit_handled == 0
            IF parser_state == 1
                IF tok_type == 1
                    IF tok_len > 0
                        LET token_char tok_hash
                        IF in_proc == 1
                            ADD proc_local_size 8
                            WRITE_STR "    sub rsp, 8"
                            WRITE_CHAR 10
                            POKE sym_ptr token_char
                            ADD sym_ptr 8
                            LET temp2 proc_local_size
                            MUL temp2 -1
                            POKE sym_ptr temp2
                            ADD sym_ptr 8
                        END
                        IF in_proc == 0
                        POKE sym_ptr token_char
                        ADD sym_ptr 8
                        POKE sym_ptr next_var_offset
                        ADD sym_ptr 8
                        ADD next_var_offset 8
                        END
                    END
                END
                LET parser_state 0
                LET emit_handled 1
            END
        END

        IF emit_handled == 0
            IF tok_type == 1
                IF parser_state == 2
                    IF tok_len > 0
                        LET expr_line token_line
                        LET expr_pending_op 0
                        LET expr_target 1
                        LET lookup_mode 1
                        LET parser_state 30
                    END
                END
            END
        END

        IF emit_handled == 0
            IF parser_state == 30
                IF tok_type == 1
                    IF tok_len > 0
                        LET token_char tok_hash
                        LET sym_scan sym_ptr
                        LET found_off 0
                        WHILE sym_scan > symbol_tbl
                            SUB sym_scan 16
                            PEEK entry_char sym_scan
                            IF entry_char == token_char
                                ADD sym_scan 8
                                PEEK found_off sym_scan
                                LET sym_scan symbol_tbl
                            END
                        END

                        IF lookup_mode == 1
                            LET target_off found_off
                            LET parser_state 29
                        END
                        IF lookup_mode == 2
                            LET post_lookup_state 27
                            LET parser_state 39
                        END
                        IF lookup_mode == 3
                            LET post_lookup_state 40
                            LET parser_state 39
                        END
                        IF lookup_mode == 4
                            LET temp4 arg_index
                            MUL temp4 8
                            ADD temp4 1024
                            LET post_lookup_state 41
                            LET parser_state 39
                        END

                        LET lookup_mode 0
                        LET emit_handled 1
                    END
                END
            END
        END

        IF parser_state == 39
            IF found_off < 0
                WRITE_STR "    mov rax, [rbp - "
                LET temp2 found_off
                MUL temp2 -1
                WRITE_INT temp2
                WRITE_STR "]"
                WRITE_CHAR 10
            END
            IF found_off >= 0
                WRITE_STR "    mov rax, [vars + "
                WRITE_INT found_off
                WRITE_STR "]"
                WRITE_CHAR 10
            END
            LET parser_state post_lookup_state
        END

        IF parser_state == 40
            WRITE_STR "    pop rbx"
            WRITE_CHAR 10
            WRITE_STR "    imul rax, rbx"
            WRITE_CHAR 10
            LET parser_state 27
        END

        IF parser_state == 41
            WRITE_STR "    mov [vars + "
            WRITE_INT temp4
            WRITE_STR "], rax"
            WRITE_CHAR 10
            ADD arg_index 1
            LET parser_state 33
        END

        IF emit_handled == 0
            IF parser_state == 27
                IF token_line == expr_line
                    IF tok_type == 4
                        PEEK temp token_buf
                        IF expr_target == 6
                            IF temp == 60
                                LET cond_op 2
                                IF tok_len == 2
                                    LET cond_op 3
                                END
                                LET post_expr_state 60
                                LET parser_state 49
                                LET emit_handled 1
                            END
                            IF temp == 61
                                IF tok_len == 2
                                    LET cond_op 1
                                    LET post_expr_state 60
                                    LET parser_state 49
                                    LET emit_handled 1
                                END
                            END
                            IF temp == 62
                                LET cond_op 5
                                IF tok_len == 2
                                    LET cond_op 4
                                END
                                LET post_expr_state 60
                                LET parser_state 49
                                LET emit_handled 1
                            END
                        END
                        IF expr_target == 8
                            IF temp == 60
                                LET cond_op 2
                                IF tok_len == 2
                                    LET cond_op 3
                                END
                                LET post_expr_state 61
                                LET parser_state 49
                                LET emit_handled 1
                            END
                            IF temp == 61
                                IF tok_len == 2
                                    LET cond_op 1
                                    LET post_expr_state 61
                                    LET parser_state 49
                                    LET emit_handled 1
                                END
                            END
                            IF temp == 62
                                LET cond_op 5
                                IF tok_len == 2
                                    LET cond_op 4
                                END
                                LET post_expr_state 61
                                LET parser_state 49
                                LET emit_handled 1
                            END
                        END
                        IF temp == 42
                            WRITE_STR "    push rax"
                            WRITE_CHAR 10
                            LET expr_mul_pending 1
                            LET parser_state 29
                            LET emit_handled 1
                        END
                    END

                    IF emit_handled == 0
                        IF tok_type == 4
                            LET post_expr_state 51
                            LET parser_state 49
                            LET emit_handled 1
                        END
                    END
                END

                IF emit_handled == 0
                    LET post_expr_state 50
                    LET parser_state 49
                END
            END
        END

        IF parser_state == 49
            IF expr_mul_pending == 1
                WRITE_STR "    pop rbx"
                WRITE_CHAR 10
                WRITE_STR "    imul rax, rbx"
                WRITE_CHAR 10
                LET expr_mul_pending 0
            END
            IF expr_pending_op == 1
                WRITE_STR "    pop rbx"
                WRITE_CHAR 10
                WRITE_STR "    add rax, rbx"
                WRITE_CHAR 10
                LET expr_pending_op 0
            END
            IF expr_pending_op == 2
                WRITE_STR "    mov rcx, rax"
                WRITE_CHAR 10
                WRITE_STR "    pop rax"
                WRITE_CHAR 10
                WRITE_STR "    sub rax, rcx"
