                        END
                        IF temp == 65
                            LET parser_state 21
                            LET emit_handled 1
                        END
                    END

                    IF tok_len == 6
                        IF temp == 82
                            LET parser_state 35
                            LET emit_handled 1
                        END
                    END

                    IF tok_len == 9
                        IF temp == 87
                            PEEK temp2 token_buf
                            IF temp2 == 87
                                LET parse_ptr token_buf
                                ADD parse_ptr 48
                                PEEK temp3 parse_ptr
                                IF temp3 == 73
                                    LET parser_state 5
                                    LET emit_handled 1
                                END
                                IF temp3 == 83
                                    LET parser_state 7
                                    LET emit_handled 1
                                END
                            END
                        END
                    END

                    IF tok_len == 10
                        IF temp == 87
                            LET parser_state 6
                            LET emit_handled 1
                        END
                    END

                    IF tok_len == 4
                        IF temp == 69
                            LET parse_ptr token_buf
                            ADD parse_ptr 8
                            PEEK temp2 parse_ptr
                            IF temp2 == 88
                                WRITE_STR "    mov rax, 60"
                                WRITE_CHAR 10
                                WRITE_STR "    xor rdi, rdi"
                                WRITE_CHAR 10
                                WRITE_STR "    syscall"
                                WRITE_CHAR 10
                                LET emit_handled 1
                            END
                            IF temp2 == 76
                                IF block_ptr > block_tbl
                                    SUB block_ptr 24
                                    PEEK temp2 block_ptr
                                    ADD block_ptr 8
                                    PEEK temp3 block_ptr
                                    ADD block_ptr 8
                                    PEEK temp4 block_ptr

                                    IF temp2 == 1
                                        IF temp4 == 0
                                            ADD next_label 1
                                            WRITE_STR "    jmp .IF_AFTER_"
                                            WRITE_INT next_label
                                            WRITE_CHAR 10
                                            WRITE_STR ".IF_END_"
                                            WRITE_INT temp3
                                            WRITE_STR ":"
                                            WRITE_CHAR 10
                                            POKE block_ptr next_label
                                            LET emit_handled 1
                                        END
                                    END

                                    ADD block_ptr 8
                                END
                            END
                        END
                        IF temp == 82
                            LET parser_state 20
                            LET emit_handled 1
                        END
                        IF temp == 67
                            LET parser_state 31
                            LET emit_handled 1
                        END
                        IF temp == 80
                            LET parse_ptr token_buf
                            ADD parse_ptr 8
                            PEEK temp2 parse_ptr
                            IF temp2 == 82
                                LET parser_state 32
                                LET emit_handled 1
                            END
                        END
                        IF temp == 80
                            LET parse_ptr token_buf
                            ADD parse_ptr 8
                            PEEK temp2 parse_ptr
                            IF temp2 == 79
                                LET parser_state 23
                            END
                            IF temp2 == 69
                                LET parser_state 22
                            END
                            LET emit_handled 1
                        END
                    END
                END
            END
        END

        IF parser_state == 48
            IF block_ptr > block_tbl
                SUB block_ptr 24
                PEEK temp2 block_ptr
                ADD block_ptr 8
                PEEK temp3 block_ptr
                ADD block_ptr 8
                PEEK temp4 block_ptr

                IF temp2 == 1
                    IF temp4 == 0
                        WRITE_STR ".IF_END_"
                        WRITE_INT temp3
                        WRITE_STR ":"
                        WRITE_CHAR 10
                    END
                    IF temp4 > 0
                        WRITE_STR ".IF_AFTER_"
                        WRITE_INT temp4
                        WRITE_STR ":"
                        WRITE_CHAR 10
                    END
                END

                IF temp2 == 2
                    WRITE_STR "    jmp .WHILE_START_"
                    WRITE_INT temp3
                    WRITE_CHAR 10
                    WRITE_STR ".WHILE_END_"
                    WRITE_INT temp4
                    WRITE_STR ":"
                    WRITE_CHAR 10
                END

                IF temp2 == 3
                    LET sym_ptr proc_saved_sym_ptr
                    LET in_proc 0
                    LET proc_local_size 0
                    WRITE_STR "    leave"
                    WRITE_CHAR 10
                    WRITE_STR "    ret"
                    WRITE_CHAR 10
                    WRITE_STR ".PROC_END_"
                    WRITE_INT temp3
                    WRITE_STR ":"
                    WRITE_CHAR 10
                END

                SUB block_ptr 16
            END
            LET parser_state 0
        END

        IF emit_handled == 0
            WRITE_STR "parse error"
            WRITE_CHAR 10
            WRITE_STR "line: "
            WRITE_INT token_line
            WRITE_STR " token_type: "
            WRITE_INT tok_type
            WRITE_STR " parser_state: "
            WRITE_INT parser_state
            WRITE_STR " token: "
            LET parse_ptr token_buf
            LET remaining tok_len
            WHILE remaining > 0
                PEEK temp parse_ptr
                WRITE_CHAR temp
                ADD parse_ptr 8
                SUB remaining 1
            END
            WRITE_CHAR 10
            EXIT
        END
    END

    IF eof_flag == 1
        LET temp 0
        IF state == 0
            LET temp 1
        END
        IF temp == 0
            WRITE_STR "unexpected eof"
            WRITE_CHAR 10
            WRITE_STR "line: "
            WRITE_INT current_line
            WRITE_STR " lexer_state: "
            WRITE_INT state
            WRITE_CHAR 10
            EXIT
        END

        LET temp 0
        IF parser_state == 33
            WRITE_STR "    call .PROC_"
            WRITE_INT proc_hash
            WRITE_CHAR 10
            IF call_mode == 1
                IF target_off < 0
                    WRITE_STR "    mov [rbp - "
                    LET temp2 target_off
                    MUL temp2 -1
                    WRITE_INT temp2
                    WRITE_STR "], rax"
                    WRITE_CHAR 10
                END
                IF target_off >= 0
                    WRITE_STR "    mov [vars + "
                    WRITE_INT target_off
                    WRITE_STR "], rax"
                    WRITE_CHAR 10
                END
            END
            IF call_mode == 2
                WRITE_STR "    call print_rax"
                WRITE_CHAR 10
            END
            IF call_mode == 3
                WRITE_STR "    call print_int_raw"
                WRITE_CHAR 10
            END
            LET call_mode 0
            LET parser_state 0
        END
        IF parser_state == 34
            LET parser_state 0
        END
        IF parser_state == 0
            LET temp 1
        END
        IF temp == 0
            WRITE_STR "unexpected eof"
            WRITE_CHAR 10
            WRITE_STR "line: "
            WRITE_INT current_line
            WRITE_STR " parser_state: "
            WRITE_INT parser_state
            WRITE_STR " token_type: "
            WRITE_INT tok_type
            WRITE_STR " token: "
            LET parse_ptr token_buf
            LET remaining tok_len
            WHILE remaining > 0
                PEEK temp parse_ptr
                WRITE_CHAR temp
                ADD parse_ptr 8
                SUB remaining 1
            END
            WRITE_CHAR 10
            EXIT
        END

        IF block_ptr > block_tbl
            WRITE_STR "unbalanced END/blocks"
            WRITE_CHAR 10
            WRITE_STR "line: "
            WRITE_INT current_line
            WRITE_STR " parser_state: "
            WRITE_INT parser_state
            WRITE_CHAR 10
            EXIT
        END

        WRITE_STR "    mov rax, 60"
        WRITE_CHAR 10
        WRITE_STR "    xor rdi, rdi"
        WRITE_CHAR 10
        WRITE_STR "    syscall"
        WRITE_CHAR 10

        WRITE_CHAR 10
        WRITE_STR "print_rax:"
        WRITE_CHAR 10
        WRITE_STR "    push rbx"
        WRITE_CHAR 10
        WRITE_STR "    push rcx"
        WRITE_CHAR 10
        WRITE_STR "    push rdx"
        WRITE_CHAR 10
        WRITE_STR "    push rsi"
        WRITE_CHAR 10
        WRITE_STR "    push rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov rdi, int_buf + 31"
        WRITE_CHAR 10
        WRITE_STR "    mov byte [rdi], 10"
        WRITE_CHAR 10
        WRITE_STR "    mov rcx, 10"
        WRITE_CHAR 10
        WRITE_STR "    cmp rax, 0"
        WRITE_CHAR 10
        WRITE_STR "    jne .print_nonzero"
        WRITE_CHAR 10
        WRITE_STR "    dec rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov byte [rdi], '0'"
        WRITE_CHAR 10
        WRITE_STR "    jmp .print_emit"
        WRITE_CHAR 10
        WRITE_STR ".print_nonzero:"
        WRITE_CHAR 10
        WRITE_STR "    xor rsi, rsi"
        WRITE_CHAR 10
        WRITE_STR "    test rax, rax"
        WRITE_CHAR 10
        WRITE_STR "    jns .print_loop"
        WRITE_CHAR 10
        WRITE_STR "    neg rax"
        WRITE_CHAR 10
        WRITE_STR "    mov rsi, 1"
        WRITE_CHAR 10
        WRITE_STR ".print_loop:"
        WRITE_CHAR 10
        WRITE_STR "    xor rdx, rdx"
        WRITE_CHAR 10
        WRITE_STR "    div rcx"
        WRITE_CHAR 10
        WRITE_STR "    add dl, '0'"
        WRITE_CHAR 10
        WRITE_STR "    dec rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov [rdi], dl"
        WRITE_CHAR 10
        WRITE_STR "    test rax, rax"
        WRITE_CHAR 10
        WRITE_STR "    jnz .print_loop"
        WRITE_CHAR 10
        WRITE_STR "    test rsi, rsi"
        WRITE_CHAR 10
        WRITE_STR "    jz .print_emit"
        WRITE_CHAR 10
        WRITE_STR "    dec rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov byte [rdi], '-'"
        WRITE_CHAR 10
        WRITE_STR ".print_emit:"
        WRITE_CHAR 10
        WRITE_STR "    mov rax, 1"
        WRITE_CHAR 10
        WRITE_STR "    mov rsi, rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov rdi, 1"
        WRITE_CHAR 10
        WRITE_STR "    mov rdx, int_buf + 32"
        WRITE_CHAR 10
        WRITE_STR "    sub rdx, rsi"
        WRITE_CHAR 10
        WRITE_STR "    syscall"
        WRITE_CHAR 10
        WRITE_STR "    pop rdi"
        WRITE_CHAR 10
        WRITE_STR "    pop rsi"
        WRITE_CHAR 10
        WRITE_STR "    pop rdx"
        WRITE_CHAR 10
        WRITE_STR "    pop rcx"
        WRITE_CHAR 10
        WRITE_STR "    pop rbx"
        WRITE_CHAR 10
        WRITE_STR "    ret"
        WRITE_CHAR 10

        WRITE_CHAR 10
        WRITE_STR "print_int_raw:"
        WRITE_CHAR 10
        WRITE_STR "    push rbx"
        WRITE_CHAR 10
        WRITE_STR "    push rcx"
        WRITE_CHAR 10
        WRITE_STR "    push rdx"
        WRITE_CHAR 10
        WRITE_STR "    push rsi"
        WRITE_CHAR 10
        WRITE_STR "    push rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov rdi, int_buf + 31"
        WRITE_CHAR 10
        WRITE_STR "    mov rcx, 10"
        WRITE_CHAR 10
        WRITE_STR "    cmp rax, 0"
        WRITE_CHAR 10
        WRITE_STR "    jne .raw_nonzero"
        WRITE_CHAR 10
        WRITE_STR "    dec rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov byte [rdi], '0'"
        WRITE_CHAR 10
        WRITE_STR "    jmp .raw_emit"
        WRITE_CHAR 10
        WRITE_STR ".raw_nonzero:"
        WRITE_CHAR 10
        WRITE_STR "    xor rsi, rsi"
        WRITE_CHAR 10
        WRITE_STR "    test rax, rax"
        WRITE_CHAR 10
        WRITE_STR "    jns .raw_loop"
        WRITE_CHAR 10
        WRITE_STR "    neg rax"
        WRITE_CHAR 10
        WRITE_STR "    mov rsi, 1"
        WRITE_CHAR 10
        WRITE_STR ".raw_loop:"
        WRITE_CHAR 10
        WRITE_STR "    xor rdx, rdx"
        WRITE_CHAR 10
        WRITE_STR "    div rcx"
        WRITE_CHAR 10
        WRITE_STR "    add dl, '0'"
        WRITE_CHAR 10
        WRITE_STR "    dec rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov [rdi], dl"
        WRITE_CHAR 10
        WRITE_STR "    test rax, rax"
        WRITE_CHAR 10
        WRITE_STR "    jnz .raw_loop"
        WRITE_CHAR 10
        WRITE_STR "    test rsi, rsi"
        WRITE_CHAR 10
        WRITE_STR "    jz .raw_emit"
        WRITE_CHAR 10
        WRITE_STR "    dec rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov byte [rdi], '-'"
        WRITE_CHAR 10
        WRITE_STR ".raw_emit:"
        WRITE_CHAR 10
        WRITE_STR "    mov rax, 1"
        WRITE_CHAR 10
        WRITE_STR "    mov rsi, rdi"
        WRITE_CHAR 10
        WRITE_STR "    mov rdi, 1"
        WRITE_CHAR 10
        WRITE_STR "    mov rdx, int_buf + 31"
        WRITE_CHAR 10
        WRITE_STR "    sub rdx, rsi"
        WRITE_CHAR 10
        WRITE_STR "    syscall"
        WRITE_CHAR 10
        WRITE_STR "    pop rdi"
        WRITE_CHAR 10
        WRITE_STR "    pop rsi"
        WRITE_CHAR 10
        WRITE_STR "    pop rdx"
        WRITE_CHAR 10
        WRITE_STR "    pop rcx"
        WRITE_CHAR 10
        WRITE_STR "    pop rbx"
        WRITE_CHAR 10
        WRITE_STR "    ret"
        WRITE_CHAR 10

        WRITE_CHAR 10
        WRITE_STR "write_char:"
        WRITE_CHAR 10
        WRITE_STR "    mov [char_buf], al"
        WRITE_CHAR 10
        WRITE_STR "    push rax"
        WRITE_CHAR 10
        WRITE_STR "    push rdi"
        WRITE_CHAR 10
        WRITE_STR "    push rsi"
        WRITE_CHAR 10
        WRITE_STR "    push rdx"
        WRITE_CHAR 10
        WRITE_STR "    mov rax, 1"
        WRITE_CHAR 10
        WRITE_STR "    mov rdi, 1"
        WRITE_CHAR 10
        WRITE_STR "    mov rsi, char_buf"
        WRITE_CHAR 10
        WRITE_STR "    mov rdx, 1"
        WRITE_CHAR 10
        WRITE_STR "    syscall"
        WRITE_CHAR 10
        WRITE_STR "    pop rdx"
        WRITE_CHAR 10
        WRITE_STR "    pop rsi"
        WRITE_CHAR 10
        WRITE_STR "    pop rdi"
        WRITE_CHAR 10
        WRITE_STR "    pop rax"
        WRITE_CHAR 10
        WRITE_STR "    ret"
        WRITE_CHAR 10

        WRITE_CHAR 10
        WRITE_STR "section .bss"
        WRITE_CHAR 10
        WRITE_STR "vars    resq 256"
        WRITE_CHAR 10
        WRITE_STR "int_buf resb 32"
        WRITE_CHAR 10
        WRITE_STR "char_buf resb 1"
        WRITE_CHAR 10
        WRITE_STR "read_char resb 1"
        WRITE_CHAR 10
        WRITE_STR "cond_expr_lhs resq 1"
        WRITE_CHAR 10
        WRITE_STR "cond_expr_rhs resq 1"
        WRITE_CHAR 10
        WRITE_STR "alloc_ptr resq 1"
        WRITE_CHAR 10
        WRITE_STR "heap    resb 65536"
        WRITE_CHAR 10

        EXIT
    END
END
