    loop {
        kind = self.next_token()

        if kind == token_end() {
            return -1
        }

        if kind != token_symbol() {
            continue
        }

        if self.token_value == 123 {
            depth += 1
        } else {
            if self.token_value == 125 {
                depth -= 1

                if depth == 0 {
                    return 0
                }
            }
        }
    }
    return 0
}

function parse_named_brace_skip_tail(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.expect_identifier() != 0 {
        return -1
    }

    kind = self.next_token()
    if kind == token_symbol() {
        if self.token_value == 58 {
            if self.expect_identifier() != 0 {
                return -2
            }

            kind = self.next_token()
        }
    }

    if kind != token_symbol() {
        return -3
    }

    if self.token_value != 123 {
        return -4
    }

    return self.skip_brace_block()
}

function parse_class_declaration_tail(self: Lexer) -> i32 {
    return self.parse_named_brace_skip_tail()
}

function parse_class_declaration(self: Lexer) -> i32 {
    if self.expect_keyword(keyword_class()) != 0 {
        return -1
    }

    return self.parse_class_declaration_tail()
}

function parse_interface_declaration_tail(self: Lexer) -> i32 {
    return self.parse_named_brace_skip_tail()
}

function parse_interface_declaration(self: Lexer) -> i32 {
    if self.expect_keyword(keyword_interface()) != 0 {
        return -1
    }

    return self.parse_interface_declaration_tail()
}

function parse_implement_declaration_tail(self: Lexer) -> i32 {
    if self.expect_identifier() != 0 {
        return -1
    }

    if self.expect_keyword(keyword_for()) != 0 {
        return -2
    }

    if self.expect_identifier() != 0 {
        return -3
    }

    if self.expect_symbol(123) != 0 {
        return -4
    }

    return self.skip_brace_block()
}

function parse_implement_declaration(self: Lexer) -> i32 {
    if self.expect_keyword(keyword_implement()) != 0 {
        return -1
    }

    return self.parse_implement_declaration_tail()
}

function parse_public_declaration(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_keyword() {
        return -1
    }

    if self.token_value == keyword_function() {
        return self.parse_function_definition_tail()
    }

    if self.token_value == keyword_fn() {
        return self.parse_function_definition_tail()
    }

    if self.token_value == keyword_async() {
        return self.parse_function_definition()
    }

    if self.token_value == keyword_struct() {
        return self.parse_struct_declaration_tail()
    }

    if self.token_value == keyword_enum() {
        return self.parse_enum_declaration_tail()
    }

    if self.token_value == keyword_class() {
        return self.parse_class_declaration_tail()
    }

    if self.token_value == keyword_interface() {
        return self.parse_interface_declaration_tail()
    }

    return -2
}

function parse_private_declaration(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_keyword() {
        return -1
    }

    if self.token_value == keyword_function() {
        return self.parse_function_definition_tail()
    }

    if self.token_value == keyword_fn() {
        return self.parse_function_definition_tail()
    }

    if self.token_value == keyword_async() {
        return self.parse_function_definition()
    }

    if self.token_value == keyword_class() {
        return self.parse_class_declaration_tail()
    }

    if self.token_value == keyword_interface() {
        return self.parse_interface_declaration_tail()
    }

    return -2
}

function parse_dotted_name_tail(self: Lexer) -> i32 {
    if self.expect_identifier() != 0 {
        return -1
    }

    loop {
        if self.next_token() != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value != 46 {
            self.push_token()
            return 0
        }

        if self.expect_identifier() != 0 {
            return -2
        }
    }
    return 0
}

function skip_paren_block(self: Lexer) -> i32 {
    variable depth: i32 = 1
    variable kind: i32 = 0

    loop {
        kind = self.next_token()

        if kind == token_end() {
            return -1
        }

        if kind != token_symbol() {
            continue
        }

        if self.token_value == 40 {
            depth += 1
        } else {
            if self.token_value == 41 {
                depth -= 1

                if depth == 0 {
                    return 0
                }
            }
        }
    }
    return 0
}

function parse_annotation(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.expect_symbol(64) != 0 {
        return -1
    }

    if self.expect_identifier() != 0 {
        return -2
    }

    kind = self.next_token()
    if kind != token_symbol() {
        self.push_token()
        return 0
    }

    if self.token_value != 40 {
        self.push_token()
        return 0
    }

    return self.skip_paren_block()
}

function parse_module_declaration(self: Lexer) -> i32 {
    if self.expect_keyword(keyword_module()) != 0 {
        return -1
    }

    return self.parse_dotted_name_tail()
}

function parse_import_member_list_tail(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind == token_symbol() {
        if self.token_value == 125 {
            return 0
        }

        self.push_token()
    } else {
        self.push_token()
    }

    loop {
        if self.expect_identifier() != 0 {
            return -2
        }

        kind = self.next_token()
        if kind == token_keyword() {
            if self.token_value == keyword_as() {
                if self.expect_identifier() != 0 {
                    return -3
                }

                kind = self.next_token()
            } else {
                return -4
            }
        }

        if kind != token_symbol() {
            return -5
        }

        if self.token_value == 125 {
            return 0
        }

        if self.token_value != 44 {
            return -6
        }
    }
    return 0
}

function parse_import_declaration(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.expect_keyword(keyword_import()) != 0 {
        return -2
    }

    if self.expect_identifier() != 0 {
        return -3
    }

    loop {
        kind = self.next_token()
        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value != 46 {
            self.push_token()
            return 0
        }

        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 123 {
                return self.parse_import_member_list_tail()
            }
        }

        if kind != token_identifier() {
            return -4
        }
    }
    return 0
}

function parse_from_import_declaration(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.expect_keyword(keyword_from()) != 0 {
        return -1
    }

    if self.parse_dotted_name_tail() != 0 {
        return -2
    }

    if self.expect_keyword(keyword_import()) != 0 {
        return -3
    }

    loop {
        if self.expect_identifier() != 0 {
            return -4
        }

        kind = self.next_token()
        if kind == token_keyword() {
            if self.token_value == keyword_as() {
                if self.expect_identifier() != 0 {
                    return -5
                }

                kind = self.next_token()
            } else {
                self.push_token()
                return 0
            }
        }

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value != 44 {
            self.push_token()
            return 0
        }
    }
    return 0
}

function parse_top_level() -> i32 {
    variable lexer: Lexer = Lexer {
        index: 0,
        line: 1,
        peeked_char: 0,
        has_peeked: false,
        token_kind: token_end(),
        token_value: 0,
        token_hash: 0,
        token_line: 1,
        token_length: 0,
        string_char_0: 0,
        string_char_1: 0,
        string_char_2: 0,
        string_char_3: 0,
        string_char_4: 0,
        string_char_5: 0,
        string_char_6: 0,
        string_char_7: 0,
        string_char_8: 0,
        string_char_9: 0,
        string_char_10: 0,
        string_char_11: 0,
        string_char_12: 0,
        string_char_13: 0,
        string_char_14: 0,
        string_char_15: 0,
        pushed_kind: token_end(),
        pushed_value: 0,
        pushed_hash: 0,
        pushed_line: 1,
        pushed_length: 0,
        has_pushed: false
    }
    variable function_count: i32 = 0
    variable saw_main: i32 = false
    variable status: i32 = 0
    variable kind: i32 = lexer.next_token()
    variable top_keyword: i32 = 0
    variable top_handled: i32 = false

    loop {
        if kind == token_symbol() {
            if lexer.token_value == 64 {
                lexer.push_token()
                status = lexer.parse_annotation()
                if status < 0 {
                    return 1
                }

                kind = lexer.next_token()
                continue
            }
        }

        if kind != token_keyword() {
            lexer.push_token()
            break
        }

        if lexer.token_value == keyword_module() {
            lexer.push_token()
            status = lexer.parse_module_declaration()
            if status < 0 {
                return 1
            }
        } else {
            if lexer.token_value == keyword_import() {
                lexer.push_token()
                status = lexer.parse_import_declaration()
                if status < 0 {
                    return 2
                }
            } else {
                if lexer.token_value == keyword_from() {
                    lexer.push_token()
                    status = lexer.parse_from_import_declaration()
                    if status < 0 {
                        return 3
                    }
                } else {
                    lexer.push_token()
                    break
                }
            }
        }

        kind = lexer.next_token()
    }

    loop {
        kind = lexer.next_token()

        if kind == token_end() {
            break
        }

        loop {
            if kind != token_symbol() {
                break
            }

            if lexer.token_value != 64 {
                break
            }

            lexer.push_token()
            status = lexer.parse_annotation()
            if status < 0 {
                return 8
            }

            kind = lexer.next_token()

            if kind == token_end() {
                break
            }
        }

        if kind == token_end() {
            break
        }

        if kind != token_keyword() {
            return 9
        }

        top_keyword = lexer.token_value
        top_handled = false

        if top_keyword == keyword_function() {
            status = lexer.parse_function_definition_tail()
            top_handled = true
        }

        if top_handled == false {
            if top_keyword == keyword_fn() {
                status = lexer.parse_function_definition_tail()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_public() {
                status = lexer.parse_public_declaration()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_pub() {
                status = lexer.parse_public_declaration()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_enum() {
                status = lexer.parse_enum_declaration_tail()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_struct() {
                status = lexer.parse_struct_declaration_tail()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_async() {
                status = lexer.parse_function_definition()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_class() {
                status = lexer.parse_class_declaration_tail()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_interface() {
                status = lexer.parse_interface_declaration_tail()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_implement() {
                status = lexer.parse_implement_declaration_tail()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_private() {
                status = lexer.parse_private_declaration()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_import() {
                status = lexer.parse_import_declaration()
                top_handled = true
            }
        }

        if top_handled == false {
            if top_keyword == keyword_from() {
                status = lexer.parse_from_import_declaration()
                top_handled = true
            }
        }

        if top_handled == false {
            return 9
        }

        if status < 0 {
            return 10
        }

        if top_keyword == keyword_function() {
            function_count += 1

            if status == identifier_hash_main() {
                saw_main = true
            }
        }

        if top_keyword == keyword_fn() {
            function_count += 1

            if status == identifier_hash_main() {
                saw_main = true
            }
        }

        if top_keyword == keyword_async() {
            function_count += 1

            if status == identifier_hash_main() {
                saw_main = true
            }
        }

        if top_keyword == keyword_public() {
            if status != 0 {
                function_count += 1

                if status == identifier_hash_main() {
                    saw_main = true
                }
            }
        }

        if top_keyword == keyword_pub() {
            if status != 0 {
                function_count += 1

                if status == identifier_hash_main() {
                    saw_main = true
                }
            }
        }

        if top_keyword == keyword_private() {
            if status != 0 {
                function_count += 1

                if status == identifier_hash_main() {
                    saw_main = true
                }
            }
        }
    }

    if function_count == 0 {
        return 100
    }

    if saw_main == false {
        return 101
    }

    return 0
}
