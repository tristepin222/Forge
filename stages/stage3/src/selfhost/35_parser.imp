        if kind == token_end() {
            return -1
        }

        if kind == token_symbol() {
            if self.token_value == 40 {
                paren_depth += 1
                continue
            }

            if self.token_value == 41 {
                if paren_depth > 0 {
                    paren_depth -= 1
                    continue
                }
            }

            if self.token_value == 91 {
                bracket_depth += 1
                continue
            }

            if self.token_value == 93 {
                if bracket_depth > 0 {
                    bracket_depth -= 1
                    continue
                }
            }

            if paren_depth == 0 {
                if bracket_depth == 0 {
                    if self.token_value == 123 {
                        self.push_token()
                        return 0
                    }

                    if self.token_value == 61 {
                        self.push_token()
                        return 0
                    }
                }
            }
