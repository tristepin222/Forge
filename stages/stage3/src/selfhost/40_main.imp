            }

            return 38
        }

        if lexer.token_value == keyword_pub() {
            kind = next_token(lexer)
            if kind != token_keyword() {
                return 10
            }

            if lexer.token_value == keyword_function() {
                if compile_function_definition_tail(lexer, state, 0) != 0 {
                    return 11
                }
                continue
            }

            if lexer.token_value == keyword_fn() {
                if compile_function_definition_tail(lexer, state, 0) != 0 {
                    return 12
                }
                continue
            }

            if lexer.token_value == keyword_struct() {
                if compile_struct_declaration_tail(lexer, state) != 0 {
                    return 22
                }
                continue
            }

            if lexer.token_value == keyword_class() {
                if compile_class_declaration_tail(lexer, state) != 0 {
                    return 23
                }
                continue
            }

            if lexer.token_value == keyword_enum() {
                if compile_enum_declaration_tail(lexer, state) != 0 {
                    return 26
                }
                continue
            }

            if lexer.token_value == keyword_interface() {
                if parse_interface_declaration_tail(lexer) != 0 {
                    return 27
                }
                continue
            }

            return 13
        }

        if lexer.token_value == keyword_struct() {
            if compile_struct_declaration_tail(lexer, state) != 0 {
                return 14
            }
            continue
        }

        if lexer.token_value == keyword_enum() {
            if compile_enum_declaration_tail(lexer, state) != 0 {
                return 15
            }
            continue
        }

        if lexer.token_value == keyword_class() {
            if compile_class_declaration_tail(lexer, state) != 0 {
                return 16
            }
            continue
        }

        if lexer.token_value == keyword_interface() {
            if parse_interface_declaration_tail(lexer) != 0 {
                return 17
            }
            continue
        }

        if lexer.token_value == keyword_implement() {
            if compile_implement_declaration_tail(lexer, state) != 0 {
                return 18
            }
            continue
        }

        return 19
    }

    return 0
}

function compile_program() -> i32 {
    emit_program_header()

    variable status: i32 = compile_translation_unit()
    if status != 0 {
        return 1
    }

    emit_program_footer()
    return 0
}

public function main() -> i32 {
    return compile_program()
}
