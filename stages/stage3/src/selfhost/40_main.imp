        var_type_12: 0,
        var_type_13: 0,
        var_type_14: 0,
        var_type_15: 0,
        print_alias_hash: 0,
        len_alias_hash: 0,
        import_call_alias_hash_0: 0,
        import_call_alias_hash_1: 0,
        import_call_alias_hash_2: 0,
        import_call_alias_hash_3: 0,
        import_call_target_hash_0: 0,
