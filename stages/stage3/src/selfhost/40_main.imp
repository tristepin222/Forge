        self.func_return_hash_7 = hash
        self.func_return_type_7 = return_type_hash
        return 0
    }

    if store_function_return_slot(self, self.next_func_return_slot, hash, return_type_hash) != 0 {
        return -1
    }

    self.next_func_return_slot += 1
    if self.next_func_return_slot == 8 {
        self.next_func_return_slot = 0
    }

    return 0
}

