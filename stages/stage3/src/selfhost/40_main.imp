function enum_variant_has_payload(self: CompileState, type_hash: i32, variant_hash: i32) -> i32 {
    variable slot: i32 = self.find_type_slot(type_hash)
    variable offset: i32 = self.lookup_type_field_offset(type_hash, variant_hash)

    if slot < 0 {
        return 0
    }

    if offset < 0 {
        return 0
    }

