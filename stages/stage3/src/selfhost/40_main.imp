function is_print_name(self: CompileState, hash: i32) -> bool {
    if hash == identifier_hash_print() {
        return true
    }

    if self.print_alias_hash == hash {
        return true
    }

    return false
}

function is_len_name(self: CompileState, hash: i32) -> bool {
    if hash == identifier_hash_len() {
        return true
    }

    if self.len_alias_hash == hash {
        return true
    }

    return false
}

function record_import_call_alias(self: CompileState, alias_hash: i32, target_hash: i32) -> i32 {
    if alias_hash == target_hash {
        return 0
    }

    if target_hash == identifier_hash_print() {
        return 0
    }

    if target_hash == identifier_hash_len() {
        return 0
    }

    if self.import_call_alias_hash_0 == alias_hash {
        self.import_call_target_hash_0 = target_hash
        return 0
    }

    if self.import_call_alias_hash_1 == alias_hash {
        self.import_call_target_hash_1 = target_hash
        return 0
    }

    if self.import_call_alias_hash_2 == alias_hash {
        self.import_call_target_hash_2 = target_hash
        return 0
    }

    if self.import_call_alias_hash_3 == alias_hash {
        self.import_call_target_hash_3 = target_hash
        return 0
    }

    if self.import_call_alias_hash_0 == 0 {
        self.import_call_alias_hash_0 = alias_hash
        self.import_call_target_hash_0 = target_hash
        return 0
    }

    if self.import_call_alias_hash_1 == 0 {
        self.import_call_alias_hash_1 = alias_hash
        self.import_call_target_hash_1 = target_hash
        return 0
    }

    if self.import_call_alias_hash_2 == 0 {
        self.import_call_alias_hash_2 = alias_hash
        self.import_call_target_hash_2 = target_hash
        return 0
    }

    if self.import_call_alias_hash_3 == 0 {
        self.import_call_alias_hash_3 = alias_hash
        self.import_call_target_hash_3 = target_hash
        return 0
    }

    return -1
}

function resolve_import_call_hash(self: CompileState, hash: i32) -> i32 {
    if self.import_call_alias_hash_0 == hash {
        return self.import_call_target_hash_0
    }

    if self.import_call_alias_hash_1 == hash {
        return self.import_call_target_hash_1
    }

    if self.import_call_alias_hash_2 == hash {
        return self.import_call_target_hash_2
    }

    if self.import_call_alias_hash_3 == hash {
        return self.import_call_target_hash_3
    }

    return hash
}

function allocate_label(self: CompileState) -> i32 {
    variable label: i32 = self.next_label
    self.next_label += 1
    return label
}

function push_call_frame(self: CompileState, hash: i32) -> i32 {
    if self.call_depth == 0 {
        self.call_hash_0 = hash
        self.call_arg_count_0 = 0
        self.call_depth += 1
        return 0
    }

    if self.call_depth == 1 {
        self.call_hash_1 = hash
        self.call_arg_count_1 = 0
        self.call_depth += 1
        return 0
    }

    if self.call_depth == 2 {
        self.call_hash_2 = hash
        self.call_arg_count_2 = 0
        self.call_depth += 1
        return 0
    }

    if self.call_depth == 3 {
        self.call_hash_3 = hash
        self.call_arg_count_3 = 0
        self.call_depth += 1
        return 0
    }

    return -1
}

function increment_call_arg_count(self: CompileState) -> i32 {
    variable depth: i32 = self.call_depth - 1

    if depth == 0 {
        self.call_arg_count_0 += 1
        return 0
    }

    if depth == 1 {
        self.call_arg_count_1 += 1
        return 0
    }

    if depth == 2 {
        self.call_arg_count_2 += 1
        return 0
    }

    if depth == 3 {
        self.call_arg_count_3 += 1
        return 0
    }

    return -1
}

function current_call_arg_count(self: CompileState) -> i32 {
    variable depth: i32 = self.call_depth - 1

    if depth == 0 {
        return self.call_arg_count_0
    }

    if depth == 1 {
        return self.call_arg_count_1
    }

    if depth == 2 {
        return self.call_arg_count_2
    }

    if depth == 3 {
        return self.call_arg_count_3
    }

    return -1
}

function pop_call_frame(self: CompileState) -> i32 {
    variable depth: i32 = self.call_depth - 1

    self.call_depth = depth

    if depth == 0 {
        return self.call_hash_0
    }

    if depth == 1 {
        return self.call_hash_1
    }

    if depth == 2 {
        return self.call_hash_2
    }

    if depth == 3 {
        return self.call_hash_3
    }

    return -1
}

function find_type_slot(self: CompileState, type_hash: i32) -> i32 {
    if self.type_hash_0 == type_hash {
        return 0
    }

    if self.type_hash_1 == type_hash {
        return 1
    }

    if self.type_hash_2 == type_hash {
        return 2
    }

    if self.type_hash_3 == type_hash {
        return 3
    }

    if self.type_hash_4 == type_hash {
        return 4
    }

    if self.type_hash_5 == type_hash {
        return 5
    }

    if self.type_hash_6 == type_hash {
        return 6
    }

    if self.type_hash_7 == type_hash {
        return 7
    }

    return -1
}

function ensure_type_slot(self: CompileState, type_hash: i32) -> i32 {
    variable slot: i32 = self.find_type_slot(type_hash)
    if slot >= 0 {
        return slot
    }

    if self.type_hash_0 == 0 {
        self.type_hash_0 = type_hash
        return 0
    }

    if self.type_hash_1 == 0 {
        self.type_hash_1 = type_hash
        return 1
    }

    if self.type_hash_2 == 0 {
        self.type_hash_2 = type_hash
        return 2
    }

    if self.type_hash_3 == 0 {
        self.type_hash_3 = type_hash
        return 3
    }

    if self.type_hash_4 == 0 {
        self.type_hash_4 = type_hash
        return 4
    }

    if self.type_hash_5 == 0 {
        self.type_hash_5 = type_hash
        return 5
    }

    if self.type_hash_6 == 0 {
        self.type_hash_6 = type_hash
        return 6
    }

    if self.type_hash_7 == 0 {
        self.type_hash_7 = type_hash
        return 7
    }

    return -1
}

function lookup_type_field_offset(self: CompileState, type_hash: i32, field_hash: i32) -> i32 {
    variable slot: i32 = self.find_type_slot(type_hash)
    if slot < 0 {
        return -1
    }

    if slot == 0 {
        if self.type_field_0_0 == field_hash {
            return 0
        }
        if self.type_field_0_1 == field_hash {
            return 8
        }
        if self.type_field_0_2 == field_hash {
            return 16
        }
        if self.type_field_0_3 == field_hash {
            return 24
        }
        return -2
    }

    if slot == 1 {
        if self.type_field_1_0 == field_hash {
            return 0
        }
        if self.type_field_1_1 == field_hash {
            return 8
        }
        if self.type_field_1_2 == field_hash {
            return 16
        }
        if self.type_field_1_3 == field_hash {
            return 24
        }
        return -3
    }

    if slot == 2 {
        if self.type_field_2_0 == field_hash {
            return 0
        }
        if self.type_field_2_1 == field_hash {
            return 8
        }
        if self.type_field_2_2 == field_hash {
            return 16
        }
        if self.type_field_2_3 == field_hash {
            return 24
        }
        return -4
    }

    if slot == 3 {
        if self.type_field_3_0 == field_hash {
            return 0
        }
        if self.type_field_3_1 == field_hash {
            return 8
        }
        if self.type_field_3_2 == field_hash {
            return 16
        }
        if self.type_field_3_3 == field_hash {
            return 24
        }
        return -5
    }

    if slot == 4 {
        if self.type_field_4_0 == field_hash {
            return 0
        }
        if self.type_field_4_1 == field_hash {
            return 8
        }
        if self.type_field_4_2 == field_hash {
            return 16
        }
        if self.type_field_4_3 == field_hash {
            return 24
        }
        return -6
    }

    if slot == 5 {
        if self.type_field_5_0 == field_hash {
            return 0
        }
        if self.type_field_5_1 == field_hash {
            return 8
        }
        if self.type_field_5_2 == field_hash {
            return 16
        }
        if self.type_field_5_3 == field_hash {
            return 24
        }
        return -7
    }

    if slot == 6 {
        if self.type_field_6_0 == field_hash {
            return 0
        }
        if self.type_field_6_1 == field_hash {
            return 8
        }
        if self.type_field_6_2 == field_hash {
            return 16
        }
        if self.type_field_6_3 == field_hash {
            return 24
        }
        return -8
    }

    if self.type_field_7_0 == field_hash {
        return 0
    }
    if self.type_field_7_1 == field_hash {
        return 8
    }
    if self.type_field_7_2 == field_hash {
        return 16
    }
    if self.type_field_7_3 == field_hash {
        return 24
    }

    return -9
}

function type_field_count(self: CompileState, type_hash: i32) -> i32 {
    variable slot: i32 = self.find_type_slot(type_hash)
    if slot < 0 {
        return 0
    }

    if slot == 0 {
        if self.type_field_0_3 != 0 {
            return 4
        }
        if self.type_field_0_2 != 0 {
            return 3
        }
        if self.type_field_0_1 != 0 {
            return 2
        }
        if self.type_field_0_0 != 0 {
            return 1
        }
        return 0
    }

    if slot == 1 {
        if self.type_field_1_3 != 0 {
            return 4
        }
        if self.type_field_1_2 != 0 {
            return 3
        }
        if self.type_field_1_1 != 0 {
            return 2
        }
        if self.type_field_1_0 != 0 {
            return 1
        }
        return 0
    }

    if slot == 2 {
        if self.type_field_2_3 != 0 {
            return 4
        }
        if self.type_field_2_2 != 0 {
            return 3
        }
        if self.type_field_2_1 != 0 {
            return 2
        }
        if self.type_field_2_0 != 0 {
            return 1
        }
        return 0
    }

    if slot == 3 {
        if self.type_field_3_3 != 0 {
            return 4
        }
        if self.type_field_3_2 != 0 {
            return 3
        }
        if self.type_field_3_1 != 0 {
            return 2
        }
        if self.type_field_3_0 != 0 {
            return 1
        }
        return 0
    }

    if slot == 4 {
        if self.type_field_4_3 != 0 {
            return 4
        }
        if self.type_field_4_2 != 0 {
            return 3
        }
        if self.type_field_4_1 != 0 {
            return 2
        }
        if self.type_field_4_0 != 0 {
            return 1
        }
        return 0
    }

    if slot == 5 {
        if self.type_field_5_3 != 0 {
            return 4
        }
        if self.type_field_5_2 != 0 {
            return 3
        }
        if self.type_field_5_1 != 0 {
            return 2
        }
        if self.type_field_5_0 != 0 {
            return 1
        }
        return 0
    }

    if slot == 6 {
        if self.type_field_6_3 != 0 {
            return 4
        }
        if self.type_field_6_2 != 0 {
            return 3
        }
        if self.type_field_6_1 != 0 {
            return 2
        }
        if self.type_field_6_0 != 0 {
            return 1
        }
        return 0
    }

    if self.type_field_7_3 != 0 {
        return 4
    }
    if self.type_field_7_2 != 0 {
        return 3
    }
    if self.type_field_7_1 != 0 {
        return 2
    }
    if self.type_field_7_0 != 0 {
        return 1
    }

    return 0
}

function register_type_field(self: CompileState, type_hash: i32, field_hash: i32) -> i32 {
    variable slot: i32 = self.ensure_type_slot(type_hash)
    if slot < 0 {
        return -1
    }

    if self.lookup_type_field_offset(type_hash, field_hash) >= 0 {
        return 0
    }

    if slot == 0 {
        if self.type_field_0_0 == 0 {
            self.type_field_0_0 = field_hash
            return 0
        }
        if self.type_field_0_1 == 0 {
            self.type_field_0_1 = field_hash
            return 0
        }
        if self.type_field_0_2 == 0 {
            self.type_field_0_2 = field_hash
            return 0
        }
        if self.type_field_0_3 == 0 {
            self.type_field_0_3 = field_hash
            return 0
