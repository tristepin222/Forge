function emit_function_label(function_hash: i32) {
    emit_function_name(function_hash)
    emits(":")
    emitc(10)
}

function emit_call_function(function_hash: i32) {
    emits("    call ")
    emit_function_name(function_hash)
    emitc(10)
}

function emit_pop_call_argument(index: i32) -> i32 {
    if index == 0 {
        emits("    pop rdi")
        emitc(10)
        return 0
    }

    if index == 1 {
        emits("    pop rsi")
        emitc(10)
        return 0
    }

    if index == 2 {
        emits("    pop rdx")
        emitc(10)
        return 0
    }

    if index == 3 {
        emits("    pop rcx")
        emitc(10)
        return 0
    }

    if index == 4 {
        emits("    pop r8")
        emitc(10)
        return 0
    }

    if index == 5 {
        emits("    pop r9")
        emitc(10)
        return 0
    }

    return -1
}

function emit_store_argument_variable(function_hash: i32, variable_hash: i32, index: i32) -> i32 {
    if index == 0 {
        emits("    mov rax, rdi")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 1 {
        emits("    mov rax, rsi")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 2 {
        emits("    mov rax, rdx")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 3 {
        emits("    mov rax, rcx")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 4 {
        emits("    mov rax, r8")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 5 {
        emits("    mov rax, r9")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    return -1
}

function emit_declare_variable(function_hash: i32, variable_hash: i32) {
    emits("section .bss")
    emitc(10)
    emit_variable_name(function_hash, variable_hash)
    emits(": resq 1")
    emitc(10)
    emits("section .text")
    emitc(10)
}

function emit_load_variable(function_hash: i32, variable_hash: i32) {
    emits("    mov rax, [")
    emit_variable_name(function_hash, variable_hash)
    emits("]")
    emitc(10)
}

function emit_store_variable(function_hash: i32, variable_hash: i32) {
    emits("    mov [")
    emit_variable_name(function_hash, variable_hash)
    emits("], rax")
    emitc(10)
}

function emit_struct_storage_name(function_hash: i32, variable_hash: i32) {
    emits("S_")
    emit_hash_suffix(function_hash)
    emitc(95)
    emit_hash_suffix(variable_hash)
}

function emit_declare_struct_storage(function_hash: i32, variable_hash: i32, field_count: i32) {
    emits("section .bss")
    emitc(10)
    emit_struct_storage_name(function_hash, variable_hash)
    emits(": resq ")
    emiti(field_count)
    emitc(10)
    emits("section .text")
    emitc(10)
}

function emit_declare_array_storage(function_hash: i32, variable_hash: i32, length: i32) {
    variable storage_length: i32 = length

    if storage_length < 1 {
        storage_length = 1
    }

    emit_variable_length_name(function_hash, variable_hash)
    emits(" equ ")
    emiti(length)
    emitc(10)
    emits("section .bss")
    emitc(10)
    emit_variable_name(function_hash, variable_hash)
    emits(": resq ")
    emiti(storage_length)
    emitc(10)
    emits("section .text")
    emitc(10)
}

function emit_initialize_struct_storage_pointer(function_hash: i32, variable_hash: i32) {
    emits("    lea rax, [")
    emit_struct_storage_name(function_hash, variable_hash)
    emits("]")
    emitc(10)
    emit_store_variable(function_hash, variable_hash)
}

function emit_load_struct_field(function_hash: i32, variable_hash: i32, offset: i32) {
    emit_load_variable(function_hash, variable_hash)
    emits("    mov rax, [rax + ")
    emiti(offset)
    emits("]")
    emitc(10)
}

function emit_store_struct_field(function_hash: i32, variable_hash: i32, offset: i32) {
    emits("    mov rbx, [")
    emit_variable_name(function_hash, variable_hash)
    emits("]")
    emitc(10)
    emits("    mov [rbx + ")
    emiti(offset)
    emits("], rax")
    emitc(10)
}

function emit_store_array_element(function_hash: i32, variable_hash: i32, index: i32) {
    emits("    mov [")
    emit_variable_name(function_hash, variable_hash)
    if index > 0 {
        emits(" + ")
        emiti(index * 8)
    }
    emits("], rax")
    emitc(10)
}

function emit_load_array_element(function_hash: i32, variable_hash: i32, index: i32) {
    emits("    mov rax, [")
    emit_variable_name(function_hash, variable_hash)
    if index > 0 {
        emits(" + ")
        emiti(index * 8)
    }
    emits("]")
    emitc(10)
}

function emit_push_rax() {
    emits("    push rax")
    emitc(10)
}

function emit_pop_rbx() {
    emits("    pop rbx")
    emitc(10)
}

function emit_load_number(value: i32) {
    emits("    mov rax, ")
    emiti(value)
    emitc(10)
}

function emit_string_label_name(label: i32) {
    emits("STR_")
    emiti(label)
}

function emit_string_literal_data(self: Lexer, label: i32) {
    variable index: i32 = 0

    emits("section .data")
    emitc(10)
    emit_string_label_name(label)
    emits(": db ")

    if self.token_length == 0 {
        emits("0")
    } else {
        loop {
            emiti(self.string_char_at(index))
            index += 1

            if index >= self.token_length {
                break
            }

            emits(", ")
        }

        emits(", 0")
    }

    emitc(10)
    emits("section .text")
    emitc(10)
}

function emit_load_string_label(label: i32) {
    emits("    lea rax, [")
    emit_string_label_name(label)
    emits("]")
    emitc(10)
}

function emit_load_current_string_literal(self: Lexer, state: CompileState) -> i32 {
    variable label: i32 = state.allocate_label()
    self.emit_string_literal_data(label)
    emit_load_string_label(label)
    return 0
}

function emit_return_rax() {
    emits("    ret")
    emitc(10)
}

function emit_print_rax_call() {
    emits("    call print_rax")
    emitc(10)
}

function emit_print_cstr_rax_call() {
    emits("    call print_cstr_rax")
    emitc(10)
}

function emit_pack_enum_payload(tag: i32) {
    emits("    mov rbx, rax")
    emitc(10)
    emits("    shl rbx, 32")
    emitc(10)
    emit_load_number(tag)
    emits("    or rax, rbx")
    emitc(10)
}

function emit_compare_enum_tag_jump_false(variable_hash: i32, tag: i32, false_label: i32, function_hash: i32) {
    emit_load_variable(function_hash, variable_hash)
    emits("    mov rbx, rax")
    emitc(10)
    emits("    shl rbx, 32")
    emitc(10)
    emits("    shr rbx, 32")
    emitc(10)
    emit_load_number(tag)
    emits("    cmp rbx, rax")
    emitc(10)
    emits("    jne ")
    emit_internal_label_name(false_label)
    emitc(10)
}

function compile_enum_variant_expression(self: Lexer, state: CompileState, type_hash: i32, variant_hash: i32, function_hash: i32) -> i32 {
    variable variant_tag: i32 = state.enum_variant_tag(type_hash, variant_hash)
    variable variant_has_payload: i32 = state.enum_variant_has_payload(type_hash, variant_hash)
    variable kind: i32 = 0

    if variant_tag < 0 {
        return -1
    }

    kind = self.next_token()
    if kind == token_symbol() {
        if self.token_value == 40 {
            if variant_has_payload == false {
                return -2
            }

            if self.compile_expression(state, function_hash) != 0 {
                return -3
            }

            if self.expect_symbol(41) != 0 {
                return -4
            }

            emit_pack_enum_payload(variant_tag)
            return 0
        }
    }

    self.push_token()
    if variant_has_payload == true {
        return -5
    }

    emit_load_number(variant_tag)
    return 0
}

function identifier_hash_wildcard() -> i32 => 95

function emit_internal_label(label: i32) {
    emit_internal_label_name(label)
    emits(":")
    emitc(10)
}

function emit_jump(label: i32) {
    emits("    jmp ")
    emit_internal_label_name(label)
    emitc(10)
}

function emit_compare_jump_false(op: i32, label: i32) {
    emits("    cmp rbx, rax")
    emitc(10)

    if op == 1 {
        emits("    jge ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    if op == 2 {
        emits("    jle ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    if op == 3 {
        emits("    jne ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    if op == 4 {
        emits("    je ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    if op == 5 {
        emits("    jg ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    emits("    jl ")
    emit_internal_label_name(label)
    emitc(10)
}

function parse_compare_operator(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_symbol() {
        return -1
    }

    if self.token_value == 60 {
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 61 {
                return 5
            }
            self.push_token()
        } else {
            self.push_token()
        }

        return 1
    }

    if self.token_value == 62 {
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 61 {
                return 6
            }
            self.push_token()
        } else {
            self.push_token()
        }

        return 2
    }

    if self.token_value == 61 {
        if self.expect_symbol(61) != 0 {
            return -2
        }

        return 3
    }

    if self.token_value == 33 {
        if self.expect_symbol(61) != 0 {
            return -3
        }

        return 4
    }

    return -4
}

function parse_type_name_hash(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.expect_identifier() != 0 {
        return -1
    }
    variable type_hash: i32 = self.token_hash

    loop {
        kind = self.next_token()

        if kind != token_symbol() {
            self.push_token()
            return type_hash
        }

        if self.token_value == 46 {
            if self.expect_identifier() != 0 {
                return -2
            }

            continue
        }

        if self.token_value == 91 {
            if self.parse_type_argument_list_tail() != 0 {
                return -3
            }

            continue
        }

        self.push_token()
        return type_hash
    }
}

function parse_optional_return_type_hash(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_symbol() {
        self.push_token()
        return 0
    }

    if self.token_value != 45 {
        self.push_token()
        return 0
    }

    if self.expect_symbol(62) != 0 {
        return -1
    }

    return self.parse_type_name_hash()
}

function check_return_expression_type(state: CompileState) -> i32 {
    if state.current_return_type_hash == 0 {
        return 0
    }

    if state.last_expression_type_hash == 0 {
        return 0
    }

    if state.current_return_type_hash == state.last_expression_type_hash {
        return 0
    }

    emit_return_type_mismatch(state.current_return_type_hash, state.last_expression_type_hash)
    return -1
}

function parse_member_name_hash(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind == token_identifier() {
        return self.token_hash
    }

    if kind == token_keyword() {
        if self.token_value == keyword_value() {
            return keyword_hash_value()
        }
    }

    return -1
}

function compile_struct_literal_into_variable(self: Lexer, state: CompileState, function_hash: i32, variable_hash: i32, type_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    variable field_hash: i32 = 0
    variable field_offset: i32 = 0

    emit_initialize_struct_storage_pointer(function_hash, variable_hash)

    if kind == token_symbol() {
        if self.token_value == 125 {
            return 0
        }
    }

    self.push_token()

    loop {
        field_hash = self.parse_member_name_hash()
        if field_hash < 0 {
            return -1
        }

        field_offset = state.lookup_type_field_offset(type_hash, field_hash)
        if field_offset < 0 {
            return -2
        }

        if self.expect_symbol(58) != 0 {
            return -3
        }

        if self.compile_expression(state, function_hash) != 0 {
            return -4
        }

        emit_store_struct_field(function_hash, variable_hash, field_offset)

        kind = self.next_token()
        if kind != token_symbol() {
            return -5
        }

        if self.token_value == 125 {
            return 0
        }

        if self.token_value != 44 {
            return -6
        }
    }
}

function compile_array_literal_into_variable(self: Lexer, state: CompileState, function_hash: i32, variable_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    variable element_index: i32 = 0

    if kind == token_symbol() {
        if self.token_value == 93 {
            emit_declare_array_storage(function_hash, variable_hash, 0)
            return 0
        }
    }

    self.push_token()

    loop {
        if self.compile_expression(state, function_hash) != 0 {
            return -2
        }

        emit_store_array_element(function_hash, variable_hash, element_index)
        element_index += 1

        kind = self.next_token()
        if kind != token_symbol() {
            return -3
        }

        if self.token_value == 93 {
            break
        }

        if self.token_value != 44 {
            return -4
        }
    }

    emit_declare_array_storage(function_hash, variable_hash, element_index)
    return 0
}

function compile_factor(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()

    if kind == token_number() {
        emit_load_number(self.token_value)
        state.last_expression_type_hash = identifier_hash_i32()
        return 0
    }

    if kind == token_keyword() {
        if self.token_value == keyword_true() {
            emit_load_number(1)
            state.last_expression_type_hash = identifier_hash_bool()
            return 0
        }

        if self.token_value == keyword_false() {
            emit_load_number(0)
            state.last_expression_type_hash = identifier_hash_bool()
            return 0
        }
    }

    if kind == token_symbol() {
        if self.token_value == 45 {
            if self.compile_factor(state, function_hash) != 0 {
                return -1
            }

            emits("    neg rax")
            emitc(10)
            state.last_expression_type_hash = identifier_hash_i32()
            return 0
        }

        if self.token_value == 40 {
            if self.compile_expression(state, function_hash) != 0 {
                return -2
            }

            if self.expect_symbol(41) != 0 {
                return -3
            }

            return 0
        }
    }

    if kind == token_identifier() {
        variable name_hash: i32 = self.token_hash
        variable type_hash: i32 = state.lookup_variable_type(function_hash, name_hash)
        variable member_hash: i32 = 0
        variable field_offset: i32 = 0
        variable arg_count: i32 = 0
        variable call_hash: i32 = 0
        variable arg_hash: i32 = 0
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 58 {
                if self.expect_symbol(58) != 0 {
                    return -4
                }

                member_hash = self.parse_member_name_hash()
                if member_hash < 0 {
                    return -5
                }

                if self.compile_enum_variant_expression(state, name_hash, member_hash, function_hash) != 0 {
                    return -6
                }
                state.last_expression_type_hash = 0
                return 0
            }

            if self.token_value == 46 {
                member_hash = self.parse_member_name_hash()
                if member_hash < 0 {
                    return -11
                }

                kind = self.next_token()
                if kind == token_symbol() {
                    if self.token_value == 40 {
                        if type_hash == 0 {
                            return -12
                        }

                        emit_load_variable(function_hash, name_hash)
                        emit_push_rax()

                        if state.push_call_frame(member_hash) != 0 {
                            return -13
                        }

                        if state.increment_call_arg_count() != 0 {
                            return -14
                        }

                        arg_count = self.compile_call_arguments(state, function_hash)
                        if arg_count < 0 {
                            return -15
                        }

                        call_hash = state.pop_call_frame()
                        emit_call_function(call_hash)
                        state.last_expression_type_hash = 0
                        return 0
                    }
                }

                self.push_token()
                if type_hash == 0 {
                    return -16
                }

                field_offset = state.lookup_type_field_offset(type_hash, member_hash)
                if field_offset < 0 {
                    return -17
                }

                emit_load_struct_field(function_hash, name_hash, field_offset)
                state.last_expression_type_hash = 0
                return 0
            }

            if self.token_value == 91 {
                if type_hash != identifier_hash_array_i32() {
                    return -20
                }

                emits("    lea rax, [")
                emit_variable_name(function_hash, name_hash)
                emits("]")
                emitc(10)
                emit_push_rax()

                if self.compile_expression(state, function_hash) != 0 {
                    return -21
                }

                if self.expect_symbol(93) != 0 {
                    return -22
                }

                emit_pop_rbx()
                emits("    mov rax, [rbx + rax*8]")
                emitc(10)
                state.last_expression_type_hash = identifier_hash_i32()
                return 0
            }

            if self.token_value == 40 {
                if state.is_len_name(name_hash) == true {
                    if self.expect_identifier() != 0 {
                        return -23
                    }

                    arg_hash = self.token_hash
                    if state.lookup_variable_type(function_hash, arg_hash) != identifier_hash_array_i32() {
                        return -24
                    }

                    if self.expect_symbol(41) != 0 {
                        return -25
                    }

                    emits("    mov rax, ")
                    emit_variable_length_name(function_hash, arg_hash)
                    emitc(10)
                    state.last_expression_type_hash = identifier_hash_i32()
                    return 0
                }

                call_hash = state.resolve_import_call_hash(name_hash)
                if state.push_call_frame(call_hash) != 0 {
                    return -26
                }

                arg_count = self.compile_call_arguments(state, function_hash)
                if arg_count < 0 {
                    return -27
                }

                call_hash = state.pop_call_frame()
                emit_call_function(call_hash)
                state.last_expression_type_hash = 0
                return 0
            }
        }

        self.push_token()
        emit_load_variable(function_hash, name_hash)
        state.last_expression_type_hash = type_hash
        return 0
    }

    return -13
}

function compile_call_arguments(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    variable arg_count: i32 = 0
    variable pop_index: i32 = 0

    if kind == token_symbol() {
        if self.token_value == 41 {
            arg_count = state.current_call_arg_count()
            if arg_count < 0 {
                return -8
            }

            if arg_count > 6 {
                return -9
            }

            if arg_count == 0 {
                return 0
            }

            pop_index = arg_count - 1
            loop {
                if emit_pop_call_argument(pop_index) != 0 {
                    return -10
                }

                if pop_index == 0 {
                    break
                }

                pop_index -= 1
            }

            return arg_count
        }
    }

    self.push_token()

    loop {
        if self.compile_expression(state, function_hash) != 0 {
            return -1
        }

        emit_push_rax()
        if state.increment_call_arg_count() != 0 {
            return -4
        }

        kind = self.next_token()
        if kind != token_symbol() {
            return -2
        }

        if self.token_value == 41 {
            break
        }

        if self.token_value != 44 {
            return -3
        }
    }

    arg_count = state.current_call_arg_count()
    if arg_count < 0 {
        return -5
    }

    if arg_count > 6 {
        return -6
    }

    pop_index = arg_count - 1
    loop {
        if emit_pop_call_argument(pop_index) != 0 {
            return -7
        }

        if pop_index == 0 {
            break
        }

        pop_index -= 1
    }

    return arg_count
}

function compile_term(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    if self.compile_factor(state, function_hash) != 0 {
        return -1
    }

    loop {
        variable kind: i32 = self.next_token()

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value != 42 {
            self.push_token()
            return 0
        }

        emit_push_rax()

        if self.compile_factor(state, function_hash) != 0 {
            return -2
        }

        emit_pop_rbx()
        emits("    imul rax, rbx")
        emitc(10)
        state.last_expression_type_hash = identifier_hash_i32()
    }
}

function compile_expression(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    if self.compile_term(state, function_hash) != 0 {
        return -1
    }

    loop {
        variable kind: i32 = self.next_token()
        variable op: i32 = 0

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value == 43 {
            op = 1
        } else {
            if self.token_value == 45 {
                op = 2
            } else {
                self.push_token()
                return 0
            }
        }

        emit_push_rax()

        if self.compile_term(state, function_hash) != 0 {
            return -2
        }

        emit_pop_rbx()

        if op == 1 {
            emits("    add rax, rbx")
            emitc(10)
        } else {
            emits("    sub rbx, rax")
            emitc(10)
            emits("    mov rax, rbx")
            emitc(10)
        }
        state.last_expression_type_hash = identifier_hash_i32()
    }
}

function compile_condition_jump_false(self: Lexer, state: CompileState, function_hash: i32, false_label: i32) -> i32 {
    variable op: i32 = 0

    if self.compile_expression(state, function_hash) != 0 {
        return -1
    }

    emit_push_rax()

    op = self.parse_compare_operator()
    if op < 0 {
        return -2
    }

    if self.compile_expression(state, function_hash) != 0 {
        return -3
    }

    emit_pop_rbx()
    emit_compare_jump_false(op, false_label)
    return 0
}

function compile_binding_tail(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable type_hash: i32 = 0
    variable field_count: i32 = 0
    variable kind: i32 = 0
    variable source_hash: i32 = 0

    if self.expect_identifier() != 0 {
        return -1
    }
    variable variable_hash: i32 = self.token_hash

    kind = self.next_token()
    if kind != token_symbol() {
        return -2
    }

    if self.token_value == 58 {
        type_hash = self.parse_type_name_hash()
        if type_hash < 0 {
            return -3
        }

        if self.expect_symbol(61) != 0 {
            return -4
        }
    } else {
        if self.token_value != 61 {
            return -5
        }
    }

    if type_hash != 0 {
        if state.register_variable_type(function_hash, variable_hash, type_hash) != 0 {
            return -6
        }
    }

    kind = self.next_token()
    if kind == token_symbol() {
        if self.token_value == 91 {
            if type_hash != 0 {
                return -7
            }

            if state.register_variable_type(function_hash, variable_hash, identifier_hash_array_i32()) != 0 {
                return -8
            }

            if self.compile_array_literal_into_variable(state, function_hash, variable_hash) != 0 {
                return -9
            }

            return 0
        }
    }
    self.push_token()

    emit_declare_variable(function_hash, variable_hash)

    field_count = state.type_field_count(type_hash)
    if field_count > 0 {
        emit_declare_struct_storage(function_hash, variable_hash, field_count)

        kind = self.next_token()
        if kind == token_identifier() {
            if self.token_hash == type_hash {
                if self.expect_symbol(123) != 0 {
                    return -10
                }

                if self.compile_struct_literal_into_variable(state, function_hash, variable_hash, type_hash) != 0 {
                    return -11
                }

                return 0
            }
        }

        self.push_token()
    }

    if type_hash == identifier_hash_str() {
        kind = self.next_token()

        if kind == token_string() {
            if self.emit_load_current_string_literal(state) != 0 {
                return -12
            }

            emit_store_variable(function_hash, variable_hash)
            return 0
        }

        if kind == token_identifier() {
            source_hash = self.token_hash
            if state.lookup_variable_type(function_hash, source_hash) == identifier_hash_str() {
                emit_load_variable(function_hash, source_hash)
                emit_store_variable(function_hash, variable_hash)
                return 0
            }
        }

        self.push_token()
    }

    if self.compile_expression(state, function_hash) != 0 {
        return -13
    }

    emit_store_variable(function_hash, variable_hash)
    return 0
}

function compile_identifier_statement_tail(self: Lexer, state: CompileState, function_hash: i32, name_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    variable type_hash: i32 = state.lookup_variable_type(function_hash, name_hash)
    variable member_hash: i32 = 0
    variable field_offset: i32 = 0
    variable arg_count: i32 = 0
    variable call_hash: i32 = 0
    variable string_hash: i32 = 0

    if kind != token_symbol() {
        return -1
    }

    if self.token_value == 40 {
        if state.is_print_name(name_hash) == true {
            kind = self.next_token()
            if kind == token_symbol() {
                if self.token_value == 41 {
                    return -2
                }
            }

            if kind == token_string() {
                if self.emit_load_current_string_literal(state) != 0 {
                    return -3
                }

                if self.expect_symbol(41) != 0 {
                    return -4
                }

