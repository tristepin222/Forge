            }

            emit_pop_rbx()
            emits("    pop rcx")
            emitc(10)
            emits("    mov rax, [rcx + rbx*8]")
            emitc(10)
            emits("    push rcx")
            emitc(10)
            emits("    push rbx")
            emitc(10)
