function enum_variant_tag(self: CompileState, type_hash: i32, variant_hash: i32) -> i32 {
    variable offset: i32 = self.lookup_type_field_offset(type_hash, variant_hash)

    if offset == 0 {
        return 1
    }
    if offset == 8 {
        return 2
    }
    if offset == 16 {
        return 3
    }
    if offset == 24 {
        return 4
    }

    return -1
}

function register_enum_variant(self: CompileState, type_hash: i32, variant_hash: i32, has_payload: i32) -> i32 {
    variable slot: i32 = self.ensure_type_slot(type_hash)
    variable status: i32 = 0
    variable offset: i32 = 0
    variable index: i32 = 0

    if slot < 0 {
        return -1
    }

    status = self.register_type_field(type_hash, variant_hash)
    if status != 0 {
        return -2
    }

    offset = self.lookup_type_field_offset(type_hash, variant_hash)
    if offset < 0 {
        return -3
    }

    if offset == 0 {
        index = 0
    } else {
        if offset == 8 {
            index = 1
        } else {
            if offset == 16 {
                index = 2
            } else {
                if offset == 24 {
                    index = 3
                } else {
                    return -4
                }
            }
        }
    }

    return self.set_enum_payload_flag(slot, index, has_payload)
}

