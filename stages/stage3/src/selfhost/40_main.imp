function emit_pack_enum_payload(tag: i32) {
    emits("    mov rbx, rax")
    emitc(10)
    emits("    shl rbx, 32")
    emitc(10)
    emit_load_number(tag)
    emits("    or rax, rbx")
    emitc(10)
}

function emit_compare_enum_tag_jump_false(variable_hash: i32, tag: i32, false_label: i32, function_hash: i32) {
    emit_load_variable(function_hash, variable_hash)
    emits("    mov rbx, rax")
    emitc(10)
    emits("    shl rbx, 32")
    emitc(10)
    emits("    shr rbx, 32")
    emitc(10)
    emit_load_number(tag)
    emits("    cmp rbx, rax")
    emitc(10)
    emits("    jne ")
    emit_internal_label_name(false_label)
    emitc(10)
}

function compile_enum_variant_expression(self: Lexer, state: CompileState, type_hash: i32, variant_hash: i32, function_hash: i32) -> i32 {
    variable variant_tag: i32 = state.enum_variant_tag(type_hash, variant_hash)
    variable variant_has_payload: i32 = state.enum_variant_has_payload(type_hash, variant_hash)
    variable kind: i32 = 0

    if variant_tag < 0 {
        return -1
    }

    kind = self.next_token()
    if kind == token_symbol() {
        if self.token_value == 40 {
            if variant_has_payload == false {
                return -2
            }

            if self.compile_expression(state, function_hash) != 0 {
                return -3
            }

            if self.expect_symbol(41) != 0 {
                return -4
            }

            emit_pack_enum_payload(variant_tag)
            return 0
        }
    }

    self.push_token()
    if variant_has_payload == true {
        return -5
    }

    emit_load_number(variant_tag)
    return 0
}

function identifier_hash_wildcard() -> i32 => 95

function emit_internal_label(label: i32) {
    emit_internal_label_name(label)
    emits(":")
    emitc(10)
}

function emit_jump(label: i32) {
