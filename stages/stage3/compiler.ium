# Parser state codes:
# 0: initial state, waiting for top-level declarations (module, import, function, etc.)
# 1: expecting module name after 'module'
# 2: inside module, expecting imports or functions
# 3: expecting function name
# 4: after function name, expecting parameters or generics
# 5: after parameters, expecting function body or return type
# 6: after '-', expecting '>' (to complete '->')
# 40: top-level declarations
# 50: after '->', expecting return type name
# 51: after return type, expecting function body
# 52: inside class/struct, expecting methods or fields
# 53: inside function body
# 54: inside import statement
# 59: expecting import module name
# 60: after import name, expecting '{'
# 61: inside import block
# 62: expecting '{'
# 63: expecting '{'
# 83: expecting struct name
# 84: after struct name, expecting '{'
# 85: inside struct, expecting fields or '}'
# 86: after field name, expecting ':'
# 87: after ':', expecting field type
# 95: expecting enum name
# 96: after enum name, expecting '{'
# 97: inside enum, expecting variants or '}'
# 98: after variant name, expecting ',' or '}' or '('
# 99: inside variant payload
# 105: expecting interface name for implements
# 106: after interface name, expecting 'implements'
# 107: after 'implements', expecting type
# 108: after type, expecting '{'
# 109: expecting interface name for definition
# 110: after interface name, expecting '{'
# 111: inside interface, expecting functions or '}'
# 112: expecting function name in interface
# 113: after function name, expecting '('
# 114: inside function parameters in interface
# 115: after parameters in interface
# 151: after '-' in interface return type
# 152: expecting interface return type name
# 120: expecting class name
# 123: expecting method name
# 125: skipping generic parameters
# 126: expecting '@'
# 127: after '@', expecting '('
# 128: inside '@' parameters
# 129: expecting function or struct
# 130: after expression function, expecting '{'
# 141: after import statement

WHILE 1 == 1
    LET emit_requested 0

    IF need_read == 1
        READ ch
        LET need_read 0
    END

    IF lex_state == 1
        LET temp 0

        IF ch >= 65
            IF ch <= 90
                LET temp 1
            END
        END
        IF ch >= 97
            IF ch <= 122
                LET temp 1
            END
        END
        IF ch >= 48
            IF ch <= 57
                LET temp 1
            END
        END
        IF ch == 95
            LET temp 1
        END

        IF temp == 1
            MUL tok_hash 131
            ADD tok_hash ch
            POKE tok_ptr ch
            ADD tok_ptr 8
            ADD tok_len 1
            LET need_read 1
        END

        IF temp == 0
            LET tok_type 1
            LET emit_requested 1
            LET lex_state 0
            LET need_read 0
        END
    END

    IF lex_state == 2
        LET temp 0

        IF ch >= 48
            IF ch <= 57
                LET temp 1
            END
        END

        IF temp == 1
            POKE tok_ptr ch
            ADD tok_ptr 8
            ADD tok_len 1
            MUL tok_value 10
            LET temp2 ch
            SUB temp2 48
            ADD tok_value temp2
            LET need_read 1
        END

        IF temp == 0
            LET tok_type 4
            LET emit_requested 1
            LET lex_state 0
            LET need_read 0
        END
    END

    IF lex_state == 3
        IF ch == 34
            LET tok_type 5
            LET emit_requested 1
            LET lex_state 0
            LET need_read 1
        END

        IF emit_requested == 0
            IF ch == 92
                LET lex_state 4
                LET need_read 1
            END
        END

        IF emit_requested == 0
            IF lex_state == 3
                IF ch == 0
                    WRITE_STR "parse error"
                    WRITE_CHAR 10
                    WRITE_STR "line: "
                    WRITE_INT line_no
                    WRITE_CHAR 10
                    WRITE_STR "char: "
                    WRITE_INT ch
                    WRITE_CHAR 10
                    WRITE_STR "invalid char"
                    WRITE_CHAR 10
                    EXIT
                END
            END
        END

        IF emit_requested == 0
            IF lex_state == 3
                IF ch == 10
                    WRITE_STR "parse error"
                    WRITE_CHAR 10
                    WRITE_STR "line: "
                    WRITE_INT line_no
                    WRITE_CHAR 10
                    WRITE_STR "char: "
                    WRITE_INT ch
                    WRITE_CHAR 10
                    WRITE_STR "invalid char"
                    WRITE_CHAR 10
                    EXIT
                END
            END
        END

        IF emit_requested == 0
            IF lex_state == 3
                POKE tok_ptr ch
                ADD tok_ptr 8
                ADD tok_len 1
                LET need_read 1
            END
        END
    END

    IF need_read == 0
        IF lex_state == 4
            IF ch == 0
                WRITE_STR "parse error"
                WRITE_CHAR 10
                WRITE_STR "line: "
                WRITE_INT line_no
                WRITE_CHAR 10
                WRITE_STR "char: "
                WRITE_INT ch
                WRITE_CHAR 10
                WRITE_STR "invalid char"
                WRITE_CHAR 10
                EXIT
            END

            IF ch == 10
                WRITE_STR "parse error"
                WRITE_CHAR 10
                WRITE_STR "line: "
                WRITE_INT line_no
                WRITE_CHAR 10
                WRITE_STR "char: "
                WRITE_INT ch
                WRITE_CHAR 10
                WRITE_STR "invalid char"
                WRITE_CHAR 10
                EXIT
            END

            LET temp ch
            LET temp2 0

            IF ch == 110
                LET temp 10
                LET temp2 1
            END
            IF ch == 116
                LET temp 9
                LET temp2 1
            END
            IF ch == 114
                LET temp 13
                LET temp2 1
            END

            IF ch == 34
                LET temp2 1
            END

            IF ch == 92
                LET temp2 1
            END

            IF temp2 == 0
                POKE tok_ptr 92
                ADD tok_ptr 8
                ADD tok_len 1
            END

            POKE tok_ptr temp
            ADD tok_ptr 8
            ADD tok_len 1

            LET lex_state 3
            LET need_read 1
        END
    END

    IF lex_state == 0
        IF emit_requested == 0
            IF ch == 0
                LET tok_type 3
                LET emit_requested 1
            END
        END

        IF emit_requested == 0
            IF ch == 10
                ADD line_no 1
                LET need_read 1
            END
        END

        IF emit_requested == 0
            IF ch <= 32
                LET need_read 1
            END
        END

        IF emit_requested == 0
            IF ch == 34
                LET tok_ptr token_buf
                LET tok_len 0
                LET tok_hash 0
                LET tok_value 0
                LET tok_line line_no
                LET lex_state 3
                LET need_read 1
            END
        END

        IF emit_requested == 0
            LET temp 0

            IF ch == 46
                LET temp 1
            END
            IF ch == 44
                LET temp 1
            END
            IF ch == 40
                LET temp 1
            END
            IF ch == 41
                LET temp 1
            END
            IF ch == 123
                LET temp 1
            END
            IF ch == 125
                LET temp 1
            END
            IF ch == 61
                LET temp 1
            END
            IF ch == 58
                LET temp 1
            END
            IF ch == 60
                LET temp 1
            END
            IF ch == 62
                LET temp 1
            END
            IF ch == 43
                LET temp 1
            END
            IF ch == 45
                LET temp 1
            END
            IF ch == 42
                LET temp 1
            END
            IF ch == 33
                LET temp 1
            END
            IF ch == 64
                LET temp 1
            END
            IF ch == 91
                LET temp 1
            END
            IF ch == 93
                LET temp 1
            END

            IF temp == 1
                LET tok_ptr token_buf
                LET tok_len 0
                LET tok_hash ch
                LET tok_value ch
                LET tok_line line_no
                POKE tok_ptr ch
                ADD tok_ptr 8
                ADD tok_len 1
                LET tok_type 2
                LET emit_requested 1
                LET need_read 1
            END
        END

        IF emit_requested == 0
            LET temp 0

            IF ch >= 65
                IF ch <= 90
                    LET temp 1
                END
            END
            IF ch >= 97
                IF ch <= 122
                    LET temp 1
                END
            END
            IF ch == 95
                LET temp 1
            END

            IF temp == 1
                LET tok_ptr token_buf
                LET tok_len 0
                LET tok_hash ch
                LET tok_value 0
                LET tok_line line_no
                POKE tok_ptr ch
                ADD tok_ptr 8
                ADD tok_len 1
                LET lex_state 1
                LET need_read 1
            END
        END

        IF emit_requested == 0
            LET temp 0

            IF ch >= 48
                IF ch <= 57
                    LET temp 1
                END
            END

            IF temp == 1
                LET tok_ptr token_buf
                LET tok_len 0
                LET tok_hash 0
                LET tok_value ch
                SUB tok_value 48
                LET tok_line line_no
                POKE tok_ptr ch
