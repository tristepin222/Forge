    call flush_write_buf
.write_done:
    pop rdx
    pop rsi
    pop rdi
    pop rbx
    pop rax
    ret

write_int_rax:
    push rax
    call flush_write_buf
    pop rax
    push rbx
    push rcx
    push rdx
    push rsi
    push rdi
    lea rdi, [print_buf + 32]
    mov rcx, 10
    test rax, rax
    jnz .write_int_loop
    dec rdi
    mov byte [rdi], '0'
    jmp .write_int_emit
.write_int_loop:
    xor rdx, rdx
    div rcx
    add dl, '0'
    dec rdi
    mov [rdi], dl
    test rax, rax
    jnz .write_int_loop
.write_int_emit:
    mov rsi, rdi
    lea rbx, [print_buf + 32]
    sub rbx, rsi
    mov rdx, rbx
    mov rax, 1
    mov rdi, 1
    syscall
    pop rdi
    pop rsi
    pop rdx
    pop rcx
    pop rbx
    ret

print_rax:
    push rax
    call flush_write_buf
    pop rax
    push rbx
    push rcx
    push rdx
    push rsi
    push rdi
    lea rdi, [print_buf + 31]
    mov byte [rdi], 10
    mov rcx, 10
    test rax, rax
    jnz .print_loop
    dec rdi
    mov byte [rdi], '0'
    jmp .print_emit
.print_loop:
    xor rdx, rdx
    div rcx
    add dl, '0'
    dec rdi
    mov [rdi], dl
    test rax, rax
    jnz .print_loop
.print_emit:
    mov rsi, rdi
    lea rbx, [print_buf + 32]
    sub rbx, rsi
    mov rdx, rbx
    mov rax, 1
    mov rdi, 1
    syscall
    pop rdi
    pop rsi
    pop rdx
    pop rcx
    pop rbx
    ret

read_char_rax:
    push rbx
    push rcx
    push rdx
    push rsi
    push rdi
    mov rbx, [read_pos]
    cmp rbx, [read_len]
    jb .read_char_ok
    mov rax, 0
    mov rdi, 0
    lea rsi, [read_buf]
    mov rdx, 16384
    syscall
    cmp rax, 0
    jle .read_char_eof
    mov [read_len], rax
    mov qword [read_pos], 0
    xor rbx, rbx
.read_char_ok:
    xor rax, rax
    mov al, [read_buf + rbx]
    inc rbx
    mov [read_pos], rbx
    jmp .read_char_done
.read_char_eof:
    xor rax, rax
.read_char_done:
    pop rdi
    pop rsi
    pop rdx
    pop rcx
    pop rbx
    ret

 section .bss
 vars: resq 131072
 print_buf: resb 32
 char_buf: resb 1
 write_len: resq 1
 write_buf: resb 16384
 read_len: resq 1
 read_pos: resq 1
 read_buf: resb 16384
 cond_expr_lhs: resq 1
 cond_expr_rhs: resq 1
 match_expr_value: resq 1
 match_expr_payload: resq 1
 enum_expr_payload: resq 1
"
                    EXIT
                END
            END
        END

        IF emit_handled == 0
            EXIT
        END
    END
END
END
