    emits("    mov rbx, rax")
    emitc(10)
    emits("    shl rbx, 32")
    emitc(10)
    emit_load_number(tag)
    emits("    or rax, rbx")
    emitc(10)
}

function emit_compare_enum_tag_jump_false(variable_hash: i32, tag: i32, false_label: i32, function_hash: i32) {
    emit_load_variable(function_hash, variable_hash)
    emits("    mov rbx, rax")
    emitc(10)
    emits("    shl rbx, 32")
    emitc(10)
    emits("    shr rbx, 32")
    emitc(10)
    emit_load_number(tag)
    emits("    cmp rbx, rax")
    emitc(10)
    emits("    jne ")
    emit_internal_label_name(false_label)
    emitc(10)
}

function compile_enum_variant_expression(self: Lexer, state: CompileState, type_hash: i32, variant_hash: i32, function_hash: i32) -> i32 {
    variable variant_tag: i32 = state.enum_variant_tag(type_hash, variant_hash)
    variable variant_has_payload: i32 = state.enum_variant_has_payload(type_hash, variant_hash)
    variable kind: i32 = 0

    if variant_tag < 0 {
        return -1
    }

    kind = self.next_token()
    if kind == token_symbol() {
        if self.token_value == 40 {
            if variant_has_payload == false {
                return -2
            }

            if self.compile_expression(state, function_hash) != 0 {
                return -3
            }

            if self.expect_symbol(41) != 0 {
                return -4
            }

            emit_pack_enum_payload(variant_tag)
            return 0
        }
    }

    self.push_token()
    if variant_has_payload == true {
        return -5
    }

    emit_load_number(variant_tag)
    return 0
}

function identifier_hash_wildcard() -> i32 => 95

function emit_internal_label(label: i32) {
    emit_internal_label_name(label)
    emits(":")
    emitc(10)
}

function emit_jump(label: i32) {
    emits("    jmp ")
    emit_internal_label_name(label)
    emitc(10)
}

function emit_compare_jump_false(op: i32, label: i32) {
    emits("    cmp rbx, rax")
    emitc(10)

    if op == 1 {
        emits("    jge ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    if op == 2 {
        emits("    jle ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    if op == 3 {
        emits("    jne ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    if op == 4 {
        emits("    je ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    if op == 5 {
        emits("    jg ")
        emit_internal_label_name(label)
        emitc(10)
        return 0
    }

    emits("    jl ")
    emit_internal_label_name(label)
    emitc(10)
}

function parse_compare_operator(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_symbol() {
        return -1
    }

    if self.token_value == 60 {
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 61 {
                return 5
            }
            self.push_token()
        } else {
            self.push_token()
        }

        return 1
    }

    if self.token_value == 62 {
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 61 {
                return 6
            }
            self.push_token()
        } else {
            self.push_token()
        }

        return 2
    }

    if self.token_value == 61 {
        if self.expect_symbol(61) != 0 {
            return -2
        }

        return 3
    }

    if self.token_value == 33 {
        if self.expect_symbol(61) != 0 {
            return -3
        }

        return 4
    }

    return -4
}

function parse_type_name_hash(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.expect_identifier() != 0 {
        return -1
    }
    variable type_hash: i32 = self.token_hash
    if type_hash == identifier_text_hash_array_i32() {
        type_hash = identifier_hash_array_i32()
    }

    loop {
        kind = self.next_token()

        if kind != token_symbol() {
            self.push_token()
            return type_hash
        }

        if self.token_value == 46 {
            if self.expect_identifier() != 0 {
                return -2
            }

            continue
        }

        if self.token_value == 91 {
            if self.parse_type_argument_list_tail() != 0 {
                return -3
            }

            continue
        }

        self.push_token()
        return type_hash
    }
    return type_hash
}

function parse_optional_return_type_hash(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_symbol() {
        self.push_token()
        return 0
    }

    if self.token_value != 45 {
        self.push_token()
        return 0
    }

    if self.expect_symbol(62) != 0 {
        return -1
    }

    return self.parse_type_name_hash()
}

function check_return_expression_type(state: CompileState, line: i32) -> i32 {
    if state.current_return_type_hash == 0 {
        return 0
    }

    if state.last_expression_type_hash == 0 {
        return 0
    }

    if state.current_return_type_hash == state.last_expression_type_hash {
        return 0
    }

    emit_return_type_mismatch(state.current_return_type_hash, state.last_expression_type_hash, line, state.current_func_hash)
    return -1
}

function emit_missing_enum_variants(state: CompileState) {
    if state.missing_enum_active != 0 {
        emits("missing variants:")
        emitc(10)

        if state.missing_enum_hash_1 != 0 {
            emits("- ")
            emit_enum_variant_name(state.missing_enum_hash_1)
            emitc(10)
        }

        if state.missing_enum_hash_2 != 0 {
            emits("- ")
            emit_enum_variant_name(state.missing_enum_hash_2)
            emitc(10)
        }

        if state.missing_enum_hash_3 != 0 {
            emits("- ")
            emit_enum_variant_name(state.missing_enum_hash_3)
            emitc(10)
        }

        if state.missing_enum_hash_4 != 0 {
            emits("- ")
            emit_enum_variant_name(state.missing_enum_hash_4)
            emitc(10)
        }
    }
}

function parse_member_name_hash(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind == token_identifier() {
        return self.token_hash
    }

    if kind == token_keyword() {
        if self.token_value == keyword_value() {
            return keyword_hash_value()
        }
    }

    return -1
}

function compile_struct_literal_into_variable(self: Lexer, state: CompileState, function_hash: i32, variable_hash: i32, type_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    variable field_hash: i32 = 0
    variable field_offset: i32 = 0

    emit_initialize_struct_storage_pointer(function_hash, variable_hash)

    if kind == token_symbol() {
        if self.token_value == 125 {
            return 0
        }
    }

    self.push_token()

    loop {
        field_hash = self.parse_member_name_hash()
        if field_hash < 0 {
            return -1
        }

        field_offset = state.lookup_type_field_offset(type_hash, field_hash)
        if field_offset < 0 {
            return -2
        }

        if self.expect_symbol(58) != 0 {
            return -3
        }

        if self.compile_expression(state, function_hash) != 0 {
            return -4
        }

        emit_store_struct_field(function_hash, variable_hash, field_offset)

        kind = self.next_token()
        if kind != token_symbol() {
            return -5
        }

        if self.token_value == 125 {
            return 0
        }

        if self.token_value != 44 {
            return -6
        }
    }
    return 0
}

function compile_array_literal_into_variable(self: Lexer, state: CompileState, function_hash: i32, variable_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    variable element_index: i32 = 0

    if kind == token_symbol() {
        if self.token_value == 93 {
            emit_declare_array_storage(function_hash, variable_hash, 0)
            return 0
        }
    }

    self.push_token()

    loop {
        if self.compile_expression(state, function_hash) != 0 {
            return -2
        }

        emit_store_array_element(function_hash, variable_hash, element_index)
        element_index += 1

        kind = self.next_token()
        if kind != token_symbol() {
            return -3
        }

        if self.token_value == 93 {
            break
        }

        if self.token_value != 44 {
            return -4
        }
    }

    emit_declare_array_storage(function_hash, variable_hash, element_index)
    return 0
}

function compile_factor(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    state.last_array_argument_hash = 0
    state.last_array_argument_mode = 0

    if kind == token_number() {
        emit_load_number(self.token_value)
        state.last_expression_type_hash = identifier_hash_i32()
        return 0
    }

    if kind == token_keyword() {
        if self.token_value == keyword_true() {
            emit_load_number(1)
            state.last_expression_type_hash = identifier_hash_bool()
            return 0
        }

        if self.token_value == keyword_false() {
            emit_load_number(0)
            state.last_expression_type_hash = identifier_hash_bool()
            return 0
        }

        if self.token_value == keyword_match() {
            if state.match_expr_active != 0 {
                if self.compile_match_expression_nested(state, function_hash) != 0 {
                    return -4
                }
            } else {
                if self.compile_match_expression(state, function_hash) != 0 {
                    return -4
                }
            }
            return 0
        }
    }

    if kind == token_symbol() {
        if self.token_value == 45 {
            if self.compile_factor(state, function_hash) != 0 {
                return -1
            }

            emits("    neg rax")
            emitc(10)
            state.last_expression_type_hash = identifier_hash_i32()
            return 0
        }

        if self.token_value == 40 {
            if self.compile_expression(state, function_hash) != 0 {
                return -2
            }

            if self.expect_symbol(41) != 0 {
                return -3
            }

            return 0
        }
    }

    if kind == token_identifier() {
        variable name_hash: i32 = self.token_hash
        variable type_hash: i32 = state.lookup_variable_type(function_hash, name_hash)
        variable variable_mode: i32 = lookup_variable_mode(state, function_hash, name_hash)
        variable member_hash: i32 = 0
        variable field_offset: i32 = 0
        variable arg_count: i32 = 0
        variable call_hash: i32 = 0
        variable arg_hash: i32 = 0
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 58 {
                if self.expect_symbol(58) != 0 {
                    return -4
                }

                member_hash = self.parse_member_name_hash()
                if member_hash < 0 {
                    return -5
                }

                if self.compile_enum_variant_expression(state, name_hash, member_hash, function_hash) != 0 {
                    return -6
                }
                state.last_expression_type_hash = 0
                return 0
            }

            if self.token_value == 46 {
                member_hash = self.parse_member_name_hash()
                if member_hash < 0 {
                    return -11
                }

                kind = self.next_token()
                if kind == token_symbol() {
                    if self.token_value == 40 {
                        if type_hash == 0 {
                            return -12
                        }

                        emit_load_variable(function_hash, name_hash)
                        emit_push_rax()

                        call_hash = state.resolve_import_call_hash(member_hash)

                        if state.push_call_frame(call_hash) != 0 {
                            return -13
                        }

                        if state.increment_call_arg_count() != 0 {
                            return -14
                        }

                        arg_count = self.compile_call_arguments(state, function_hash)
                        if arg_count < 0 {
                            return -15
                        }

                        call_hash = state.pop_call_frame()
                        emit_call_function(call_hash)
                        state.last_expression_type_hash = lookup_function_return_type(state, call_hash)
                        return 0
                    }
                }

                self.push_token()
                if type_hash == 0 {
                    return -16
                }

                field_offset = state.lookup_type_field_offset(type_hash, member_hash)
                if field_offset < 0 {
                    return -17
                }

                emit_load_struct_field(function_hash, name_hash, field_offset)
                state.last_expression_type_hash = 0
                return 0
            }

            if self.token_value == 91 {
                if type_hash != identifier_hash_array_i32() {
                    return -20
                }

                emit_load_array_base(function_hash, name_hash, variable_mode)
                emit_push_rax()

                if self.compile_expression(state, function_hash) != 0 {
                    return -21
                }

                if self.expect_symbol(93) != 0 {
                    return -22
                }

                emit_pop_rbx()
                emits("    mov rax, [rbx + rax*8]")
                emitc(10)
                state.last_expression_type_hash = identifier_hash_i32()
                return 0
            }

            if self.token_value == 40 {
                if state.is_len_name(name_hash) == true {
                    if self.expect_identifier() != 0 {
                        return -23
                    }

                    arg_hash = self.token_hash
                if state.lookup_variable_type(function_hash, arg_hash) != identifier_hash_array_i32() {
                    return -24
                }

                if self.expect_symbol(41) != 0 {
                    return -25
                }

                emit_load_array_length(function_hash, arg_hash, lookup_variable_mode(state, function_hash, arg_hash))
                state.last_expression_type_hash = identifier_hash_i32()
                return 0
            }

                call_hash = state.resolve_import_call_hash(name_hash)
                if state.push_call_frame(call_hash) != 0 {
                    return -26
                }

                arg_count = self.compile_call_arguments(state, function_hash)
                if arg_count < 0 {
                    return -27
                }

                call_hash = state.pop_call_frame()
                emit_call_function(call_hash)
                state.last_expression_type_hash = lookup_function_return_type(state, call_hash)
                return 0
            }
        }

        self.push_token()
        if type_hash == identifier_hash_array_i32() {
            emit_load_array_base(function_hash, name_hash, variable_mode)
            state.last_expression_type_hash = type_hash
            state.last_array_argument_hash = name_hash
            state.last_array_argument_mode = variable_mode
            return 0
        }
        emit_load_variable(function_hash, name_hash)
        state.last_expression_type_hash = type_hash
        return 0
    }

    return -13
}

function compile_call_arguments(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    variable arg_count: i32 = 0
    variable pop_index: i32 = 0

    if kind == token_symbol() {
        if self.token_value == 41 {
            arg_count = state.current_call_arg_count()
            if arg_count < 0 {
                return -8
            }

            if arg_count > 6 {
                return -9
            }

            if arg_count == 0 {
                return 0
            }

            pop_index = arg_count - 1
            loop {
                if emit_pop_call_argument(pop_index) != 0 {
                    return -10
                }

                if pop_index == 0 {
                    break
                }

                pop_index -= 1
            }

            return arg_count
        }
    }

    self.push_token()

    loop {
        if self.compile_expression(state, function_hash) != 0 {
            return -1
        }

        emit_push_rax()
        if state.increment_call_arg_count() != 0 {
            return -4
        }

        if state.last_expression_type_hash == identifier_hash_array_i32() {
            if state.last_array_argument_hash == 0 {
                return -11
            }

            emit_load_array_length(function_hash, state.last_array_argument_hash, state.last_array_argument_mode)
            emit_push_rax()
            if state.increment_call_arg_count() != 0 {
                return -12
            }
        }

        kind = self.next_token()
        if kind != token_symbol() {
            return -2
        }

        if self.token_value == 41 {
            break
        }

        if self.token_value != 44 {
            return -3
        }
    }

    arg_count = state.current_call_arg_count()
    if arg_count < 0 {
        return -5
    }

    if arg_count > 6 {
        return -6
    }

    pop_index = arg_count - 1
    loop {
        if emit_pop_call_argument(pop_index) != 0 {
            return -7
        }

        if pop_index == 0 {
            break
        }

        pop_index -= 1
    }

    return arg_count
}

function compile_term(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    if self.compile_factor(state, function_hash) != 0 {
        return -1
    }

    loop {
        variable kind: i32 = self.next_token()

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value != 42 {
            self.push_token()
            return 0
        }

        emit_push_rax()

        if self.compile_factor(state, function_hash) != 0 {
            return -2
        }

        emit_pop_rbx()
        emits("    imul rax, rbx")
        emitc(10)
        state.last_expression_type_hash = identifier_hash_i32()
    }
    return 0
}

function compile_expression(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    if self.compile_term(state, function_hash) != 0 {
        return -1
    }

    loop {
        variable kind: i32 = self.next_token()

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value == 43 {
            emit_push_rax()

            if self.compile_term(state, function_hash) != 0 {
                return -2
            }

            emit_pop_rbx()
            emits("    add rax, rbx")
            emitc(10)
            state.last_expression_type_hash = identifier_hash_i32()
            continue
        }

        if self.token_value == 45 {
            emit_push_rax()

            if self.compile_term(state, function_hash) != 0 {
                return -2
            }

            emit_pop_rbx()

            emits("    sub rbx, rax")
            emitc(10)
            emits("    mov rax, rbx")
            emitc(10)
            state.last_expression_type_hash = identifier_hash_i32()
            continue
        }

        self.push_token()
        return 0
    }
    return 0
}

function peek_compare_operator(self: Lexer) -> bool {
    variable saved_index: i32 = self.index
    variable saved_line: i32 = self.line
    variable saved_has_peeked: i32 = self.has_peeked
    variable saved_peeked_char: i32 = self.peeked_char
    variable result: bool = false

    if self.has_pushed == true {
        if self.pushed_kind == token_symbol() {
            if self.pushed_value == 60 {
                return true
            }
            if self.pushed_value == 62 {
                return true
            }
            if self.pushed_value == 61 {
                if self.peek_char() == 61 {
                    return true
                }
                return false
            }
            if self.pushed_value == 33 {
                if self.peek_char() == 61 {
                    return true
                }
                return false
            }
        }
        return false
    }

    self.skip_whitespace()

    variable first: i32 = self.peek_char()
    if first == 60 {
        result = true
    }
    if first == 62 {
        result = true
    }
    if first == 61 {
        self.next_char()
        variable second: i32 = self.peek_char()
        if second == 61 {
            result = true
        }
    }
    if first == 33 {
        self.next_char()
        variable second: i32 = self.peek_char()
        if second == 61 {
            result = true
        }
    }

    self.index = saved_index
    self.line = saved_line
    self.has_peeked = saved_has_peeked
    self.peeked_char = saved_peeked_char
    return result
}

function compile_condition_jump_false(self: Lexer, state: CompileState, function_hash: i32, false_label: i32) -> i32 {
    variable op: i32 = 0

    if self.compile_expression(state, function_hash) != 0 {
        return -1
    }

    if self.peek_compare_operator() == true {
        emit_push_rax()

        op = self.parse_compare_operator()
        if op < 0 {
            return -2
        }

        if self.compile_expression(state, function_hash) != 0 {
            return -3
        }

        emit_pop_rbx()
        emit_compare_jump_false(op, false_label)
        return 0
    }

    emits("    cmp rax, 0")
    emitc(10)
    emits("    je ")
    emit_internal_label_name(false_label)
    emitc(10)
    return 0
}

function compile_binding_tail(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable type_hash: i32 = 0
    variable field_count: i32 = 0
    variable kind: i32 = 0
    variable source_hash: i32 = 0
    variable variant_hash: i32 = 0

    if self.expect_identifier() != 0 {
        return -1
    }
    variable variable_hash: i32 = self.token_hash

    kind = self.next_token()
    if kind != token_symbol() {
        return -2
    }

    if self.token_value == 58 {
        type_hash = self.parse_type_name_hash()
        if type_hash < 0 {
            return -3
        }

        if self.expect_symbol(61) != 0 {
            return -4
        }
    } else {
        if self.token_value != 61 {
            return -5
        }
    }

    if type_hash != 0 {
        if state.register_variable_type(function_hash, variable_hash, type_hash) != 0 {
            return -6
        }
    }

    kind = self.next_token()
    if kind == token_symbol() {
        if self.token_value == 91 {
            if type_hash != 0 {
                return -7
            }

            if state.register_variable_type(function_hash, variable_hash, identifier_hash_array_i32()) != 0 {
                return -8
            }

            if self.compile_array_literal_into_variable(state, function_hash, variable_hash) != 0 {
                return -9
            }

            return 0
        }
    }

    if kind == token_keyword() {
        if self.token_value == keyword_match() {
            emit_declare_variable(function_hash, variable_hash)
            if self.compile_match_expression_into_variable(state, function_hash, variable_hash) != 0 {
                return -10
            }
            return 0
        }
    }
    self.push_token()

    emit_declare_variable(function_hash, variable_hash)

    field_count = state.type_field_count(type_hash)
    if field_count > 0 {
        kind = self.next_token()
        if kind == token_identifier() {
            if self.token_hash == type_hash {
                kind = self.next_token()
                if kind == token_symbol() {
                    if self.token_value == 123 {
                        emit_declare_struct_storage(function_hash, variable_hash, field_count)
                        if self.compile_struct_literal_into_variable(state, function_hash, variable_hash, type_hash) != 0 {
                            return -11
                        }

                        return 0
                    }
                    if self.token_value == 58 {
                        if self.expect_symbol(58) != 0 {
                            return -10
                        }
                        if self.expect_identifier() != 0 {
                            return -12
                        }
                        variant_hash = self.token_hash
                        if self.compile_enum_variant_expression(state, type_hash, variant_hash, function_hash) != 0 {
                            return -13
                        }
                        emit_store_variable(function_hash, variable_hash)
                        return 0
                    }
                }
                return -10
            }
        }

        self.push_token()
    }

    if type_hash == identifier_hash_str() {
        kind = self.next_token()

        if kind == token_string() {
            if self.emit_load_current_string_literal(state) != 0 {
                return -12
            }

            emit_store_variable(function_hash, variable_hash)
            return 0
        }

        if kind == token_identifier() {
            source_hash = self.token_hash
            if state.lookup_variable_type(function_hash, source_hash) == identifier_hash_str() {
                emit_load_variable(function_hash, source_hash)
                emit_store_variable(function_hash, variable_hash)
                return 0
            }
        }

        self.push_token()
    }

    if self.compile_expression(state, function_hash) != 0 {
        return -13
    }

    emit_store_variable(function_hash, variable_hash)
    return 0
}

function compile_identifier_statement_tail(self: Lexer, state: CompileState, function_hash: i32, name_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    variable type_hash: i32 = state.lookup_variable_type(function_hash, name_hash)
    variable variable_mode: i32 = lookup_variable_mode(state, function_hash, name_hash)
    variable member_hash: i32 = 0
    variable field_offset: i32 = 0
    variable arg_count: i32 = 0
    variable call_hash: i32 = 0
    variable string_hash: i32 = 0
    variable variant_hash: i32 = 0

    if kind != token_symbol() {
        return -1
    }

    if self.token_value == 40 {
        if state.is_print_name(name_hash) == true {
            kind = self.next_token()
            if kind == token_symbol() {
                if self.token_value == 41 {
                    return -2
                }
            }

            if kind == token_string() {
                if self.emit_load_current_string_literal(state) != 0 {
                    return -3
                }

                if self.expect_symbol(41) != 0 {
                    return -4
                }

                emit_print_cstr_rax_call()
                return 0
            }

            if kind == token_identifier() {
                string_hash = self.token_hash
                if state.lookup_variable_type(function_hash, string_hash) == identifier_hash_str() {
                    if self.expect_symbol(41) != 0 {
                        return -5
                    }

                    emit_load_variable(function_hash, string_hash)
                    emit_print_cstr_rax_call()
                    return 0
                }
            }

            self.push_token()

            if self.compile_expression(state, function_hash) != 0 {
                return -6
            }

            if self.expect_symbol(41) != 0 {
                return -7
            }

            emit_print_rax_call()
            return 0
        }

        call_hash = state.resolve_import_call_hash(name_hash)
        if state.push_call_frame(call_hash) != 0 {
            return -8
        }

        arg_count = self.compile_call_arguments(state, function_hash)
        if arg_count < 0 {
            return -9
        }

        emit_call_function(state.pop_call_frame())
        return 0
    }

    if self.token_value == 46 {
        if type_hash == 0 {
            return -7
        }

        member_hash = self.parse_member_name_hash()
        if member_hash < 0 {
            return -8
        }

        field_offset = state.lookup_type_field_offset(type_hash, member_hash)

        kind = self.next_token()
        if kind != token_symbol() {
            return -9
        }

        if self.token_value == 40 {
            emit_load_variable(function_hash, name_hash)
            emit_push_rax()

            call_hash = state.resolve_import_call_hash(member_hash)

            if state.push_call_frame(call_hash) != 0 {
                return -10
            }

            if state.increment_call_arg_count() != 0 {
                return -11
            }

            arg_count = self.compile_call_arguments(state, function_hash)
            if arg_count < 0 {
                return -12
            }

            emit_call_function(state.pop_call_frame())
            return 0
        }

        if field_offset < 0 {
            return -13
        }

        if self.token_value == 61 {
            kind = self.next_token()
            if kind == token_identifier() {
                if self.token_hash == type_hash {
                    if self.expect_symbol(123) != 0 {
                        return -14
                    }

                    if self.compile_struct_literal_into_variable(state, function_hash, name_hash, type_hash) != 0 {
                        return -15
                    }

                    return 0
                }
            }

            self.push_token()

            if self.compile_expression(state, function_hash) != 0 {
                return -16
            }

            emit_store_struct_field(function_hash, name_hash, field_offset)
            return 0
        }

        if self.token_value == 43 {
            if self.expect_symbol(61) != 0 {
                return -17
            }

            emit_load_struct_field(function_hash, name_hash, field_offset)
            emit_push_rax()
            if self.compile_expression(state, function_hash) != 0 {
                return -18
            }

            emit_pop_rbx()
            emits("    add rax, rbx")
            emitc(10)
            emit_store_struct_field(function_hash, name_hash, field_offset)
            return 0
        }

        if self.token_value == 45 {
            if self.expect_symbol(61) != 0 {
                return -19
            }

            emit_load_struct_field(function_hash, name_hash, field_offset)
            emit_push_rax()
            if self.compile_expression(state, function_hash) != 0 {
                return -20
            }

            emit_pop_rbx()
            emits("    sub rbx, rax")
            emitc(10)
            emits("    mov rax, rbx")
            emitc(10)
            emit_store_struct_field(function_hash, name_hash, field_offset)
            return 0
        }

        return -21
    }

    if self.token_value == 91 {
        variable op_value: i32 = 0

        if type_hash != identifier_hash_array_i32() {
            return -30
        }

        emit_load_array_base(function_hash, name_hash, variable_mode)
        emit_push_rax()

        if self.compile_expression(state, function_hash) != 0 {
            return -31
        }

        if self.expect_symbol(93) != 0 {
            return -32
        }

        emit_push_rax()

        kind = self.next_token()
        if kind != token_symbol() {
            return -33
        }

        op_value = self.token_value

        if op_value == 43 {
            if self.expect_symbol(61) != 0 {
                return -34
            }

            emit_pop_rbx()
            emits("    pop rcx")
            emitc(10)
            emits("    mov rax, [rcx + rbx*8]")
            emitc(10)
            emits("    push rcx")
            emitc(10)
            emits("    push rbx")
            emitc(10)
            emit_push_rax()

            if self.compile_expression(state, function_hash) != 0 {
                return -35
            }

            emit_pop_rbx()
            emits("    add rax, rbx")
            emitc(10)
            emit_pop_rbx()
            emits("    pop rcx")
            emitc(10)
            emits("    mov [rcx + rbx*8], rax")
            emitc(10)
            return 0
        }

        if op_value == 45 {
            if self.expect_symbol(61) != 0 {
                return -36
            }

            emit_pop_rbx()
            emits("    pop rcx")
            emitc(10)
            emits("    mov rax, [rcx + rbx*8]")
            emitc(10)
            emits("    push rcx")
            emitc(10)
            emits("    push rbx")
            emitc(10)
            emit_push_rax()

            if self.compile_expression(state, function_hash) != 0 {
                return -37
            }

            emit_pop_rbx()
            emits("    sub rbx, rax")
            emitc(10)
            emits("    mov rax, rbx")
            emitc(10)
            emit_pop_rbx()
            emits("    pop rcx")
            emitc(10)
            emits("    mov [rcx + rbx*8], rax")
            emitc(10)
            return 0
        }

        if op_value != 61 {
            return -38
        }

        if self.compile_expression(state, function_hash) != 0 {
            return -39
        }

        emit_pop_rbx()
        emits("    pop rcx")
        emitc(10)
        emits("    mov [rcx + rbx*8], rax")
        emitc(10)
        return 0
    }

    if self.token_value == 61 {
        kind = self.next_token()

        if kind == token_keyword() {
            if self.token_value == keyword_match() {
                if self.compile_match_expression_into_variable(state, function_hash, name_hash) != 0 {
                    return -21
                }
                return 0
            }
        }

        if type_hash == identifier_hash_str() {
            if kind == token_string() {
                if self.emit_load_current_string_literal(state) != 0 {
                    return -22
                }

                emit_store_variable(function_hash, name_hash)
                return 0
            }

            if kind == token_identifier() {
                string_hash = self.token_hash
                if state.lookup_variable_type(function_hash, string_hash) == identifier_hash_str() {
                    emit_load_variable(function_hash, string_hash)
                    emit_store_variable(function_hash, name_hash)
                    return 0
                }
            }
        }

        if type_hash != 0 {
            if kind == token_identifier() {
                if self.token_hash == type_hash {
                    kind = self.next_token()
                    if kind == token_symbol() {
                        if self.token_value == 123 {
                            if self.compile_struct_literal_into_variable(state, function_hash, name_hash, type_hash) != 0 {
                                return -24
                            }

                            return 0
                        }
                        if self.token_value == 58 {
                            if self.expect_symbol(58) != 0 {
                                return -23
                            }
                            if self.expect_identifier() != 0 {
                                return -24
                            }
                            variant_hash = self.token_hash
                            if self.compile_enum_variant_expression(state, type_hash, variant_hash, function_hash) != 0 {
                                return -25
                            }
                            emit_store_variable(function_hash, name_hash)
                            return 0
                        }
                    }
                    return -23
                }
            }

            self.push_token()
        } else {
            self.push_token()
        }

        if self.compile_expression(state, function_hash) != 0 {
            return -25
        }

        emit_store_variable(function_hash, name_hash)
        return 0
    }

    if self.token_value == 43 {
        if self.expect_symbol(61) != 0 {
            return -25
        }

        emit_load_variable(function_hash, name_hash)
        emit_push_rax()
        if self.compile_expression(state, function_hash) != 0 {
            return -26
        }

        emit_pop_rbx()
        emits("    add rax, rbx")
        emitc(10)
        emit_store_variable(function_hash, name_hash)
        return 0
    }

    if self.token_value == 45 {
        if self.expect_symbol(61) != 0 {
            return -27
        }

        emit_load_variable(function_hash, name_hash)
        emit_push_rax()
        if self.compile_expression(state, function_hash) != 0 {
            return -28
        }

        emit_pop_rbx()
        emits("    sub rbx, rax")
        emitc(10)
        emits("    mov rax, rbx")
        emitc(10)
        emit_store_variable(function_hash, name_hash)
        return 0
    }

    return -35
}

function compile_if_tail(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable else_label: i32 = state.allocate_label()
    variable end_label: i32 = state.allocate_label()
    variable kind: i32 = 0
    variable is_top_level: bool = false
    variable parent_depth: i32 = 0
    variable then_return: bool = false
    variable else_return: bool = false
    variable has_else: bool = false
    variable statement_returns: i32 = 0

    parent_depth = state.current_block_depth
    if state.current_block_depth == 1 {
        is_top_level = true
    }
    set_if_is_top_level(state, parent_depth, is_top_level)
    set_if_has_else(state, parent_depth, 0)
    set_if_then_return(state, parent_depth, 0)
    set_if_end_label(state, parent_depth, end_label)

    if self.compile_condition_jump_false(state, function_hash, else_label) != 0 {
        return -1
    }

    if self.expect_symbol(123) != 0 {
        return -2
    }

    if self.compile_block_body(state, function_hash) != 0 {
        return -3
    }
    parent_depth = state.current_block_depth
    if get_block_return_guaranteed(state, parent_depth + 1) == 1 {
        then_return = true
    }
    set_if_then_return(state, parent_depth, then_return)

    emit_jump(end_label)
    emit_internal_label(else_label)

    kind = self.next_token()
    if kind == token_keyword() {
        if self.token_value == keyword_else() {
            if self.expect_symbol(123) != 0 {
                return -4
            }

            has_else = true
            set_if_has_else(state, parent_depth, 1)
            if self.compile_block_body(state, function_hash) != 0 {
                return -5
            }
            parent_depth = state.current_block_depth
            else_return = false
            if get_block_return_guaranteed(state, parent_depth + 1) == 1 {
                else_return = true
            }
        } else {
            self.push_token()
        }
    } else {
        self.push_token()
    }

    parent_depth = state.current_block_depth
    end_label = get_if_end_label(state, parent_depth)
    emit_internal_label(end_label)
    has_else = get_if_has_else(state, parent_depth)
    then_return = get_if_then_return(state, parent_depth)
    is_top_level = get_if_is_top_level(state, parent_depth)
    if has_else != 0 {
        if then_return != 0 {
            if else_return != 0 {
                statement_returns = 1
            }
        }
    }
    if statement_returns != 0 {
        if parent_depth > 0 {
            set_block_return_guaranteed(state, parent_depth, 1)
        }
        if is_top_level != 0 {
            state.current_return_guaranteed = 1
        }
        state.last_statement_return_guaranteed = 1
    } else {
        state.last_statement_return_guaranteed = 0
    }
    if parent_depth == 1 {
        if get_block_return_guaranteed(state, parent_depth) == 1 {
            state.current_return_guaranteed = 1
        }
    }
    return 0
}

function compile_while_tail(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable start_label: i32 = state.allocate_label()
    variable end_label: i32 = state.allocate_label()
    variable previous_loop_start: i32 = state.current_loop_start
    variable previous_loop_continue: i32 = state.current_loop_continue
    variable previous_loop_end: i32 = state.current_loop_end

    state.current_loop_start = start_label
    state.current_loop_continue = start_label
    state.current_loop_end = end_label

    emit_internal_label(start_label)

    if self.compile_condition_jump_false(state, function_hash, end_label) != 0 {
        state.current_loop_start = previous_loop_start
        state.current_loop_continue = previous_loop_continue
        state.current_loop_end = previous_loop_end
        return -1
    }

    if self.expect_symbol(123) != 0 {
        state.current_loop_start = previous_loop_start
        state.current_loop_continue = previous_loop_continue
        state.current_loop_end = previous_loop_end
        return -2
    }

    if self.compile_block_body(state, function_hash) != 0 {
        state.current_loop_start = previous_loop_start
        state.current_loop_continue = previous_loop_continue
        state.current_loop_end = previous_loop_end
        return -3
    }

    emit_jump(start_label)
    emit_internal_label(end_label)
    state.current_loop_start = previous_loop_start
    state.current_loop_continue = previous_loop_continue
    state.current_loop_end = previous_loop_end
    return 0
}

function compile_loop_tail(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable start_label: i32 = state.allocate_label()
    variable end_label: i32 = state.allocate_label()
    variable previous_loop_start: i32 = state.current_loop_start
    variable previous_loop_continue: i32 = state.current_loop_continue
    variable previous_loop_end: i32 = state.current_loop_end

    state.current_loop_start = start_label
    state.current_loop_continue = start_label
    state.current_loop_end = end_label

    if self.expect_symbol(123) != 0 {
        state.current_loop_start = previous_loop_start
        state.current_loop_continue = previous_loop_continue
        state.current_loop_end = previous_loop_end
        return -1
    }

    emit_internal_label(start_label)

    if self.compile_block_body(state, function_hash) != 0 {
        state.current_loop_start = previous_loop_start
        state.current_loop_continue = previous_loop_continue
        state.current_loop_end = previous_loop_end
        return -2
    }

    emit_jump(start_label)
    emit_internal_label(end_label)
    state.current_loop_start = previous_loop_start
    state.current_loop_continue = previous_loop_continue
    state.current_loop_end = previous_loop_end
    return 0
}

function compile_for_tail(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable loop_variable_hash: i32 = 0
    variable range_end_hash: i32 = 910000000 + state.allocate_label()
    variable condition_label: i32 = state.allocate_label()
    variable continue_label: i32 = state.allocate_label()
    variable end_label: i32 = state.allocate_label()
    variable previous_loop_start: i32 = state.current_loop_start
    variable previous_loop_continue: i32 = state.current_loop_continue
    variable previous_loop_end: i32 = state.current_loop_end

    if self.expect_identifier() != 0 {
        return -1
    }
    loop_variable_hash = self.token_hash

    if self.expect_keyword(keyword_in()) != 0 {
        return -2
    }

    emit_declare_variable(function_hash, loop_variable_hash)
    if self.compile_expression(state, function_hash) != 0 {
        return -3
    }
    emit_store_variable(function_hash, loop_variable_hash)

    if self.expect_symbol(46) != 0 {
        return -4
    }

    if self.expect_symbol(46) != 0 {
        return -5
    }

    emit_declare_variable(function_hash, range_end_hash)
    if self.compile_expression(state, function_hash) != 0 {
        return -6
    }
    emit_store_variable(function_hash, range_end_hash)

    if self.expect_symbol(123) != 0 {
        return -7
    }

    state.current_loop_start = continue_label
    state.current_loop_continue = continue_label
    state.current_loop_end = end_label

    emit_jump(condition_label)
    emit_internal_label(continue_label)
    emit_load_variable(function_hash, loop_variable_hash)
    emits("    add rax, 1")
    emitc(10)
    emit_store_variable(function_hash, loop_variable_hash)

    emit_internal_label(condition_label)
    emit_load_variable(function_hash, loop_variable_hash)
    emit_push_rax()
    emit_load_variable(function_hash, range_end_hash)
    emit_pop_rbx()
    emits("    cmp rbx, rax")
    emitc(10)
    emits("    jge ")
    emit_internal_label_name(end_label)
    emitc(10)

    if self.compile_block_body(state, function_hash) != 0 {
        state.current_loop_start = previous_loop_start
        state.current_loop_continue = previous_loop_continue
        state.current_loop_end = previous_loop_end
        return -8
    }

    emit_jump(continue_label)
    emit_internal_label(end_label)

    state.current_loop_start = previous_loop_start
    state.current_loop_continue = previous_loop_continue
    state.current_loop_end = previous_loop_end
    return 0
}

function compile_match_tail(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable match_value_hash: i32 = 900000000 + state.allocate_label()
    variable end_label: i32 = state.allocate_label()
    variable kind: i32 = 0
    variable next_label: i32 = 0
    variable pattern_value: i32 = 0
    variable is_default_arm: bool = false
    variable enum_type_hash: i32 = 0
    variable enum_variant_hash: i32 = 0
    variable payload_binding_hash: i32 = 0
    variable has_payload_pattern: i32 = false
    variable guard_present: bool = false
    variable is_top_level: bool = false
    variable match_all_return: bool = true
    variable has_default_arm: bool = false
    variable arm_return: bool = false
    variable parent_depth: i32 = 0
    variable statement_returns: i32 = 0
    variable match_enum_type: i32 = 0
    variable match_enum_count: i32 = 0
    variable match_enum_seen_1: i32 = 0
    variable match_enum_seen_2: i32 = 0
    variable match_enum_seen_3: i32 = 0
    variable match_enum_seen_4: i32 = 0
    variable match_enum_invalid: i32 = 0
    variable match_enum_exhaustive: i32 = 0

    parent_depth = state.current_block_depth
    if state.current_block_depth == 1 {
        is_top_level = true
    }

    if self.compile_expression(state, function_hash) != 0 {
        return -1
    }

    emit_declare_variable(function_hash, match_value_hash)
    emit_store_variable(function_hash, match_value_hash)

    if self.expect_symbol(123) != 0 {
        return -2
    }

    loop {
        kind = self.next_token()
        has_payload_pattern = false
        guard_present = false
        next_label = 0

        if kind == token_symbol() {
            if self.token_value == 125 {
                break
            }
        }

        is_default_arm = false

        if kind == token_number() {
            pattern_value = self.token_value
            match_enum_invalid = 1
            if match_enum_type > 0 { match_enum_type = -1 }
            next_label = state.allocate_label()
            emit_load_variable(function_hash, match_value_hash)
            emit_push_rax()
            emit_load_number(pattern_value)
            emit_pop_rbx()
            emits("    cmp rbx, rax")
            emitc(10)
            emits("    jne ")
            emit_internal_label_name(next_label)
            emitc(10)
        } else {
            if kind == token_keyword() {
                if self.token_value == keyword_true() {
                    pattern_value = 1
                    match_enum_invalid = 1
                    if match_enum_type > 0 { match_enum_type = -1 }
                    next_label = state.allocate_label()
                    emit_load_variable(function_hash, match_value_hash)
                    emit_push_rax()
                    emit_load_number(pattern_value)
                    emit_pop_rbx()
                    emits("    cmp rbx, rax")
                    emitc(10)
                    emits("    jne ")
                    emit_internal_label_name(next_label)
                    emitc(10)
                } else {
                    if self.token_value == keyword_false() {
                        pattern_value = 0
                        match_enum_invalid = 1
                        if match_enum_type > 0 { match_enum_type = -1 }
                        next_label = state.allocate_label()
                        emit_load_variable(function_hash, match_value_hash)
                        emit_push_rax()
                        emit_load_number(pattern_value)
                        emit_pop_rbx()
                        emits("    cmp rbx, rax")
                        emitc(10)
                        emits("    jne ")
                        emit_internal_label_name(next_label)
                        emitc(10)
                    } else {
                        if self.token_value == keyword_default() {
                            is_default_arm = true
                        } else {
                            return -3
                        }
                    }
                }
            } else {
                if kind == token_identifier() {
                    if self.token_hash == identifier_hash_wildcard() {
                        is_default_arm = true
                    } else {
                        enum_type_hash = self.token_hash

                        if self.expect_symbol(58) != 0 {
                            return -4
                        }

                        if self.expect_symbol(58) != 0 {
                            return -5
                        }

                        if self.expect_identifier() != 0 {
                            return -6
                        }
                        enum_variant_hash = self.token_hash

                        if enum_variant_hash == identifier_hash_wildcard() {
                            is_default_arm = true
                            if match_enum_invalid != 0 {
                                match_enum_type = -1
                            } else {
                                if match_enum_type == 0 {
                                    match_enum_type = enum_type_hash
                                    match_enum_count = state.type_field_count(enum_type_hash)
                                } else {
                                    if match_enum_type != enum_type_hash {
                                        match_enum_type = -1
                                    }
                                }
                            }
                        } else {
                            pattern_value = state.enum_variant_tag(enum_type_hash, enum_variant_hash)
                            if pattern_value < 0 {
                                return -7
                            }
                            if match_enum_invalid != 0 {
                                match_enum_type = -1
                            } else {
                                if match_enum_type == 0 {
                                    match_enum_type = enum_type_hash
                                    match_enum_count = state.type_field_count(enum_type_hash)
                                } else {
                                    if match_enum_type != enum_type_hash {
                                        match_enum_type = -1
                                    }
                                }
                            }
                            if match_enum_type > 0 {
                                if pattern_value == 1 { match_enum_seen_1 = 1 }
                                if pattern_value == 2 { match_enum_seen_2 = 1 }
                                if pattern_value == 3 { match_enum_seen_3 = 1 }
                                if pattern_value == 4 { match_enum_seen_4 = 1 }
                            }

                            next_label = state.allocate_label()
                            emit_compare_enum_tag_jump_false(match_value_hash, pattern_value, next_label, function_hash)

                            kind = self.next_token()
                            if kind == token_symbol() {
                                if self.token_value == 40 {
                                    if state.enum_variant_has_payload(enum_type_hash, enum_variant_hash) == false {
                                        return -8
                                    }

                                if self.expect_identifier() != 0 {
                                    return -9
                                }
                                payload_binding_hash = self.token_hash
                                if payload_binding_hash == identifier_hash_wildcard() {
                                    has_payload_pattern = false
                                } else {
                                    has_payload_pattern = true
                                }

                                if self.expect_symbol(41) != 0 {
                                    return -10
                                }
                                } else {
                                    self.push_token()
                                }
                            } else {
                                self.push_token()
                            }
                        }
                    }
                } else {
                    return -11
                }
            }
        }

        if has_payload_pattern == true {
            if state.lookup_variable_type(function_hash, payload_binding_hash) == 0 {
                emit_declare_variable(function_hash, payload_binding_hash)
                if state.register_variable_type(function_hash, payload_binding_hash, identifier_hash_i32()) != 0 {
                    return -11
                }
                if register_variable_mode(state, function_hash, payload_binding_hash, 0) != 0 {
                    return -12
                }
            }
            emit_load_variable(function_hash, match_value_hash)
            emits("    sar rax, 32")
            emitc(10)
            emit_store_variable(function_hash, payload_binding_hash)
        }

        kind = self.next_token()
        if kind == token_keyword() {
            if self.token_value == keyword_if() {
                guard_present = true
                if next_label == 0 {
                    next_label = state.allocate_label()
                }
                if self.compile_condition_jump_false(state, function_hash, next_label) != 0 {
                    return -12
                }
            } else {
                self.push_token()
            }
        } else {
            self.push_token()
        }

        if self.expect_symbol(61) != 0 {
            return -12
        }

        if self.expect_symbol(62) != 0 {
            return -13
        }

        if self.expect_symbol(123) != 0 {
            return -14
        }

        if self.compile_block_body(state, function_hash) != 0 {
            return -15
        }
        parent_depth = state.current_block_depth
        arm_return = false
        if get_block_return_guaranteed(state, parent_depth + 1) == 1 {
            arm_return = true
        }
        if arm_return == false {
            match_all_return = false
        }

        emit_jump(end_label)

        if is_default_arm == false {
            emit_internal_label(next_label)
        } else {
            if guard_present == true {
                emit_internal_label(next_label)
            } else {
                has_default_arm = true
            }
        }
    }

    emit_internal_label(end_label)
    if match_enum_type > 0 {
        if match_enum_count == 1 {
            if match_enum_seen_1 != 0 { match_enum_exhaustive = 1 }
        } else {
            if match_enum_count == 2 {
                if match_enum_seen_1 != 0 {
                    if match_enum_seen_2 != 0 {
                        match_enum_exhaustive = 1
                    }
                }
            } else {
                if match_enum_count == 3 {
                    if match_enum_seen_1 != 0 {
                        if match_enum_seen_2 != 0 {
                            if match_enum_seen_3 != 0 {
                                match_enum_exhaustive = 1
                            }
                        }
                    }
                } else {
                    if match_enum_count == 4 {
                        if match_enum_seen_1 != 0 {
                            if match_enum_seen_2 != 0 {
                                if match_enum_seen_3 != 0 {
                                    if match_enum_seen_4 != 0 {
                                        match_enum_exhaustive = 1
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    state.missing_enum_active = 0
    state.missing_enum_hash_1 = 0
    state.missing_enum_hash_2 = 0
    state.missing_enum_hash_3 = 0
    state.missing_enum_hash_4 = 0
    if match_all_return != 0 {
        if has_default_arm == 0 {
            if match_enum_exhaustive == 0 {
                if match_enum_invalid == 0 {
                    if match_enum_type > 0 {
                        state.missing_enum_active = 1
                        if match_enum_count >= 1 {
                            if match_enum_seen_1 == 0 { state.missing_enum_hash_1 = state.type_field_hash(match_enum_type, 0) }
                        }
                        if match_enum_count >= 2 {
                            if match_enum_seen_2 == 0 { state.missing_enum_hash_2 = state.type_field_hash(match_enum_type, 1) }
                        }
                        if match_enum_count >= 3 {
                            if match_enum_seen_3 == 0 { state.missing_enum_hash_3 = state.type_field_hash(match_enum_type, 2) }
                        }
                        if match_enum_count >= 4 {
                            if match_enum_seen_4 == 0 { state.missing_enum_hash_4 = state.type_field_hash(match_enum_type, 3) }
                        }
                    }
                }
            }
        }
    }
    if has_default_arm != 0 {
        if match_all_return != 0 {
            statement_returns = 1
        }
    } else {
        if match_enum_exhaustive != 0 {
            if match_all_return != 0 {
                statement_returns = 1
            }
        }
    }
    if statement_returns != 0 {
            if parent_depth > 0 {
                set_block_return_guaranteed(state, parent_depth, 1)
            }
            if is_top_level != 0 {
                state.current_return_guaranteed = 1
            }
            state.last_statement_return_guaranteed = 1
    } else {
        state.last_statement_return_guaranteed = 0
    }
    return 0
}

function compile_match_expression_into_variable(self: Lexer, state: CompileState, function_hash: i32, target_hash: i32) -> i32 {
    variable prev_active: i32 = state.match_expr_active
    variable result: i32 = 0

    state.match_expr_active = prev_active + 1
    result = self.compile_match_expression_into_variable_outer(state, function_hash, target_hash)
    state.match_expr_active = prev_active
    return result
}

function compile_match_expression_into_variable_outer(self: Lexer, state: CompileState, function_hash: i32, target_hash: i32) -> i32 {
