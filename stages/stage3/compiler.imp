}

function scan_string(self: Lexer) -> i32 {
    variable length: i32 = 0

    loop {
        variable ch: i32 = self.next_char()
        variable escaped: i32 = 0

        if ch == 0 {
            break
        }

        if ch == 10 {
            break
        }

        if ch == 34 {
            break
        }

        if ch == 92 {
            ch = self.next_char()
            if ch == 0 {
                break
            }

            if ch == 10 {
                break
            }

            if ch == 110 {
                ch = 10
                escaped = 1
            } else {
                if ch == 116 {
                    ch = 9
                    escaped = 1
                } else {
                    if ch == 114 {
                        ch = 13
                        escaped = 1
                    } else {
                        if ch == 34 {
                            escaped = 1
                        } else {
                            if ch == 92 {
                                escaped = 1
                            }
                        }
                    }
                }
            }

            if escaped == 0 {
                if length < 16 {
                    self.set_string_char(length, 92)
                }

                length += 1
            }
        }

        if length < 16 {
            self.set_string_char(length, ch)
        }

        length += 1
    }

    self.token_kind = token_string()
    self.token_value = 0
    if length > 16 {
        self.token_length = 16
    } else {
        self.token_length = length
    }
    return self.token_kind
}


function read_token(self: Lexer) -> i32 {
    self.skip_whitespace()
    self.reset_token()

    variable ch: i32 = self.next_char()

    if ch == 0 {
        return self.token_kind
    }

    if is_alpha(ch) == true {
        return self.scan_identifier(ch)
    }

    if is_digit(ch) == true {
        return self.scan_number(ch)
    }

    if ch == 34 {
        return self.scan_string()
    }

    self.token_kind = token_symbol()
    self.token_value = ch
    self.token_length = 1
    return self.token_kind
}

function push_token(self: Lexer) {
    self.pushed_kind = self.token_kind
    self.pushed_value = self.token_value
    self.pushed_hash = self.token_hash
    self.pushed_line = self.token_line
    self.pushed_length = self.token_length
    self.has_pushed = true
}

function next_token(self: Lexer) -> i32 {
    if self.has_pushed == true {
        self.token_kind = self.pushed_kind
        self.token_value = self.pushed_value
        self.token_hash = self.pushed_hash
        self.token_line = self.pushed_line
        self.token_length = self.pushed_length
        self.has_pushed = false
        return self.token_kind
    }

    return self.read_token()
}


function identifier_hash_print() -> i32 => 33242089957
function identifier_hash_len() -> i32 => 1866729

function emit_type_name(hash: i32) {
    variable emitted: bool = false

    if hash == identifier_hash_i32() {
        emits("i32")
        emitted = true
    }

    if emitted == false {
        if hash == identifier_hash_bool() {
            emits("bool")
            emitted = true
        }
    }

    if emitted == false {
        if hash == identifier_hash_str() {
            emits("str")
            emitted = true
        }
    }

    if emitted == false {
        if hash == identifier_hash_array_i32() {
            emits("array_i32")
            emitted = true
        }
    }

    if emitted == false {
        emits("unknown")
    }
}

function emit_enum_variant_name(hash: i32) {
    variable emitted: bool = false

    if hash >= 0 {
        if hash < 128 {
            emitc(hash)
            emitted = true
        }
    }

    if emitted == false {
        emits("unknown")
    }
}

function emit_return_type_mismatch(expected_hash: i32, actual_hash: i32, line: i32, function_hash: i32) {
    emits("type error")
    emitc(10)
    emits("line: ")
    emiti(line)
    emitc(10)
    emits("function: ")
    emit_function_name(function_hash)
    emitc(10)
    emits("return type mismatch")
    emitc(10)
    emits("expected: ")
    emit_type_name(expected_hash)
    emitc(10)
    emits("got: ")
    emit_type_name(actual_hash)
    emitc(10)
}

function emit_missing_return(expected_hash: i32, line: i32, function_hash: i32) {
    emits("type error")
    emitc(10)
    emits("line: ")
    emiti(line)
    emitc(10)
    emits("function: ")
    emit_function_name(function_hash)
    emitc(10)
    emits("missing return")
    emitc(10)
    emits("expected: ")
    emit_type_name(expected_hash)
    emitc(10)
}

function emit_hash_suffix(hash: i32) {
    if hash < 0 {
        emits("N_")
        emiti(0 - hash)
    } else {
        emits("P_")
        emiti(hash)
    }
}

function emit_function_name(hash: i32) {
    if hash == identifier_hash_main() {
        emits("main")
    } else {
        emits("FN_")
        emit_hash_suffix(hash)
    }
}

function emit_variable_name(function_hash: i32, variable_hash: i32) {
    emits("V_")
    emit_hash_suffix(function_hash)
    emitc(95)
    emit_hash_suffix(variable_hash)
}

function emit_variable_length_name(function_hash: i32, variable_hash: i32) {
    emit_variable_name(function_hash, variable_hash)
    emits("_LEN")
}

function emit_internal_label_name(label: i32) {
    emits("L_")
    emiti(label)
}

function emit_program_header() {
    emits("BITS 64")
    emitc(10)
    emits("section .text")
    emitc(10)
    emits("global _start")
    emitc(10)
    emitc(10)
    emits("_start:")
    emitc(10)
    emits("    call main")
    emitc(10)
    emits("    xor rdi, rdi")
    emitc(10)
    emits("    mov rax, 60")
    emitc(10)
    emits("    syscall")
    emitc(10)
    emitc(10)
}

function emit_program_footer() {
    emits("print_rax:")
    emitc(10)
    emits("    push rbx")
    emitc(10)
    emits("    push rcx")
    emitc(10)
    emits("    push rdx")
    emitc(10)
    emits("    push rsi")
    emitc(10)
    emits("    push rdi")
    emitc(10)
    emits("    lea rdi, [print_buf + 31]")
    emitc(10)
    emits("    mov byte [rdi], 10")
    emitc(10)
    emits("    mov rcx, 10")
    emitc(10)
    emits("    test rax, rax")
    emitc(10)
    emits("    jnz .print_loop")
    emitc(10)
    emits("    dec rdi")
    emitc(10)
    emits("    mov byte [rdi], '0'")
    emitc(10)
    emits("    jmp .print_emit")
    emitc(10)
    emits(".print_loop:")
    emitc(10)
    emits("    xor rdx, rdx")
    emitc(10)
    emits("    div rcx")
    emitc(10)
    emits("    add dl, '0'")
    emitc(10)
    emits("    dec rdi")
    emitc(10)
    emits("    mov [rdi], dl")
    emitc(10)
    emits("    test rax, rax")
    emitc(10)
    emits("    jnz .print_loop")
    emitc(10)
    emits(".print_emit:")
    emitc(10)
    emits("    mov rsi, rdi")
    emitc(10)
    emits("    lea rbx, [print_buf + 32]")
    emitc(10)
    emits("    sub rbx, rsi")
    emitc(10)
    emits("    mov rdx, rbx")
    emitc(10)
    emits("    mov rax, 1")
    emitc(10)
    emits("    mov rdi, 1")
    emitc(10)
    emits("    syscall")
    emitc(10)
    emits("    pop rdi")
    emitc(10)
    emits("    pop rsi")
    emitc(10)
    emits("    pop rdx")
    emitc(10)
    emits("    pop rcx")
    emitc(10)
    emits("    pop rbx")
    emitc(10)
    emits("    ret")
    emitc(10)
    emitc(10)
    emits("print_cstr_rax:")
    emitc(10)
    emits("    push rbx")
    emitc(10)
    emits("    push rcx")
    emitc(10)
    emits("    push rdx")
    emitc(10)
    emits("    push rsi")
    emitc(10)
    emits("    push rdi")
    emitc(10)
    emits("    mov rsi, rax")
    emitc(10)
    emits("    xor rdx, rdx")
    emitc(10)
    emits(".print_cstr_len:")
    emitc(10)
    emits("    cmp byte [rsi + rdx], 0")
    emitc(10)
    emits("    je .print_cstr_emit")
    emitc(10)
    emits("    inc rdx")
    emitc(10)
    emits("    jmp .print_cstr_len")
    emitc(10)
    emits(".print_cstr_emit:")
    emitc(10)
    emits("    mov rax, 1")
    emitc(10)
    emits("    mov rdi, 1")
    emitc(10)
    emits("    syscall")
    emitc(10)
    emits("    mov byte [print_buf], 10")
    emitc(10)
    emits("    mov rax, 1")
    emitc(10)
    emits("    mov rdi, 1")
    emitc(10)
    emits("    lea rsi, [print_buf]")
    emitc(10)
    emits("    mov rdx, 1")
    emitc(10)
    emits("    syscall")
    emitc(10)
    emits("    pop rdi")
    emitc(10)
    emits("    pop rsi")
    emitc(10)
    emits("    pop rdx")
    emitc(10)
    emits("    pop rcx")
    emitc(10)
    emits("    pop rbx")
    emitc(10)
    emits("    ret")
    emitc(10)
    emitc(10)
    emits("section .bss")
    emitc(10)
    emits("print_buf: resb 32")
    emitc(10)
}


function expect_keyword(self: Lexer, keyword: i32) -> i32 {
    if self.next_token() != token_keyword() {
        return 1
    }

    if self.token_value != keyword {
        return 2
    }

    return 0
}

function expect_identifier(self: Lexer) -> i32 {
    if self.next_token() != token_identifier() {
        return 1
    }

    return 0
}

function expect_named_identifier(self: Lexer, expected_hash: i32) -> i32 {
    if self.expect_identifier() != 0 {
        return 1
    }

    if self.token_hash != expected_hash {
        return 2
    }

    return 0
}

function expect_symbol(self: Lexer, code: i32) -> i32 {
    if self.next_token() != token_symbol() {
        return 1
    }

    if self.token_value != code {
        return 2
    }

    return 0
}

function expect_number(self: Lexer, expected_value: i32) -> i32 {
    if self.next_token() != token_number() {
        return 1
    }

    if self.token_value != expected_value {
        return 2
    }

    return 0
}

function parse_struct_literal_tail(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_symbol() {
        return -1
    }

    if self.token_value == 125 {
        return 0
    }

    self.push_token()

    loop {
        if self.expect_identifier() != 0 {
            return -2
        }

        if self.expect_symbol(58) != 0 {
            return -3
        }

        if self.parse_expression() != 0 {
            return -4
        }

        kind = self.next_token()
        if kind != token_symbol() {
            return -5
        }

        if self.token_value == 125 {
            return 0
        }

        if self.token_value != 44 {
            return -6
        }
    }
    return 0
}

function parse_postfix_tail(self: Lexer) -> i32 {
    variable kind: i32 = 0

    loop {
        kind = self.next_token()

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value == 40 {
            if self.parse_argument_list_tail() != 0 {
                return -1
            }
        } else {
            if self.token_value == 91 {
                if self.parse_expression() != 0 {
                    return -4
                }

                if self.expect_symbol(93) != 0 {
                    return -5
                }
            } else {
                if self.token_value == 46 {
                    if self.expect_identifier() != 0 {
                        return -2
                    }
                } else {
                    if self.token_value == 123 {
                        if self.parse_struct_literal_tail() != 0 {
                            return -3
                        }
                    } else {
                        self.push_token()
                        return 0
                    }
                }
            }
        }
    }
    return 0
}

function parse_factor(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind == token_number() {
        return 0
    }

    if kind == token_string() {
        return 0
    }

    if kind == token_keyword() {
        if self.token_value == keyword_true() {
            return 0
        }

        if self.token_value == keyword_false() {
            return 0
        }

        if self.token_value == keyword_await() {
            return self.parse_factor()
        }
    }

    if kind == token_symbol() {
        if self.token_value == 45 {
            if self.parse_factor() != 0 {
                return -4
            }

            return 0
        }

        if self.token_value != 40 {
            return -1
        }

        if self.parse_expression() != 0 {
            return -2
        }

        if self.expect_symbol(41) != 0 {
            return -3
        }

        return 0
    }

    if kind == token_identifier() {
        return self.parse_postfix_tail()
    }

    return -1
}

function parse_term(self: Lexer) -> i32 {
    if self.parse_factor() != 0 {
        return -1
    }

    loop {
        variable kind: i32 = self.next_token()

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value != 42 {
            self.push_token()
            return 0
        }

        if self.parse_factor() != 0 {
            return -2
        }
    }
    return 0
}

function parse_expression(self: Lexer) -> i32 {
    if self.parse_term() != 0 {
        return -1
    }

    loop {
        variable kind: i32 = self.next_token()

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value != 43 {
            if self.token_value != 45 {
                self.push_token()
                return 0
            }
        }

        if self.parse_term() != 0 {
            return -2
        }
    }
    return 0
}

function parse_argument_list_tail(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_symbol() {
        return -1
    }

    if self.token_value == 41 {
        return 0
    }

    self.push_token()

    loop {
        if self.parse_expression() != 0 {
            return -2
        }

        kind = self.next_token()
        if kind != token_symbol() {
            return -3
        }

        if self.token_value == 41 {
            return 0
        }

        if self.token_value != 44 {
            return -4
        }
    }
    return 0
}

function parse_return_tail(self: Lexer) -> i32 {
    if self.parse_expression() != 0 {
        return -1
    }

    return 0
}

function parse_throw_tail(self: Lexer) -> i32 {
    if self.parse_expression() != 0 {
        return -1
    }

    return 0
}

function parse_condition(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.parse_expression() != 0 {
        return -1
    }

    kind = self.next_token()
    if kind != token_symbol() {
        return -2
    }

    if self.token_value == 60 {
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value != 61 {
                self.push_token()
            }
        } else {
            self.push_token()
        }
    } else {
        if self.token_value == 62 {
            kind = self.next_token()
            if kind == token_symbol() {
                if self.token_value != 61 {
                    self.push_token()
                }
            } else {
                self.push_token()
            }
        } else {
            if self.token_value == 61 {
                if self.expect_symbol(61) != 0 {
                    return -3
                }
            } else {
                if self.token_value == 33 {
                    if self.expect_symbol(61) != 0 {
                        return -4
                    }
                } else {
                    return -6
                }
            }
        }
    }

    if self.parse_expression() != 0 {
        return -5
    }

    return 0
}

function parse_type_argument_list_tail(self: Lexer) -> i32 {
    loop {
        if self.parse_type_name() != 0 {
            return -1
        }

        variable kind: i32 = self.next_token()
        if kind != token_symbol() {
            return -2
        }

        if self.token_value == 93 {
            return 0
        }

        if self.token_value != 44 {
            return -3
        }
    }
    return 0
}

function parse_type_name(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.expect_identifier() != 0 {
        return -1
    }

    loop {
        kind = self.next_token()

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value == 46 {
            if self.expect_identifier() != 0 {
                return -2
            }

            continue
        }

        if self.token_value == 91 {
            if self.parse_type_argument_list_tail() != 0 {
                return -3
            }

            continue
        }

        self.push_token()
        return 0
    }
    return 0
}

function parse_parameter(self: Lexer) -> i32 {
    if self.expect_identifier() != 0 {
        return -1
    }

    if self.expect_symbol(58) != 0 {
        return -2
    }

    if self.parse_type_name() != 0 {
        return -3
    }

    return 0
}

function parse_parameter_list(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_symbol() {
        return -1
    }

    if self.token_value == 41 {
        return 0
    }

    self.push_token()

    loop {
        if self.parse_parameter() != 0 {
            return -2
        }

        kind = self.next_token()
        if kind != token_symbol() {
            return -3
        }

        if self.token_value == 41 {
            return 0
        }

        if self.token_value != 44 {
            return -4
        }
    }
    return 0
}

function parse_optional_generic_parameters(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_symbol() {
        self.push_token()
        return 0
    }

    if self.token_value != 91 {
        self.push_token()
        return 0
    }

    loop {
        if self.expect_identifier() != 0 {
            return -1
        }

        kind = self.next_token()
        if kind != token_symbol() {
            return -2
        }

        if self.token_value == 93 {
            return 0
        }

        if self.token_value != 44 {
            return -3
        }
    }
    return 0
}

function parse_optional_return_type(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_symbol() {
        self.push_token()
        return 0
    }

    if self.token_value != 45 {
        self.push_token()
        return 0
    }

    if self.expect_symbol(62) != 0 {
        return -1
    }

    if self.parse_type_name() != 0 {
        return -2
    }

    return 0
}

function parse_skip_signature_clause(self: Lexer) -> i32 {
    variable paren_depth: i32 = 0
    variable bracket_depth: i32 = 0
    variable kind: i32 = 0

    loop {
        kind = self.next_token()

        if kind == token_end() {
            return -1
        }

        if kind == token_symbol() {
            if self.token_value == 40 {
                paren_depth += 1
                continue
            }

            if self.token_value == 41 {
                if paren_depth > 0 {
                    paren_depth -= 1
                    continue
                }
            }

            if self.token_value == 91 {
                bracket_depth += 1
                continue
            }

            if self.token_value == 93 {
                if bracket_depth > 0 {
                    bracket_depth -= 1
                    continue
                }
            }

            if paren_depth == 0 {
                if bracket_depth == 0 {
                    if self.token_value == 123 {
                        self.push_token()
                        return 0
                    }

                    if self.token_value == 61 {
                        self.push_token()
                        return 0
                    }
                }
            }
        }

        if kind == token_keyword() {
            if paren_depth == 0 {
                if bracket_depth == 0 {
                    if self.token_value == keyword_where() {
                        self.push_token()
                        return 0
                    }

                    if self.token_value == keyword_requires() {
                        self.push_token()
                        return 0
                    }

                    if self.token_value == keyword_ensures() {
                        self.push_token()
                        return 0
                    }
                }
            }
        }
    }
    return 0
}

function parse_optional_where_clause(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind != token_keyword() {
        self.push_token()
        return 0
    }

    if self.token_value != keyword_where() {
        self.push_token()
        return 0
    }

    return self.parse_skip_signature_clause()
}

function parse_optional_contracts(self: Lexer) -> i32 {
    variable kind: i32 = 0

    loop {
        kind = self.next_token()

        if kind != token_keyword() {
            self.push_token()
            return 0
        }

        if self.token_value == keyword_requires() {
            if self.parse_skip_signature_clause() != 0 {
                return -1
            }
        } else {
            if self.token_value == keyword_ensures() {
                if self.parse_skip_signature_clause() != 0 {
                    return -2
                }
            } else {
                self.push_token()
                return 0
            }
        }
    }
    return 0
}

function parse_expression_body(self: Lexer) -> i32 {
    if self.expect_symbol(62) != 0 {
        return -1
    }

    if self.parse_expression() != 0 {
        return -2
    }

    return 0
}

function parse_binding_tail(self: Lexer) -> i32 {
    if self.expect_identifier() != 0 {
        return -1
    }

    if self.expect_symbol(58) != 0 {
        return -2
    }

    if self.parse_type_name() != 0 {
        return -3
    }

    if self.expect_symbol(61) != 0 {
        return -4
    }

    if self.parse_expression() != 0 {
        return -5
    }

    return 0
}

function parse_identifier_statement_tail(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    loop {
        if kind != token_symbol() {
            return -1
        }

        if self.token_value != 46 {
            break
        }

        if self.expect_identifier() != 0 {
            return -4
        }

        kind = self.next_token()
    }

    if kind != token_symbol() {
        return -1
    }

    if self.token_value == 61 {
        if self.parse_expression() != 0 {
            return -2
        }

        return 0
    }

    if self.token_value == 40 {
        return self.parse_argument_list_tail()
    }

    return -3
}

function parse_if_tail(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.parse_condition() != 0 {
        return -1
    }

    if self.expect_symbol(123) != 0 {
        return -2
    }

    if self.parse_block_body() != 0 {
        return -3
    }

    kind = self.next_token()
    if kind != token_keyword() {
        self.push_token()
        return 0
    }

    if self.token_value != keyword_else() {
        self.push_token()
        return 0
    }

    if self.expect_symbol(123) != 0 {
        return -4
    }

    if self.parse_block_body() != 0 {
        return -5
    }

    return 0
}

function parse_while_tail(self: Lexer) -> i32 {
    if self.parse_condition() != 0 {
        return -1
    }

    if self.expect_symbol(123) != 0 {
