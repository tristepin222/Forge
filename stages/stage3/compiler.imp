struct SourceCursor {
    index: i32
    line: i32
}

struct ParserState {
    phase: i32
    current: i32
}

struct Lexer {
    index: i32
    line: i32
    peeked_char: i32
    has_peeked: i32
    token_kind: i32
    token_value: i32
    token_hash: i32
    token_line: i32
    token_length: i32
    string_char_0: i32
    string_char_1: i32
    string_char_2: i32
    string_char_3: i32
    string_char_4: i32
    string_char_5: i32
    string_char_6: i32
    string_char_7: i32
    string_char_8: i32
    string_char_9: i32
    string_char_10: i32
    string_char_11: i32
    string_char_12: i32
    string_char_13: i32
    string_char_14: i32
    string_char_15: i32
    pushed_kind: i32
    pushed_value: i32
    pushed_hash: i32
    pushed_line: i32
    pushed_length: i32
    has_pushed: i32
}


function hash_step(hash: i32, ch: i32) -> i32 => hash * 131 + ch


function is_space(code: i32) -> bool {
    if code == 32 {
        return true
    }

    if code == 10 {
        return true
    }

    if code == 9 {
        return true
    }

    return false
}


function is_digit(code: i32) -> bool {
    if code < 48 {
        return false
    }

    if code > 57 {
        return false
    }

    return true
}


function is_alpha(code: i32) -> bool {
    if code == 95 {
        return true
    }

    if code < 65 {
        return false
    }

    if code <= 90 {
        return true
    }

    if code < 97 {
        return false
    }

    if code <= 122 {
        return true
    }

    return false
}

function is_ident_continue(code: i32) -> bool {
    if is_alpha(code) == true {
        return true
    }

    return is_digit(code)
}


function peek_char(self: Lexer) -> i32 {
    if self.has_peeked == false {
        self.peeked_char = __read_char
        self.has_peeked = true
    }

    return self.peeked_char
}

function next_char(self: Lexer) -> i32 {
    variable ch: i32 = self.peek_char()

    self.has_peeked = false

    if ch != 0 {
        self.index += 1
    }

    if ch == 10 {
        self.line += 1
    }

    return ch
}

function reset_token(self: Lexer) {
    self.token_kind = token_end()
    self.token_value = 0
    self.token_hash = 0
    self.token_line = self.line
    self.token_length = 0
}

function skip_whitespace(self: Lexer) {
    loop {
        variable ch: i32 = self.peek_char()

        if is_space(ch) == false {
            break
        }

        self.next_char()
    }
}


function scan_identifier(self: Lexer, first: i32) -> i32 {
    variable hash: i32 = 0
    variable length: i32 = 0
    variable ch: i32 = first

    hash = hash_step(hash, ch)
    length += 1

    loop {
        variable peek: i32 = self.peek_char()

        if is_ident_continue(peek) == false {
            break
        }

        ch = self.next_char()
        hash = hash_step(hash, ch)
        length += 1
    }

    self.token_kind = token_identifier()
    self.token_hash = hash
    self.token_length = length

    if length == 8 {
        if hash == keyword_hash_function() {
            self.token_kind = token_keyword()
            self.token_value = keyword_function()
            return self.token_kind
        }
    }

    if length == 6 {
        if hash == keyword_hash_return() {
            self.token_kind = token_keyword()
            self.token_value = keyword_return()
            return self.token_kind
        }

        if hash == keyword_hash_module() {
            self.token_kind = token_keyword()
