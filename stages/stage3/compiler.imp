            next_label = state.allocate_label()
            emit_load_variable(function_hash, match_value_hash)
            emit_push_rax()
            emit_load_number(pattern_value)
            emit_pop_rbx()
            emits("    cmp rbx, rax")
            emitc(10)
            emits("    jne ")
            emit_internal_label_name(next_label)
            emitc(10)
