    }
    if index == 14 {
        self.string_char_14 = ch
        return 0
    }
    if index == 15 {
        self.string_char_15 = ch
        return 0
    }

    return -1
}

function string_char_at(self: Lexer, index: i32) -> i32 {
    if index == 0 {
        return self.string_char_0
    }
    if index == 1 {
        return self.string_char_1
    }
    if index == 2 {
        return self.string_char_2
    }
    if index == 3 {
        return self.string_char_3
    }
    if index == 4 {
        return self.string_char_4
    }
    if index == 5 {
