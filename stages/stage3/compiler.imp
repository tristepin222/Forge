                            }
                        }
                    }
                }
            }
        }
    }

    if has_default_arm == 0 {
        if match_enum_exhaustive == 0 {
            return -18
        }
    }

    if match_expr_type_set != 0 {
        state.last_expression_type_hash = match_expr_type_hash
    } else {
        state.last_expression_type_hash = 0
    }

    return 0
}

function compile_match_expression_into_variable_nested(self: Lexer, state: CompileState, function_hash: i32, target_hash: i32) -> i32 {
    variable match_value_hash: i32 = 900000000 + state.allocate_label()
    variable end_label: i32 = state.allocate_label()
    variable kind: i32 = 0
    variable next_label: i32 = 0
    variable pattern_value: i32 = 0
    variable is_default_arm: bool = false
    variable enum_type_hash: i32 = 0
    variable enum_variant_hash: i32 = 0
    variable payload_binding_hash: i32 = 0
    variable has_payload_pattern: bool = false
    variable guard_present: bool = false
    variable has_default_arm: bool = false
    variable match_enum_type: i32 = 0
    variable match_enum_count: i32 = 0
    variable match_enum_seen_1: i32 = 0
    variable match_enum_seen_2: i32 = 0
    variable match_enum_seen_3: i32 = 0
    variable match_enum_seen_4: i32 = 0
    variable match_enum_invalid: i32 = 0
    variable match_enum_exhaustive: i32 = 0
    variable match_expr_type_hash: i32 = 0
    variable match_expr_type_set: bool = false

    if self.compile_expression(state, function_hash) != 0 {
        return -1
    }

    emit_declare_variable(function_hash, match_value_hash)
    emit_store_variable(function_hash, match_value_hash)

    if self.expect_symbol(123) != 0 {
        return -2
    }

    loop {
        kind = self.next_token()
        has_payload_pattern = false
        guard_present = false
        next_label = 0

        if kind == token_symbol() {
            if self.token_value == 125 {
                break
            }
        }

        is_default_arm = false

        if kind == token_number() {
            pattern_value = self.token_value
            match_enum_invalid = 1
            if match_enum_type > 0 { match_enum_type = -1 }
            next_label = state.allocate_label()
            emit_load_variable(function_hash, match_value_hash)
            emit_push_rax()
            emit_load_number(pattern_value)
            emit_pop_rbx()
            emits("    cmp rbx, rax")
            emitc(10)
            emits("    jne ")
            emit_internal_label_name(next_label)
            emitc(10)
        } else {
            if kind == token_keyword() {
                if self.token_value == keyword_true() {
                    pattern_value = 1
                    match_enum_invalid = 1
                    if match_enum_type > 0 { match_enum_type = -1 }
                    next_label = state.allocate_label()
                    emit_load_variable(function_hash, match_value_hash)
                    emit_push_rax()
                    emit_load_number(pattern_value)
                    emit_pop_rbx()
                    emits("    cmp rbx, rax")
                    emitc(10)
                    emits("    jne ")
                    emit_internal_label_name(next_label)
                    emitc(10)
                } else {
                    if self.token_value == keyword_false() {
                        pattern_value = 0
                        match_enum_invalid = 1
                        if match_enum_type > 0 { match_enum_type = -1 }
                        next_label = state.allocate_label()
                        emit_load_variable(function_hash, match_value_hash)
                        emit_push_rax()
                        emit_load_number(pattern_value)
                        emit_pop_rbx()
                        emits("    cmp rbx, rax")
                        emitc(10)
                        emits("    jne ")
                        emit_internal_label_name(next_label)
                        emitc(10)
                    } else {
                        if self.token_value == keyword_default() {
                            is_default_arm = true
                        } else {
                            return -3
                        }
                    }
                }
            } else {
                if kind == token_identifier() {
                    if self.token_hash == identifier_hash_wildcard() {
                        is_default_arm = true
                    } else {
                        enum_type_hash = self.token_hash

                        if self.expect_symbol(58) != 0 {
                            return -4
                        }

                        if self.expect_symbol(58) != 0 {
                            return -5
                        }

                        if self.expect_identifier() != 0 {
                            return -6
                        }
                        enum_variant_hash = self.token_hash

                        if enum_variant_hash == identifier_hash_wildcard() {
                            is_default_arm = true
                            if match_enum_invalid != 0 {
                                match_enum_type = -1
                            } else {
                                if match_enum_type == 0 {
                                    match_enum_type = enum_type_hash
                                    match_enum_count = state.type_field_count(enum_type_hash)
                                } else {
                                    if match_enum_type != enum_type_hash {
                                        match_enum_type = -1
                                    }
                                }
                            }
                        } else {
                            pattern_value = state.enum_variant_tag(enum_type_hash, enum_variant_hash)
                            if pattern_value < 0 {
                                return -7
                            }
                            if match_enum_invalid != 0 {
                                match_enum_type = -1
                            } else {
                                if match_enum_type == 0 {
                                    match_enum_type = enum_type_hash
                                    match_enum_count = state.type_field_count(enum_type_hash)
                                } else {
                                    if match_enum_type != enum_type_hash {
                                        match_enum_type = -1
                                    }
                                }
                            }
                            if match_enum_type > 0 {
                                if pattern_value == 1 { match_enum_seen_1 = 1 }
                                if pattern_value == 2 { match_enum_seen_2 = 1 }
                                if pattern_value == 3 { match_enum_seen_3 = 1 }
                                if pattern_value == 4 { match_enum_seen_4 = 1 }
                            }

                            next_label = state.allocate_label()
                            emit_compare_enum_tag_jump_false(match_value_hash, pattern_value, next_label, function_hash)

                            kind = self.next_token()
                            if kind == token_symbol() {
                                if self.token_value == 40 {
                                    if state.enum_variant_has_payload(enum_type_hash, enum_variant_hash) == false {
                                        return -8
                                    }

                                    if self.expect_identifier() != 0 {
                                        return -9
                                    }
                                    payload_binding_hash = self.token_hash
                                    if payload_binding_hash == identifier_hash_wildcard() {
                                        has_payload_pattern = false
                                    } else {
                                        has_payload_pattern = true
                                    }

                                    if self.expect_symbol(41) != 0 {
                                        return -10
                                    }
                                } else {
                                    self.push_token()
                                }
                            } else {
                                self.push_token()
                            }
                        }
                    }
                } else {
                    return -11
                }
            }
        }

        if has_payload_pattern == true {
            if state.lookup_variable_type(function_hash, payload_binding_hash) == 0 {
                emit_declare_variable(function_hash, payload_binding_hash)
                if state.register_variable_type(function_hash, payload_binding_hash, identifier_hash_i32()) != 0 {
                    return -11
                }
                if register_variable_mode(state, function_hash, payload_binding_hash, 0) != 0 {
                    return -12
                }
            }
            emit_load_variable(function_hash, match_value_hash)
            emits("    sar rax, 32")
            emitc(10)
            emit_store_variable(function_hash, payload_binding_hash)
        }

        kind = self.next_token()
        if kind == token_keyword() {
            if self.token_value == keyword_if() {
                guard_present = true
                if next_label == 0 {
                    next_label = state.allocate_label()
                }
                if self.compile_condition_jump_false(state, function_hash, next_label) != 0 {
                    return -12
                }
            } else {
                self.push_token()
            }
        } else {
            self.push_token()
        }

        if self.expect_symbol(61) != 0 {
            return -13
        }

        if self.expect_symbol(62) != 0 {
            return -14
        }

        if self.compile_expression(state, function_hash) != 0 {
            return -15
        }

        if match_expr_type_set == false {
            if state.last_expression_type_hash > 0 {
                match_expr_type_hash = state.last_expression_type_hash
                match_expr_type_set = true
            }
        } else {
            if state.last_expression_type_hash > 0 {
                if state.last_expression_type_hash != match_expr_type_hash {
                    return -16
                }
            }
        }

        emit_store_variable(function_hash, target_hash)
        emit_jump(end_label)

        if is_default_arm == false {
            emit_internal_label(next_label)
        } else {
            if guard_present == true {
                emit_internal_label(next_label)
            } else {
                has_default_arm = true
            }
        }

        if self.expect_symbol(44) != 0 {
            return -17
        }
    }

    emit_internal_label(end_label)
    if match_enum_type > 0 {
        if match_enum_count == 1 {
            if match_enum_seen_1 != 0 { match_enum_exhaustive = 1 }
        } else {
            if match_enum_count == 2 {
                if match_enum_seen_1 != 0 {
                    if match_enum_seen_2 != 0 {
                        match_enum_exhaustive = 1
                    }
                }
            } else {
                if match_enum_count == 3 {
                    if match_enum_seen_1 != 0 {
                        if match_enum_seen_2 != 0 {
                            if match_enum_seen_3 != 0 {
                                match_enum_exhaustive = 1
                            }
                        }
                    }
                } else {
                    if match_enum_count == 4 {
                        if match_enum_seen_1 != 0 {
                            if match_enum_seen_2 != 0 {
                                if match_enum_seen_3 != 0 {
                                    if match_enum_seen_4 != 0 {
                                        match_enum_exhaustive = 1
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if has_default_arm == 0 {
        if match_enum_exhaustive == 0 {
            return -18
        }
    }

    if match_expr_type_set != 0 {
        state.last_expression_type_hash = match_expr_type_hash
    } else {
        state.last_expression_type_hash = 0
    }

    return 0
}

function compile_match_expression(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable temp_hash: i32 = 900000000 + state.allocate_label()

    emit_declare_variable(function_hash, temp_hash)
    if self.compile_match_expression_into_variable(state, function_hash, temp_hash) != 0 {
        return -1
    }

    emit_load_variable(function_hash, temp_hash)
    return 0
}

function compile_match_expression_nested(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable temp_hash: i32 = 900000000 + state.allocate_label()

    emit_declare_variable(function_hash, temp_hash)
    if self.compile_match_expression_into_variable_nested(state, function_hash, temp_hash) != 0 {
        return -1
    }

    emit_load_variable(function_hash, temp_hash)
    return 0
}

function compile_statement(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    variable kind: i32 = self.next_token()
    state.last_statement_return_guaranteed = 0

    if kind == token_identifier() {
        return self.compile_identifier_statement_tail(state, function_hash, self.token_hash)
    }

    if kind == token_keyword() {
        if self.token_value == keyword_return() {
            variable return_line: i32 = self.token_line
            if self.compile_expression(state, function_hash) != 0 {
                return -1
            }

            if check_return_expression_type(state, return_line) != 0 {
                return -16
            }

            state.current_return_seen += 1
            if state.current_block_depth > 0 {
                set_block_return_guaranteed(state, state.current_block_depth, 1)
            }
            if state.current_block_depth == 1 {
                state.current_return_guaranteed = 1
            }
            state.last_statement_return_guaranteed = 1
            emit_return_rax()
            return 0
        }

        if self.token_value == keyword_value() {
            return self.compile_binding_tail(state, function_hash)
        }

        if self.token_value == keyword_variable() {
            return self.compile_binding_tail(state, function_hash)
        }

        if self.token_value == keyword_constant() {
            return self.compile_binding_tail(state, function_hash)
        }

        if self.token_value == keyword_let() {
            return self.compile_binding_tail(state, function_hash)
        }

        if self.token_value == keyword_var() {
            return self.compile_binding_tail(state, function_hash)
        }

        if self.token_value == keyword_if() {
            return self.compile_if_tail(state, function_hash)
        }

        if self.token_value == keyword_while() {
            return self.compile_while_tail(state, function_hash)
        }

        if self.token_value == keyword_loop() {
            return self.compile_loop_tail(state, function_hash)
        }

        if self.token_value == keyword_match() {
            return self.compile_match_tail(state, function_hash)
        }

        if self.token_value == keyword_for() {
            return self.compile_for_tail(state, function_hash)
        }

        if self.token_value == keyword_break() {
            if state.current_loop_end < 0 {
                return -3
            }

            emit_jump(state.current_loop_end)
            return 0
        }

        if self.token_value == keyword_continue() {
            if state.current_loop_continue < 0 {
                return -4
            }

            emit_jump(state.current_loop_continue)
            return 0
        }
    }

    return -2
}

function compile_block_body(self: Lexer, state: CompileState, function_hash: i32) -> i32 {
    state.current_block_depth += 1
    set_block_return_guaranteed(state, state.current_block_depth, 0)
    loop {
        variable kind: i32 = self.next_token()

        if kind == token_symbol() {
            if self.token_value == 125 {
                state.current_block_depth -= 1
                return 0
            }
        }

        if get_block_return_guaranteed(state, state.current_block_depth) == 1 {
            set_block_return_guaranteed(state, state.current_block_depth, 0)
        }

        self.push_token()

        if self.compile_statement(state, function_hash) != 0 {
            state.current_block_depth -= 1
            return -1
        }
        set_block_return_guaranteed(state, state.current_block_depth, state.last_statement_return_guaranteed)
    }
    return 0
}

function compile_register_field_declaration_tail(self: Lexer, state: CompileState, type_hash: i32) -> i32 {
    variable parsed_type: i32 = 0
    variable field_hash: i32 = 0

    field_hash = self.parse_member_name_hash()
    if field_hash < 0 {
        return -1
    }

    if state.register_type_field(type_hash, field_hash) != 0 {
        return -2
    }

    if self.expect_symbol(58) != 0 {
        return -3
    }

    parsed_type = self.parse_type_name_hash()
    if parsed_type < 0 {
        return -4
    }

    return 0
}

function compile_register_named_field_tail(self: Lexer, state: CompileState, type_hash: i32, field_hash: i32) -> i32 {
    variable parsed_type: i32 = 0

    if state.register_type_field(type_hash, field_hash) != 0 {
        return -1
    }

    if self.expect_symbol(58) != 0 {
        return -2
    }

    parsed_type = self.parse_type_name_hash()
    if parsed_type < 0 {
        return -3
    }

    return 0
}

function compile_function_definition_tail(self: Lexer, state: CompileState, implicit_self_type: i32) -> i32 {
    if self.expect_identifier() != 0 {
        return -1
    }
    variable function_hash: i32 = self.token_hash
    variable kind: i32 = 0
    variable param_index: i32 = 0
    variable parameter_hash: i32 = 0
    variable parameter_type_hash: i32 = 0
    variable parameter_field_count: i32 = 0
    variable return_type_hash: i32 = 0

    emit_function_label(function_hash)

    if self.expect_symbol(40) != 0 {
        return -2
    }

    kind = self.next_token()
    if kind == token_symbol() {
        if self.token_value != 41 {
            return -4
        }
    } else {
        self.push_token()

        loop {
            if self.expect_identifier() != 0 {
                return -3
            }
            parameter_hash = self.token_hash

            kind = self.next_token()
            if kind == token_symbol() {
                if self.token_value == 58 {
                    parameter_type_hash = self.parse_type_name_hash()
                    if parameter_type_hash < 0 {
                        return -5
                    }
                } else {
                    self.push_token()
                    if implicit_self_type == 0 {
                        return -4
                    }
                    if param_index != 0 {
                        return -4
                    }
                    parameter_type_hash = implicit_self_type
                }
            } else {
                self.push_token()
                if implicit_self_type == 0 {
                    return -4
                }
                if param_index != 0 {
                    return -4
                }
                parameter_type_hash = implicit_self_type
            }

            if state.register_variable_type(function_hash, parameter_hash, parameter_type_hash) != 0 {
                return -6
            }

            if parameter_type_hash == identifier_hash_array_i32() {
                if register_variable_mode(state, function_hash, parameter_hash, 1) != 0 {
                    return -6
                }
            }

            emit_declare_variable(function_hash, parameter_hash)
            if parameter_type_hash == identifier_hash_array_i32() {
                emit_declare_array_length_variable(function_hash, parameter_hash)
            }
            parameter_field_count = state.type_field_count(parameter_type_hash)
            if parameter_field_count > 0 {
                emit_declare_struct_storage(function_hash, parameter_hash, parameter_field_count)
            }
            if emit_store_argument_variable(function_hash, parameter_hash, param_index) != 0 {
                return -7
            }
            if parameter_type_hash == identifier_hash_array_i32() {
                if emit_store_argument_array_length(function_hash, parameter_hash, param_index + 1) != 0 {
                    return -7
                }
                param_index += 2
            } else {
                param_index += 1
            }

            kind = self.next_token()
            if kind != token_symbol() {
                return -8
            }

            if self.token_value == 41 {
                break
            }

            if self.token_value != 44 {
                return -9
            }
        }
    }

    return_type_hash = self.parse_optional_return_type_hash()
    if return_type_hash < 0 {
        return -10
    }
    if register_function_return_type(state, function_hash, return_type_hash) != 0 {
        return -17
    }
    state.current_func_hash = function_hash
    state.missing_enum_active = 0
    state.missing_enum_hash_1 = 0
    state.missing_enum_hash_2 = 0
    state.missing_enum_hash_3 = 0
    state.missing_enum_hash_4 = 0
    state.current_return_type_hash = return_type_hash
    state.current_return_seen = 0
    state.current_return_guaranteed = 0
    state.current_block_depth = 0

    kind = self.next_token()
    if kind != token_symbol() {
        return -11
    }

    if self.token_value == 123 {
        if self.compile_block_body(state, function_hash) != 0 {
            return -12
        }

        if return_type_hash > 0 {
            if get_block_return_guaranteed(state, 1) == 1 {
                state.current_return_guaranteed = 1
            }
            if state.current_return_guaranteed == 0 {
                emit_missing_return(return_type_hash, self.token_line, function_hash)
                emit_missing_enum_variants(state)
                state.current_return_type_hash = 0
                state.current_return_seen = 0
                state.current_return_guaranteed = 0
                state.current_block_depth = 0
                state.current_func_hash = 0
                return -18
            }
        }

        state.current_return_type_hash = 0
        state.current_return_seen = 0
        state.current_return_guaranteed = 0
        state.current_block_depth = 0
        state.current_func_hash = 0
        emits("    mov rax, 0")
        emitc(10)
        emit_return_rax()
        return 0
    }

    if self.token_value == 61 {
        variable return_line: i32 = self.token_line
        if self.expect_symbol(62) != 0 {
            return -13
        }

        if self.compile_expression(state, function_hash) != 0 {
            return -14
        }

        if check_return_expression_type(state, return_line) != 0 {
            return -16
        }

        state.current_return_type_hash = 0
        state.current_return_seen = 0
        state.current_return_guaranteed = 0
        state.current_block_depth = 0
        state.current_func_hash = 0
        emit_return_rax()
        return 0
    }

    state.current_return_type_hash = 0
    state.current_return_seen = 0
    state.current_return_guaranteed = 0
    state.current_block_depth = 0
    state.current_func_hash = 0
    return -15
}

function compile_struct_declaration_tail(self: Lexer, state: CompileState) -> i32 {
    variable type_hash: i32 = 0
    variable kind: i32 = 0

    if self.expect_identifier() != 0 {
        return -1
    }
    type_hash = self.token_hash

    if state.ensure_type_slot(type_hash) < 0 {
        return -2
    }

    if self.expect_symbol(123) != 0 {
        return -3
    }

    loop {
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 125 {
                return 0
            }
        }

        self.push_token()
        if self.compile_register_field_declaration_tail(state, type_hash) != 0 {
            return -4
        }
    }
    return 0
}

function compile_enum_declaration_tail(self: Lexer, state: CompileState) -> i32 {
    variable type_hash: i32 = 0
    variable kind: i32 = 0
    variable variant_hash: i32 = 0
    variable has_payload: i32 = false

    if self.expect_identifier() != 0 {
        return -1
    }
    type_hash = self.token_hash

    if state.ensure_type_slot(type_hash) < 0 {
        return -2
    }

    if self.expect_symbol(123) != 0 {
        return -3
    }

    loop {
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 125 {
                return 0
            }
        }

        if kind != token_identifier() {
            return -4
        }
        variant_hash = self.token_hash
        has_payload = false

        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 40 {
                if self.parse_type_name_hash() < 0 {
                    return -5
                }

                if self.expect_symbol(41) != 0 {
                    return -6
                }

                has_payload = true
                kind = self.next_token()
            }
        }

        if state.register_enum_variant(type_hash, variant_hash, has_payload) != 0 {
            return -7
        }

        if kind == token_identifier() {
            self.push_token()
            continue
        }

        if kind != token_symbol() {
            return -8
        }

        if self.token_value == 44 {
            continue
        }

        if self.token_value == 125 {
            return 0
        }

        return -9
    }
    return 0
}

function compile_class_declaration_tail(self: Lexer, state: CompileState) -> i32 {
    variable type_hash: i32 = 0
    variable kind: i32 = 0
    variable field_hash: i32 = 0

    if self.expect_identifier() != 0 {
        return -1
    }
    type_hash = self.token_hash

    if state.ensure_type_slot(type_hash) < 0 {
        return -2
    }

    kind = self.next_token()
    if kind != token_symbol() {
        return -3
    }

    if self.token_value == 58 {
        if self.parse_type_name() != 0 {
            return -4
        }

        if self.expect_symbol(123) != 0 {
            return -5
        }
    } else {
        if self.token_value != 123 {
            return -6
        }
    }

    loop {
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 125 {
                return 0
            }
        }

        if kind == token_identifier() {
            field_hash = self.token_hash
            if self.compile_register_named_field_tail(state, type_hash, field_hash) != 0 {
                return -7
            }
            continue
        }

        if kind != token_keyword() {
            return -8
        }

        if self.token_value == keyword_public() {
            kind = self.next_token()
            if kind != token_keyword() {
                return -9
            }
        } else {
            if self.token_value == keyword_private() {
                kind = self.next_token()
                if kind != token_keyword() {
                    return -10
                }
            } else {
                if self.token_value == keyword_pub() {
                    kind = self.next_token()
                    if kind != token_keyword() {
                        return -11
                    }
                }
            }
        }

        if self.token_value == keyword_value() {
            if self.compile_register_field_declaration_tail(state, type_hash) != 0 {
                return -12
            }
            continue
        }

        if self.token_value == keyword_variable() {
            if self.compile_register_field_declaration_tail(state, type_hash) != 0 {
                return -13
            }
            continue
        }

        if self.token_value == keyword_constant() {
            if self.compile_register_field_declaration_tail(state, type_hash) != 0 {
                return -14
            }
            continue
        }

        if self.token_value == keyword_let() {
            if self.compile_register_field_declaration_tail(state, type_hash) != 0 {
                return -15
            }
            continue
        }

        if self.token_value == keyword_var() {
            if self.compile_register_field_declaration_tail(state, type_hash) != 0 {
                return -16
            }
            continue
        }

        if self.token_value == keyword_function() {
            if self.compile_function_definition_tail(state, type_hash) != 0 {
                return -17
            }
            continue
        }

        if self.token_value == keyword_fn() {
            if self.compile_function_definition_tail(state, type_hash) != 0 {
                return -18
            }
            continue
        }

        return -19
    }
    return 0
}

function compile_implement_declaration_tail(self: Lexer, state: CompileState) -> i32 {
    variable type_hash: i32 = 0
    variable kind: i32 = 0

    if self.expect_identifier() != 0 {
        return -1
    }

    if self.expect_keyword(keyword_for()) != 0 {
        return -2
    }

    type_hash = self.parse_type_name_hash()
    if type_hash < 0 {
        return -3
    }

    if self.expect_symbol(123) != 0 {
        return -4
    }

    loop {
        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 125 {
                return 0
            }
        }

        if kind != token_keyword() {
            return -5
        }

        if self.token_value == keyword_public() {
            kind = self.next_token()
            if kind != token_keyword() {
                return -6
            }
        } else {
            if self.token_value == keyword_private() {
                kind = self.next_token()
                if kind != token_keyword() {
                    return -7
                }
            } else {
                if self.token_value == keyword_pub() {
                    kind = self.next_token()
                    if kind != token_keyword() {
                        return -8
                    }
                }
            }
        }

        if self.token_value == keyword_function() {
            if self.compile_function_definition_tail(state, type_hash) != 0 {
                return -9
            }
            continue
        }

        if self.token_value == keyword_fn() {
            if self.compile_function_definition_tail(state, type_hash) != 0 {
                return -10
            }
            continue
        }

        return -11
    }
    return 0
}

function compile_import_member_list_semantic(self: Lexer, state: CompileState) -> i32 {
    variable kind: i32 = self.next_token()
    variable member_hash: i32 = 0
    variable alias_hash: i32 = 0

    if kind == token_symbol() {
        if self.token_value == 125 {
            return 0
        }

        self.push_token()
    } else {
        self.push_token()
    }

    loop {
        if self.expect_identifier() != 0 {
            return -1
        }
        member_hash = self.token_hash
        alias_hash = member_hash

        kind = self.next_token()
        if kind == token_keyword() {
            if self.token_value == keyword_as() {
                if self.expect_identifier() != 0 {
                    return -2
                }

                alias_hash = self.token_hash
                kind = self.next_token()
            } else {
                return -3
            }
        }

        if member_hash == identifier_hash_print() {
            state.print_alias_hash = alias_hash
        }

        if member_hash == identifier_hash_len() {
            state.len_alias_hash = alias_hash
        }

        if state.record_import_call_alias(alias_hash, member_hash) != 0 {
            return -6
        }

        if kind != token_symbol() {
            return -4
        }

        if self.token_value == 125 {
            return 0
        }

        if self.token_value != 44 {
            return -5
        }
    }
    return 0
}

function compile_import_declaration_semantic(self: Lexer, state: CompileState) -> i32 {
    variable kind: i32 = 0

    if self.expect_keyword(keyword_import()) != 0 {
        return -1
    }

    if self.expect_identifier() != 0 {
        return -2
    }

    loop {
        kind = self.next_token()
        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value != 46 {
            self.push_token()
            return 0
        }

        kind = self.next_token()
        if kind == token_symbol() {
            if self.token_value == 123 {
                return self.compile_import_member_list_semantic(state)
            }
        }

        if kind != token_identifier() {
            return -3
        }
    }
    return 0
}

function compile_from_import_declaration_semantic(self: Lexer, state: CompileState) -> i32 {
    variable member_hash: i32 = 0
    variable alias_hash: i32 = 0
    variable kind: i32 = 0

    if self.expect_keyword(keyword_from()) != 0 {
        return -1
    }

    if self.parse_dotted_name_tail() != 0 {
        return -2
    }

    if self.expect_keyword(keyword_import()) != 0 {
        return -3
    }

    loop {
        if self.expect_identifier() != 0 {
            return -4
        }
        member_hash = self.token_hash
        alias_hash = member_hash

        kind = self.next_token()
        if kind == token_keyword() {
            if self.token_value == keyword_as() {
                if self.expect_identifier() != 0 {
                    return -5
                }

                alias_hash = self.token_hash
                kind = self.next_token()
            } else {
                self.push_token()
                return 0
            }
        }

        if member_hash == identifier_hash_print() {
            state.print_alias_hash = alias_hash
        }

        if member_hash == identifier_hash_len() {
            state.len_alias_hash = alias_hash
        }

        if state.record_import_call_alias(alias_hash, member_hash) != 0 {
            return -6
        }

        if kind != token_symbol() {
            self.push_token()
            return 0
        }

        if self.token_value != 44 {
            self.push_token()
            return 0
        }
    }
    return 0
}

function compile_skip_preamble(self: Lexer, state: CompileState) -> i32 {
    variable kind: i32 = self.next_token()

    loop {
        if kind == token_symbol() {
            if self.token_value == 64 {
                self.push_token()
                if self.parse_annotation() != 0 {
                    return -1
                }

                kind = self.next_token()
                continue
            }
        }

        if kind != token_keyword() {
            self.push_token()
            return 0
        }

        if self.token_value == keyword_module() {
            self.push_token()
            if self.parse_module_declaration() != 0 {
                return -2
            }

            kind = self.next_token()
            continue
        }

        if self.token_value == keyword_import() {
            self.push_token()
            if self.compile_import_declaration_semantic(state) != 0 {
                return -3
            }

            kind = self.next_token()
            continue
        }

        if self.token_value == keyword_from() {
            self.push_token()
            if self.compile_from_import_declaration_semantic(state) != 0 {
                return -4
            }

            kind = self.next_token()
            continue
        }

        self.push_token()
        return 0
    }
    return 0
}

