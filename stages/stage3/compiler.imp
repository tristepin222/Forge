            return self.token_kind
        }

        if hash == keyword_hash_let() {
            self.token_kind = token_keyword()
            self.token_value = keyword_let()
            return self.token_kind
        }

        if hash == keyword_hash_var() {
            self.token_kind = token_keyword()
