    emits("], rax")
    emitc(10)
}

function emit_load_array_base(function_hash: i32, variable_hash: i32, variable_mode: i32) {
    if variable_mode == 1 {
        emit_load_variable(function_hash, variable_hash)
        return 0
    }

    emits("    lea rax, [")
    emit_variable_name(function_hash, variable_hash)
    emits("]")
