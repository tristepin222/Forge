    }

    if self.parse_block_body() != 0 {
        return -2
    }

    return 0
}

function parse_for_tail(self: Lexer) -> i32 {
    if self.expect_identifier() != 0 {
        return -1
    }

    if self.expect_keyword(keyword_in()) != 0 {
        return -2
    }

    if self.parse_expression() != 0 {
        return -3
    }

    if self.expect_symbol(46) != 0 {
        return -4
    }

    if self.expect_symbol(46) != 0 {
        return -5
    }

    if self.parse_expression() != 0 {
        return -6
    }

    if self.expect_symbol(123) != 0 {
        return -7
    }

    if self.parse_block_body() != 0 {
        return -8
    }

    return 0
}

function parse_unsafe_tail(self: Lexer) -> i32 {
    if self.expect_symbol(123) != 0 {
        return -1
    }

    if self.parse_block_body() != 0 {
        return -2
    }

    return 0
}

function parse_try_tail(self: Lexer) -> i32 {
    variable kind: i32 = 0
    variable saw_handler: i32 = false

    if self.expect_symbol(123) != 0 {
        return -1
    }

    if self.parse_block_body() != 0 {
        return -2
    }

    kind = self.next_token()
    if kind == token_keyword() {
        if self.token_value == keyword_catch() {
            saw_handler = true

            kind = self.next_token()
            if kind == token_identifier() {
                kind = self.next_token()
                if kind == token_symbol() {
                    if self.token_value == 58 {
                        if self.parse_type_name() != 0 {
                            return -3
                        }
                    } else {
                        self.push_token()
                    }
                } else {
                    self.push_token()
                }
            } else {
                self.push_token()
            }

            if self.expect_symbol(123) != 0 {
                return -4
            }

            if self.parse_block_body() != 0 {
                return -5
            }

            kind = self.next_token()
        }
    }

    if kind == token_keyword() {
        if self.token_value == keyword_finally() {
            saw_handler = true

            if self.expect_symbol(123) != 0 {
                return -6
            }

            if self.parse_block_body() != 0 {
                return -7
            }

            return 0
        }
    }

    self.push_token()

    if saw_handler == false {
        return -8
    }

    return 0
}

function parse_match_tail(self: Lexer) -> i32 {
    variable kind: i32 = 0

    if self.parse_expression() != 0 {
        return -1
    }

    if self.expect_symbol(123) != 0 {
        return -2
    }

    loop {
        kind = self.next_token()

        if kind == token_symbol() {
            if self.token_value == 125 {
                return 0
            }
        }

        if kind == token_keyword() {
            if self.token_value == keyword_default() {
                if self.expect_symbol(61) != 0 {
                    return -3
                }

                if self.expect_symbol(62) != 0 {
                    return -4
                }

                if self.expect_symbol(123) != 0 {
                    return -5
                }

                if self.parse_block_body() != 0 {
                    return -6
                }

                continue
            }
        }

        self.push_token()

        if self.parse_expression() != 0 {
            return -7
        }

        if self.expect_symbol(61) != 0 {
            return -8
        }

        if self.expect_symbol(62) != 0 {
            return -9
        }

        if self.expect_symbol(123) != 0 {
            return -10
        }

        if self.parse_block_body() != 0 {
            return -11
        }
    }
    return 0
}

function parse_statement(self: Lexer) -> i32 {
    variable kind: i32 = self.next_token()

    if kind == token_identifier() {
        return self.parse_identifier_statement_tail()
    }

    if kind == token_keyword() {
        if self.token_value == keyword_return() {
            return self.parse_return_tail()
        }

        if self.token_value == keyword_value() {
            return self.parse_binding_tail()
        }

        if self.token_value == keyword_let() {
            return self.parse_binding_tail()
        }

        if self.token_value == keyword_variable() {
            return self.parse_binding_tail()
        }

        if self.token_value == keyword_var() {
            return self.parse_binding_tail()
        }

        if self.token_value == keyword_constant() {
            return self.parse_binding_tail()
        }

        if self.token_value == keyword_throw() {
            return self.parse_throw_tail()
        }

        if self.token_value == keyword_if() {
            return self.parse_if_tail()
        }

        if self.token_value == keyword_while() {
            return self.parse_while_tail()
        }

        if self.token_value == keyword_loop() {
            return self.parse_loop_tail()
        }

        if self.token_value == keyword_for() {
            return self.parse_for_tail()
        }

        if self.token_value == keyword_match() {
            return self.parse_match_tail()
        }

        if self.token_value == keyword_unsafe() {
            return self.parse_unsafe_tail()
        }

        if self.token_value == keyword_try() {
            return self.parse_try_tail()
        }

        if self.token_value == keyword_break() {
            return 0
        }

        if self.token_value == keyword_continue() {
            return 0
        }
    }

    return -2
}

function parse_block_body(self: Lexer) -> i32 {
    loop {
        variable kind: i32 = self.next_token()

        if kind == token_symbol() {
            if self.token_value == 125 {
                return 0
            }
        }

