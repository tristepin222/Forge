function emit_function_label(function_hash: i32) {
    emit_function_name(function_hash)
    emits(":")
    emitc(10)
}

function emit_call_function(function_hash: i32) {
    emits("    call ")
    emit_function_name(function_hash)
    emitc(10)
}

function emit_pop_call_argument(index: i32) -> i32 {
    if index == 0 {
        emits("    pop rdi")
        emitc(10)
        return 0
    }

    if index == 1 {
        emits("    pop rsi")
        emitc(10)
        return 0
    }

    if index == 2 {
        emits("    pop rdx")
        emitc(10)
        return 0
    }

    if index == 3 {
        emits("    pop rcx")
        emitc(10)
        return 0
    }

    if index == 4 {
        emits("    pop r8")
        emitc(10)
        return 0
    }

    if index == 5 {
        emits("    pop r9")
        emitc(10)
        return 0
    }

    return -1
}

function emit_store_argument_variable(function_hash: i32, variable_hash: i32, index: i32) -> i32 {
    if index == 0 {
        emits("    mov rax, rdi")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 1 {
        emits("    mov rax, rsi")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 2 {
        emits("    mov rax, rdx")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 3 {
        emits("    mov rax, rcx")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 4 {
        emits("    mov rax, r8")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    if index == 5 {
        emits("    mov rax, r9")
        emitc(10)
        emit_store_variable(function_hash, variable_hash)
        return 0
    }

    return -1
}

